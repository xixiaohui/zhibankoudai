/**app.wxss - 智伴口袋全局样式**/

/* 主题色变量 */
page {
  --primary: #6C63FF;
  --primary-light: #EEF0FF;
  --secondary: #FF6584;
  --accent: #43D9AD;
  --warning: #FFB347;
  --danger: #FF5252;
  --success: #4CAF50;
  --text-main: #1A1A2E;
  --text-sub: #666680;
  --text-light: #999BB8;
  --bg: #F7F8FC;
  --bg-card: #FFFFFF;
  --border: #EEEEF5;
  --shadow: 0 4rpx 24rpx rgba(108, 99, 255, 0.10);
  --radius: 24rpx;
  --radius-sm: 12rpx;
  background: var(--bg);
  font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', sans-serif;
  color: var(--text-main);
  font-size: 28rpx;
}

/* 重置 */
.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  box-sizing: border-box;
  background: var(--bg);
}

button {
  background: initial;
  padding: 0;
  margin: 0;
  border: none;
  line-height: initial;
}
button:focus { outline: 0; }
button::after { border: none; }

/* 卡片 */
.card {
  background: var(--bg-card);
  border-radius: var(--radius);
  padding: 32rpx;
  margin: 16rpx 24rpx;
  box-shadow: var(--shadow);
}

/* 标题 */
.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-main);
  padding: 32rpx 32rpx 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 20rpx;
}

/* 主按钮 */
.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--primary);
  color: #fff;
  border-radius: 100rpx;
  height: 88rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(108, 99, 255, 0.35);
}

.btn-outline {
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  color: var(--primary);
  border: 2rpx solid var(--primary);
  border-radius: 100rpx;
  height: 80rpx;
  font-size: 28rpx;
  font-weight: 500;
}

/* 标签 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 18rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-primary { background: var(--primary-light); color: var(--primary); }
.tag-success { background: #E8F5E9; color: var(--success); }
.tag-danger { background: #FFEBEE; color: var(--danger); }
.tag-warning { background: #FFF8E1; color: var(--warning); }

/* 分隔线 */
.divider {
  height: 1rpx;
  background: var(--border);
  margin: 20rpx 0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  color: var(--text-light);
}
.empty-state .empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}
.empty-state text {
  font-size: 28rpx;
}

/* 浮动按钮 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 160rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  background: var(--primary);
  color: #fff;
  font-size: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(108, 99, 255, 0.45);
  z-index: 100;
}

/* 弹窗蒙层 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(26, 26, 46, 0.5);
  z-index: 200;
  display: flex;
  align-items: flex-end;
}

.modal-box {
  width: 100%;
  background: #fff;
  border-radius: 40rpx 40rpx 0 0;
  padding: 40rpx 32rpx 60rpx;
  box-sizing: border-box;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-main);
  text-align: center;
  margin-bottom: 32rpx;
}

/* 输入框 */
.input-item {
  background: var(--bg);
  border-radius: var(--radius-sm);
  padding: 24rpx;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  color: var(--text-main);
  width: 100%;
  box-sizing: border-box;
}

/* 渐变背景 */
.gradient-header {
  background: linear-gradient(135deg, #6C63FF 0%, #9B59B6 100%);
  padding: 40rpx 32rpx 60rpx;
  color: #fff;
  position: relative;
  overflow: hidden;
}

.gradient-header::before {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
}
.gradient-header::after {
  content: '';
  position: absolute;
  bottom: -80rpx;
  left: -40rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.05);
}

/* 图标文字组合 */
.icon-label {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.icon-label text:first-child {
  font-size: 48rpx;
}
.icon-label text:last-child {
  font-size: 22rpx;
  color: var(--text-sub);
}

/* flex工具 */
.flex { display: flex; }
.flex-column { display: flex; flex-direction: column; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-1 { flex: 1; }
.gap-8 { gap: 8rpx; }
.gap-16 { gap: 16rpx; }
.gap-24 { gap: 24rpx; }

/* 安全区域 */
.safe-bottom { padding-bottom: env(safe-area-inset-bottom); }
