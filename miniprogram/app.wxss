/** app.wxss - 全局样式表 **/
/* 智伴口袋 - 统一设计语言 */

/* 主题色 */
page {
  /* 主色调 */
  --primary-color: #7C6AFF;
  --primary-light: #9D8FFF;
  --primary-dark: #6555E8;
  
  /* 功能色 */
  --success-color: #34D399;
  --warning-color: #FFCA28;
  --danger-color: #FF6B6B;
  --info-color: #60A5FA;
  
  /* 中性色 */
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-placeholder: #999999;
  --text-disabled: #CCCCCC;
  
  --bg-primary: #FFFFFF;
  --bg-secondary: #F7F7F7;
  --bg-tertiary: #F0F0F0;
  --bg-gradient-start: #F8F6FF;
  --bg-gradient-end: #F0EDFF;
  
  /* 边框 */
  --border-color: #E5E5E5;
  --border-light: #F0F0F0;
  
  /* 阴影 */
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  --shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  --shadow-lg: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  --shadow-primary: 0 8rpx 32rpx rgba(124, 106, 255, 0.2);
  
  /* 圆角 */
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  --radius-full: 999rpx;
  
  /* 字体大小 */
  --font-xs: 22rpx;
  --font-sm: 24rpx;
  --font-base: 28rpx;
  --font-lg: 32rpx;
  --font-xl: 36rpx;
  --font-xxl: 48rpx;
}

/* 全局页面样式 */
page {
  background-color: var(--bg-secondary);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
  font-size: var(--font-base);
  color: var(--text-primary);
  line-height: 1.5;
}

/* 通用容器 */
.page-container {
  min-height: 100vh;
  background: linear-gradient(135deg, var(--bg-gradient-start) 0%, var(--bg-gradient-end) 100%);
  padding: 20rpx 30rpx 100rpx;
}

/* 通用卡片 */
.card {
  background: var(--bg-primary);
  border-radius: var(--radius-xl);
  padding: 30rpx;
  box-shadow: var(--shadow-md);
}

/* 通用按钮 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 40rpx;
  border-radius: var(--radius-md);
  font-size: var(--font-base);
  font-weight: 500;
  transition: all 0.2s;
  border: none;
}

.btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  color: white;
  box-shadow: var(--shadow-primary);
}

.btn-secondary {
  background: var(--bg-secondary);
  color: var(--text-primary);
  border: 1rpx solid var(--border-color);
}

.btn-danger {
  background: var(--danger-color);
  color: white;
}

/* 输入框 */
.input {
  width: 100%;
  padding: 24rpx 30rpx;
  background: var(--bg-primary);
  border: 2rpx solid var(--border-color);
  border-radius: var(--radius-md);
  font-size: var(--font-base);
  color: var(--text-primary);
  transition: border-color 0.2s;
}

.input:focus {
  border-color: var(--primary-color);
}

.input::placeholder {
  color: var(--text-placeholder);
}

/* 文本域 */
.textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx 30rpx;
  background: var(--bg-secondary);
  border: none;
  border-radius: var(--radius-md);
  font-size: var(--font-base);
  color: var(--text-primary);
  line-height: 1.6;
}

.textarea::placeholder {
  color: var(--text-placeholder);
}

/* 标题 */
.section-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

/* 标签 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  background: rgba(124, 106, 255, 0.1);
  color: var(--primary-color);
  border-radius: var(--radius-full);
  font-size: var(--font-sm);
}

/* 分隔线 */
.divider {
  height: 1rpx;
  background: var(--border-light);
  margin: 20rpx 0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: var(--font-lg);
  color: var(--text-placeholder);
  margin-bottom: 10rpx;
}

.empty-desc {
  font-size: var(--font-sm);
  color: var(--text-disabled);
}

/* 动画 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes pulse {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.5;
  }
}

.animate-fade-in {
  animation: fadeIn 0.3s ease;
}

.animate-pulse {
  animation: pulse 1.5s infinite;
}

/* 列表项 */
.list-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  background: var(--bg-primary);
  border-radius: var(--radius-md);
  margin-bottom: 16rpx;
  transition: all 0.2s;
}

.list-item:active {
  background: var(--bg-secondary);
}

.list-item-content {
  flex: 1;
}

.list-item-title {
  font-size: var(--font-base);
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.list-item-desc {
  font-size: var(--font-sm);
  color: var(--text-secondary);
}

/* 徽章 */
.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 12rpx;
  background: var(--danger-color);
  color: white;
  border-radius: var(--radius-full);
  font-size: var(--font-xs);
  font-weight: 500;
}

/* 加载动画 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.loading-dot {
  width: 16rpx;
  height: 16rpx;
  background: var(--primary-color);
  border-radius: 50%;
  margin: 0 8rpx;
  animation: pulse 1s infinite;
}

.loading-dot:nth-child(2) {
  animation-delay: 0.2s;
}

.loading-dot:nth-child(3) {
  animation-delay: 0.4s;
}
