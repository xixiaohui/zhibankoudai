/**app.wxss**/
/* 全局样式 */

page {
  background: #F8F6FF;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

/* 主题色变量 */
page {
  --theme-color: #7C6AFF;
  --theme-gradient: linear-gradient(135deg, #7C6AFF 0%, #A594F9 100%);
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-placeholder: #999999;
  --bg-primary: #F8F6FF;
  --bg-white: #FFFFFF;
  --border-color: #F0EEFF;
  --shadow-light: 0 4rpx 20rpx rgba(124, 106, 255, 0.08);
  --shadow-medium: 0 8rpx 30rpx rgba(124, 106, 255, 0.12);
}

/* 通用按钮样式 */
.btn-primary {
  background: var(--theme-gradient);
  color: #FFFFFF;
  border: none;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary::after {
  border: none;
}

.btn-primary:active {
  opacity: 0.9;
}

/* 通用卡片样式 */
.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: var(--shadow-light);
}

/* 通用区块标题 */
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

/* 通用分隔线 */
.divider {
  height: 1rpx;
  background: #F0F0F0;
  margin: 20rpx 0;
}

/* 通用空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-placeholder);
}

/* Toast 样式增强 */
.wx-toast {
  background: rgba(0, 0, 0, 0.8) !important;
  color: #FFFFFF !important;
}

/* Modal 样式 */
.weui-modal {
  border-radius: 24rpx !important;
  overflow: hidden;
}

.weui-modal__bd {
  padding: 40rpx 30rpx !important;
  font-size: 28rpx !important;
  line-height: 1.6 !important;
}

.weui-modal__ft {
  padding: 20rpx 30rpx 30rpx !important;
}

.weui-dialog__btn_primary {
  color: var(--theme-color) !important;
}

/* 安全区域适配 */
.safe-area-bottom {
  padding-bottom: calc(env(safe-area-inset-bottom) + 20rpx);
}

.safe-area-top {
  padding-top: env(safe-area-inset-top);
}

/* 动画 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.fade-in {
  animation: fadeIn 0.3s ease-out;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.05);
  }
}

.pulse {
  animation: pulse 2s infinite;
}

/* 隐藏滚动条 */
.hide-scrollbar {
  scrollbar-width: none;
  -ms-overflow-style: none;
}

.hide-scrollbar::-webkit-scrollbar {
  display: none;
}
