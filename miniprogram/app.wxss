/** app.wxss - 全局样式表 **/
/* Pinterest Design System - 智伴口袋 */

page {
  /* Pinterest Design System Colors */
  --primary: #E60023;
  --surface: #FFFFFF;
  --surface-secondary: #FAFAFA;
  --surface-accent: #F5F5F5;
  --border: #E0E0E0;
  --text-primary: #211922;
  --text-secondary: #62625B;
  --text-placeholder: #9A9A9A;
  --accent-warm-light: #E0E0D9;
  --focus-ring: #435EE5;
  --overlay: rgba(33, 25, 34, 0.6);
  
  /* Functional Colors */
  --success: #211922;
  --warning: #62625B;
  --danger: #E60023;
  --info: #435EE5;
  
  /* Pinterest Typography */
  --font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
  --font-size-xs: 20rpx;
  --font-size-sm: 22rpx;
  --font-size-base: 24rpx;
  --font-size-lg: 28rpx;
  --font-size-xl: 32rpx;
  --font-size-xxl: 40rpx;
  --font-size-xxxl: 48rpx;
  
  /* Pinterest Spacing */
  --space-xs: 8rpx;
  --space-sm: 12rpx;
  --space-md: 16rpx;
  --space-lg: 24rpx;
  --space-xl: 32rpx;
  --space-xxl: 48rpx;
  
  /* Pinterest Border Radius */
  --radius-sm: 12rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-full: 999rpx;
}

/* Global Page Styles */
.page {
  background-color: var(--surface-secondary);
  font-family: var(--font-family);
  font-size: var(--font-size-base);
  color: var(--text-primary);
  line-height: 1.5;
}

/* Focus Ring for Accessibility - 使用类名替代通配符 */
.focus-ring:focus {
  outline: 2rpx solid var(--focus-ring);
  outline-offset: 2rpx;
}

/* Page Container */
.page-container {
  min-height: 100vh;
  background-color: var(--surface-secondary);
  padding: var(--space-lg) var(--space-lg) 100rpx;
}

/* Card Component */
.card {
  background-color: var(--surface);
  border-radius: var(--radius-lg);
  padding: var(--space-xl);
  border: 1rpx solid var(--border);
}

/* Primary Button */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 40rpx;
  border-radius: var(--radius-md);
  font-size: var(--font-size-base);
  font-weight: 500;
  border: none;
  transition: all 0.2s ease;
}

.btn-primary {
  background-color: var(--primary);
  color: var(--surface);
}

.btn-secondary {
  background-color: var(--accent-warm-light);
  color: var(--text-primary);
}

.btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

/* Input Field */
.input {
  width: 100%;
  padding: 24rpx var(--space-lg);
  background-color: var(--surface);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-md);
  font-size: var(--font-size-base);
  color: var(--text-primary);
}

.input:focus {
  border-color: var(--focus-ring);
}

.input::placeholder {
  color: var(--text-placeholder);
}

/* Textarea */
.textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx var(--space-lg);
  background-color: var(--surface-accent);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-md);
  font-size: var(--font-size-base);
  color: var(--text-primary);
  line-height: 1.6;
}

.textarea::placeholder {
  color: var(--text-placeholder);
}

/* Section Title */
.section-title {
  font-size: var(--font-size-lg);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--space-md);
}

/* Tag */
.tag {
  display: inline-flex;
  align-items: center;
  padding: var(--space-xs) var(--space-sm);
  background-color: var(--accent-warm-light);
  color: var(--text-primary);
  border-radius: var(--radius-full);
  font-size: var(--font-size-sm);
}

/* Divider */
.divider {
  height: 1rpx;
  background-color: var(--border);
  margin: var(--space-md) 0;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-xxl) var(--space-lg);
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: var(--space-md);
  opacity: 0.5;
}

.empty-text {
  font-size: var(--font-size-lg);
  color: var(--text-placeholder);
  margin-bottom: var(--space-xs);
}

.empty-desc {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
}

/* Animation */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes pulse {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.5;
  }
}

.animate-fade-in {
  animation: fadeIn 0.3s ease;
}

.animate-pulse {
  animation: pulse 1.5s infinite;
}

/* List Item */
.list-item {
  display: flex;
  align-items: center;
  padding: 24rpx var(--space-lg);
  background-color: var(--surface);
  border-radius: var(--radius-md);
  margin-bottom: var(--space-sm);
  border: 1rpx solid var(--border);
}

.list-item:active {
  background-color: var(--surface-accent);
}

.list-item-content {
  flex: 1;
}

.list-item-title {
  font-size: var(--font-size-base);
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.list-item-desc {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
}

/* Badge */
.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 12rpx;
  background-color: var(--primary);
  color: var(--surface);
  border-radius: var(--radius-full);
  font-size: var(--font-size-xs);
  font-weight: 500;
}

/* Loading */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-lg);
}

.loading-dot {
  width: 16rpx;
  height: 16rpx;
  background-color: var(--text-secondary);
  border-radius: 50%;
  margin: 0 8rpx;
  animation: pulse 1s infinite;
}

.loading-dot:nth-child(2) {
  animation-delay: 0.2s;
}

.loading-dot:nth-child(3) {
  animation-delay: 0.4s;
}
