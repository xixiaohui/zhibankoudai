/* app.wxss - 智伴口袋全局样式 */

/* ===== 主题色变量 ===== */
page {
  --primary: #6C63FF;
  --secondary: #FF6584;
  --accent: #43D9AD;
  --warning: #FFB347;
  --bg: #F7F8FC;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-hint: #999999;
  --border: #EEEEEE;
  --white: #FFFFFF;
}

/* ===== 全局通用样式 ===== */
.container {
  min-height: 100vh;
  background: var(--bg);
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.flex-1 {
  flex: 1;
}

/* ===== 卡片通用样式 ===== */
.section-card {
  background: var(--white);
  border-radius: 20rpx;
  padding: 28rpx;
  margin: 0 24rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.section-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-t {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.section-more {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* ===== 按钮通用样式 ===== */
.btn-primary {
  background: var(--primary);
  color: var(--white);
  border-radius: 12rpx;
  font-size: 28rpx;
  padding: 24rpx 0;
  text-align: center;
}

.btn-secondary {
  background: var(--bg);
  color: var(--text-secondary);
  border-radius: 12rpx;
  font-size: 28rpx;
  padding: 24rpx 0;
  text-align: center;
}

/* ===== 列表通用样式 ===== */
.list-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.list-item:last-child {
  border-bottom: none;
}

/* ===== 空状态通用样式 ===== */
.empty-hint {
  text-align: center;
  padding: 48rpx 24rpx;
  color: var(--text-hint);
  font-size: 26rpx;
}

/* ===== 输入框通用样式 ===== */
.input-group {
  margin-bottom: 32rpx;
}

.input-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  display: block;
}

.input-field {
  background: var(--bg);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
}

/* ===== 模态框通用样式 ===== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
}

.modal-content {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--white);
  border-radius: 32rpx 32rpx 0 0;
  z-index: 1000;
  max-height: 85vh;
}

/* ===== 标签通用样式 ===== */
.tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.tag-primary {
  background: rgba(108, 99, 255, 0.1);
  color: var(--primary);
}

.tag-success {
  background: rgba(67, 217, 173, 0.1);
  color: var(--accent);
}

.tag-warning {
  background: rgba(255, 179, 71, 0.1);
  color: var(--warning);
}

/* ===== 动画通用样式 ===== */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from { transform: translateY(20rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.fade-in {
  animation: fadeIn 0.3s ease;
}

.slide-up {
  animation: slideUp 0.3s ease;
}
