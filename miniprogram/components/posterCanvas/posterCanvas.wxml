<!-- components/posterCanvas/posterCanvas.wxml -->
<view class="poster-overlay" wx:if="{{visible}}">
  <view class="mask" bindtap="closePoster"></view>
  
  <view class="poster-modal">
    <!-- 关闭按钮 -->
    <view class="close-btn" bindtap="closePoster">×</view>
    
    <!-- 海报预览 -->
    <view class="poster-preview">
      <image 
        wx:if="{{posterPath}}"
        class="poster-image" 
        src="{{posterPath}}" 
        mode="aspectFit"
      />
      <view wx:else class="poster-loading">
        <text>海报生成中...</text>
      </view>
    </view>
    
    <!-- 操作按钮 -->
    <view class="action-row">
      <button class="action-btn save-btn" bindtap="saveToAlbum" hover-class="btn-active">
        <text class="btn-icon">💾</text>
        <text class="btn-text">保存图片</text>
      </button>
      <button class="action-btn share-btn" open-type="share" hover-class="btn-active">
        <text class="btn-icon">📤</text>
        <text class="btn-text">转发好友</text>
      </button>
    </view>
  </view>

  <!-- 隐藏的 Canvas -->
  <canvas canvas-id="posterCanvas" class="hidden-canvas" style="width:{{canvasWidth}}px;height:{{canvasHeight}}px;"></canvas>
</view>
