        <text class="trade-tag" wx:if="{{content.tips}}" style="background: {{config.colors.bg}}; color: {{config.colors.accent}};">📝 {{content.tips}}</text>
      </view>
      <view class="trade-tags" wx:if="{{content.tags && content.tags.length > 0}}">
