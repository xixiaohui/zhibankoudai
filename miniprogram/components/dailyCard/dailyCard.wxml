      </view>
      <view class="trade-summary" style="color: {{config.colors.textSecondary}};">{{content.summary}}</view>
      <view class="trade-tips" wx:if="{{content.tips}}" style="color: {{config.colors.accent}}; background: {{config.colors.bg}};">
