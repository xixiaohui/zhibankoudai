<!-- components/dailyCard/dailyCard.wxml - 每日内容卡片组件 -->
<view class="daily-card-wrapper" wx:if="{{!isHidden}}">
  <view class="section-title-row">
    <view class="section-title">
      <text class="title-icon">{{config.icon}}</text>
      <text class="title-text">{{config.name}}</text>
    </view>
    <view class="action-btns-row">
      <!-- 了解更多按钮 -->
      <view 
        class="more-btn focus-ring"
        bindtap="onViewMore" 
        hover-class="btn-active"
      >
        <text class="more-icon">›</text>
        <text class="more-text">更多</text>
      </view>
      <!-- 分享按钮 -->
      <view 
        class="share-btn focus-ring" 
        bindtap="onShare" 
        hover-class="btn-active"
      >
        <text class="share-icon">↗</text>
      </view>
      <!-- 刷新按钮 -->
      <view 
        class="refresh-btn focus-ring {{isLoading ? 'loading' : ''}}" 
        bindtap="onRefresh" 
        hover-class="btn-active"
      >
        <text class="refresh-icon {{isLoading ? 'spin' : ''}}">↻</text>
        <text class="refresh-text">{{isLoading ? '生成中...' : config.refreshText}}</text>
      </view>
    </view>
  </view>

  <!-- 内容卡片 - Pinterest Card Style -->
  <view 
    class="content-card" 
    wx:if="{{content && !isLoading}}"
  >
    <!-- 标签区域 -->
    <view class="card-tags" wx:if="{{tags.length > 0}}">
      <block wx:for="{{tags}}" wx:key="index">
        <view 
          class="tag-item" 
          wx:if="{{item.type === 'field'}}"
          style="background: {{config.colors.bg}};"
        >
          <text class="tag-icon">{{item.icon}}</text>
          <text class="tag-text" style="color: {{config.colors.accent}};">{{item.text}}</text>
        </view>
        <view 
          class="tag-item ai-tag" 
          wx:elif="{{item.type === 'ai'}}"
          style="background: {{config.colors.bg}}; color: {{config.colors.primary}};"
        >
          <text class="tag-text">{{item.text}}</text>
        </view>
        <view 
          class="tag-item meta-tag" 
          wx:elif="{{item.type === 'meta'}}"
          style="background: {{config.colors.bg}}; color: {{config.colors.accent}};"
        >
          <text>{{item.text}}</text>
        </view>
      </block>
    </view>


    <!-- 内容区域 - 根据类型渲染 -->
    <block wx:if="{{moduleType === 'quote'}}">
      <view class="quote-content" style="color: {{config.colors.text}};">"{{content.content}}"</view>
      <view class="quote-author" style="color: {{config.colors.textSecondary}};">—— {{content.title}}</view>
      <view class="quote-meta" wx:if="{{content.subtitle}}">
        <text class="source-tag" style="background: {{config.colors.bg}}; color: {{config.colors.accent}};">{{content.subtitle}}</text>
        <text class="category-tag" style="background: {{config.colors.bg}}; color: {{config.colors.accent}};">{{content.category}}</text>
      </view>
    </block>

    <block wx:elif="{{moduleType === 'joke'}}">
      <view class="joke-header" style="border-bottom: 1rpx solid {{config.colors.bg}};">
        <text class="joke-title" style="color: {{config.colors.primary}};">{{content.title}}</text>
      </view>
      <view class="joke-content" style="color: {{config.colors.textSecondary}};">{{content.content}}</view>
      <view class="joke-footer" wx:if="{{content.source}}">
        <text class="joke-source">📌 出处：{{content.source}}</text>
      </view>
    </block>

    <block wx:elif="{{moduleType === 'psychology' || moduleType === 'finance'}}">
      <view class="knowledge-header" style="border-bottom: 1rpx solid {{config.colors.bg}};">
        <text class="knowledge-title" style="color: {{config.colors.text}};">{{content.title}}</text>
      </view>
      <view class="knowledge-content" style="color: {{config.colors.textSecondary}};">{{content.content}}</view>
      <view class="knowledge-tags" wx:if="{{content.category || content.subtitle}}">
        <text class="knowledge-tag" wx:if="{{content.category}}" style="background: {{config.colors.bg}}; color: {{config.colors.accent}};">{{content.category}}</text>
        <text class="knowledge-tag subtitle-tag" wx:if="{{content.subtitle}}" style="background: {{config.colors.bg}}; color: {{config.colors.primary}};">💡 {{content.subtitle}}</text>
      </view>
    </block>

    <block wx:elif="{{moduleType === 'love'}}">
      <!-- 情话内容 -->
      <view class="love-content" style="color: {{config.colors.text}};">"{{content.content}}"</view>
      <!-- 作者信息 -->
      <view class="love-author" style="color: {{config.colors.textSecondary}}; border-top: 1rpx solid {{config.colors.bg}};">
        <text class="author-prefix">——</text>
        <text class="author-name" style="color: {{config.colors.accent}};">{{content.author}}</text>
      </view>
      <!-- 出处 + 国内外标签 -->
      <view class="love-meta" wx:if="{{content.source || content.region}}">
        <text class="love-source" wx:if="{{content.source}}" style="color: {{config.colors.textSecondary}};">📖 {{content.source}}</text>
        <text class="love-region" wx:if="{{content.region}}" style="background: {{config.colors.bg}}; color: {{config.colors.accent}};">🌏 {{content.region}}</text>
      </view>
      <!-- 一句话总结 -->
      <view class="love-subtitle" wx:if="{{content.subtitle}}" style="color: {{config.colors.primary}}; background: {{config.colors.bg}};">
        <text>{{content.subtitle}}</text>
      </view>
    </block>

    <block wx:elif="{{moduleType === 'movie'}}">
      <view class="movie-header" style="border-bottom: 1rpx solid {{config.colors.bg}};">
        <text class="movie-title" style="color: {{config.colors.primary}};">{{content.title}}</text>
        <view class="movie-rating" style="background: {{config.colors.bg}};" wx:if="{{content.rating}}">
          <text style="color: {{config.colors.accent}};">⭐ {{content.rating}}</text>
        </view>
      </view>
      <view class="movie-meta" wx:if="{{content.director || content.year}}">
        <text class="movie-director" style="color: {{config.colors.textSecondary}};" wx:if="{{content.director}}">导演：{{content.director}}</text>
        <text class="movie-year" style="color: {{config.colors.accent}};" wx:if="{{content.year}}">{{content.year}}年</text>
      </view>
      <view class="movie-summary" style="color: {{config.colors.textSecondary}};">{{content.summary || content.content}}</view>
      <view class="movie-quote" wx:if="{{content.quote}}" style="color: {{config.colors.accent}}; background: {{config.colors.bg}};">
        <text>"{{content.quote}}"</text>
      </view>
      <view class="movie-tags" wx:if="{{content.tags && content.tags.length > 0}}">
        <block wx:for="{{content.tags}}" wx:key="index">
          <text class="movie-tag" style="background: {{config.colors.bg}}; color: {{config.colors.accent}};">{{item}}</text>
        </block>
      </view>
    </block>

    <block wx:elif="{{moduleType === 'music'}}">
      <view class="music-header" style="border-bottom: 1rpx solid {{config.colors.bg}};">
        <text class="music-title" style="color: {{config.colors.primary}};">{{content.title}}</text>
        <view class="music-mood" wx:if="{{content.mood}}" style="background: {{config.colors.bg}};">
          <text style="color: {{config.colors.accent}};">{{content.moodIcon || '🎵'}} {{content.mood}}</text>
        </view>
      </view>
      <view class="music-meta" wx:if="{{content.artist || content.year}}">
        <text class="music-artist" style="color: {{config.colors.textSecondary}};" wx:if="{{content.artist}}">{{content.artist}}</text>
        <text class="music-year" style="color: {{config.colors.accent}};" wx:if="{{content.year}}">{{content.year}}</text>
      </view>
      <view class="music-album" wx:if="{{content.album}}" style="color: {{config.colors.textSecondary}};">
        <text class="album-label">专辑：</text><text>{{content.album}}</text>
        <text wx:if="{{content.duration}}" class="music-duration"> · {{content.duration}}</text>
      </view>
      <view class="music-content" style="color: {{config.colors.textSecondary}};">{{content.description || content.content}}</view>
      <view class="music-lyric" wx:if="{{content.lyric}}" style="color: {{config.colors.accent}}; background: {{config.colors.bg}};">
        <text>"{{content.lyric}}"</text>
      </view>
      <view class="music-tags" wx:if="{{content.tags && content.tags.length > 0}}">
        <block wx:for="{{content.tags}}" wx:key="index">
          <text class="music-tag" style="background: {{config.colors.bg}}; color: {{config.colors.accent}};">{{item}}</text>
        </block>
      </view>
    </block>

    <block wx:elif="{{moduleType === 'tech'}}">
      <view class="tech-header" style="border-bottom: 1rpx solid {{config.colors.bg}};">
        <text class="tech-title" style="color: {{config.colors.primary}};">{{content.title}}</text>
        <text class="tech-category" wx:if="{{content.category}}" style="color: {{config.colors.accent}};">{{content.category}}</text>
      </view>
      <view class="tech-summary" style="color: {{config.colors.textSecondary}};">{{content.summary || content.content}}</view>
      <view class="tech-tags" wx:if="{{content.subtitle || content.impact}}">
        <text class="tech-tag" wx:if="{{content.subtitle}}" style="background: {{config.colors.bg}}; color: {{config.colors.primary}};">💡 {{content.subtitle}}</text>
        <text class="tech-tag" wx:if="{{content.impact}}" style="background: {{config.colors.bg}}; color: {{config.colors.accent}};">⚡ {{content.impact}}</text>
      </view>
      <view class="tech-tags" wx:if="{{content.tags && content.tags.length > 0}}">
        <block wx:for="{{content.tags}}" wx:key="index">
          <text class="tech-tag" style="background: {{config.colors.bg}}; color: {{config.colors.accent}};">{{item}}</text>
        </block>
      </view>
