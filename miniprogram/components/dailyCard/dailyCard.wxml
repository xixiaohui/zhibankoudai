      <view class="fortune-summary" style="color: {{config.colors.textSecondary}};">{{content.content}}</view>
      <view class="fortune-lucky" wx:if="{{content.luckyDirection || content.luckyNumber || content.luckyColor}}">
        <text class="lucky-item" wx:if="{{content.luckyDirection}}" style="background: {{config.colors.bg}}; color: {{config.colors.accent}};">🧭 {{content.luckyDirection}}</text>
        <text class="lucky-item" wx:if="{{content.luckyNumber}}" style="background: {{config.colors.bg}}; color: {{config.colors.accent}};">🔢 {{content.luckyNumber}}</text>
        <text class="lucky-item" wx:if="{{content.luckyColor}}" style="background: {{config.colors.bg}}; color: {{config.colors.accent}};">🎨 {{content.luckyColor}}</text>
      </view>
      <view class="fortune-tags" wx:if="{{content.tags && content.tags.length > 0}}">
        <block wx:for="{{content.tags}}" wx:key="index">
          <text class="fortune-tag" style="background: {{config.colors.bg}}; color: {{config.colors.accent}};">{{item}}</text>
        </block>
      </view>
    </block>

    <block wx:elif="{{moduleType === 'literature'}}">
      <view class="lit-header" style="border-bottom: 1rpx solid {{config.colors.bg}};">
        <text class="lit-author" style="color: {{config.colors.primary}};">{{content.author}}</text>
        <text class="lit-era" style="color: {{config.colors.accent}};">{{content.era}} · {{content.region}}</text>
      </view>
      <view class="lit-title" wx:if="{{content.title}}" style="color: {{config.colors.primary}}; font-weight: bold;">
        {{content.title}}
      </view>
      <view class="lit-works" wx:if="{{content.works && content.works.length > 0}}" style="color: {{config.colors.textSecondary}};">
        <text class="works-label">代表作：</text>
        <block wx:for="{{content.works}}" wx:key="index">
          <text class="work-item">{{item}}{{index < content.works.length - 1 ? ' · ' : ''}}</text>
        </block>
      </view>
      <view class="lit-content" wx:if="{{content.content}}" style="color: {{config.colors.textSecondary}};">{{content.content}}</view>
      <view class="lit-summary" wx:if="{{content.summary && content.summary !== content.content}}" style="color: {{config.colors.textSecondary}};">{{content.summary}}</view>
      <view class="lit-quote" wx:if="{{content.quote}}" style="color: {{config.colors.accent}}; background: {{config.colors.bg}};">
        <text>"{{content.quote}}"</text>
      </view>
      <view class="lit-subtitle" wx:if="{{content.subtitle}}" style="color: {{config.colors.primary}}; background: {{config.colors.bg}};">
        <text>💡 {{content.subtitle}}</text>
      </view>
      <view class="lit-tags" wx:if="{{content.tags && content.tags.length > 0}}">
        <block wx:for="{{content.tags}}" wx:key="index">
          <text class="lit-tag" style="background: {{config.colors.bg}}; color: {{config.colors.accent}};">{{item}}</text>
        </block>
      </view>
    </block>

