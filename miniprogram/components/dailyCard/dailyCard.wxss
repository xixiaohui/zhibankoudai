/* components/dailyCard/dailyCard.wxss - 每日内容卡片组件样式 */

/* 外层容器 */
.daily-card-wrapper {
  margin-top: 40rpx;
}

/* 标题行 */
.section-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.title-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.title-text {
  font-size: 32rpx;
}

/* 操作按钮行 */
.action-btns-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

/* 更多按钮 */
.more-btn {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  transition: all 0.2s ease;
}

.more-btn:active {
  opacity: 0.7;
  transform: scale(0.95);
}

.more-icon {
  font-size: 28rpx;
  color: #FFFFFF;
  margin-right: 4rpx;
  font-weight: bold;
}

.more-text {
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 500;
}

/* 分享按钮 */
.share-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.share-icon {
  font-size: 26rpx;
  color: #FFFFFF;
}

/* 刷新按钮 */
.refresh-btn {
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  border-radius: 24rpx;
  color: white;
  font-size: 24rpx;
}

.refresh-icon {
  font-size: 26rpx;
  margin-right: 6rpx;
}

.refresh-text {
  font-weight: 500;
}

/* 按钮点击效果 */
.btn-active {
  opacity: 0.7;
  transform: scale(0.95);
}

/* 内容卡片 */
.content-card {
  border-radius: 24rpx;
  padding: 30rpx;
}

/* 标签区域 */
.card-tags {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.tag-item {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.tag-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.tag-text {
  font-weight: 500;
}

.ai-tag {
  font-size: 18rpx;
  padding: 4rpx 10rpx;
  border-radius: 10rpx;
  font-weight: 600;
}

.meta-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

/* 名言样式 */
.quote-content {
  font-size: 30rpx;
  line-height: 1.6;
  margin-bottom: 24rpx;
  padding-left: 20rpx;
  font-style: italic;
}

.quote-author {
  font-size: 26rpx;
  text-align: right;
  margin-bottom: 20rpx;
}

.quote-meta {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 16rpx;
  padding-top: 16rpx;
}

.era-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

.era-tag.modern {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

.region-tag {
  font-size: 28rpx;
}

/* 段子样式 */
.joke-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
}

.joke-title {
  font-size: 26rpx;
  font-weight: 600;
}

.joke-content {
  font-size: 28rpx;
  line-height: 1.7;
}

.joke-footer {
  margin-top: 20rpx;
  padding-top: 16rpx;
}

.joke-source {
  font-size: 24rpx;
  color: #999999;
}

/* 知识样式（心理学/金融） */
.knowledge-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.knowledge-content {
  font-size: 28rpx;
  line-height: 1.8;
}

/* 情话样式 */
.love-content {
  font-size: 32rpx;
  line-height: 1.7;
  font-style: italic;
  text-align: center;
  padding: 20rpx 10rpx;
}

.love-author {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8rpx;
  margin-top: 24rpx;
  padding-top: 20rpx;
}

.author-prefix {
  font-size: 26rpx;
}

.author-name {
  font-size: 26rpx;
  font-weight: 600;
}

.author-source {
  font-size: 22rpx;
  color: #999999;
  margin-left: 8rpx;
}

/* 加载状态 */
.loading-state {
  text-align: center;
  padding: 60rpx 40rpx;
}

.loading-dots {
  display: flex;
  justify-content: center;
  margin-bottom: 20rpx;
}

.loading-dots .dot {
  font-size: 48rpx;
  margin: 0 8rpx;
}

.loading-text {
  font-size: 26rpx;
}

/* 占位状态 */
.placeholder-state {
  text-align: center;
  padding: 60rpx 40rpx;
  background: #FAFAFA;
  border-radius: 24rpx;
}

.placeholder-text {
  color: #BBBBBB;
  font-size: 26rpx;
}

/* 动画 */
@keyframes dotPulse {
  0%, 80%, 100% { opacity: 0.3; transform: scale(0.8); }
  40% { opacity: 1; transform: scale(1.2); }
}

