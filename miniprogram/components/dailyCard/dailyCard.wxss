/* components/dailyCard/dailyCard.wxss - Pinterest Design System */

/* ==================== 组件特定变量（仅组件内使用） ==================== */
.daily-card {
  /* Pinterest Brand Colors - 组件特有 */
  --pinterest-red: #e60023;
  --pinterest-plum: #211922;
}

/* ==================== 每日卡片容器 - Pinterest Card Style ==================== */
/* White bg, 24px radius, no shadow - flat design (使用全局变量) */
.daily-card {
  width: 100%;
  background-color: var(--surface);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
  margin-bottom: var(--space-lg);
  border: 1rpx solid var(--border);
  box-sizing: border-box;
}

.daily-card.last-card {
  margin-bottom: 0;
}

/* ==================== 头部区域 ==================== */
.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-md);
  padding-bottom: var(--space-sm);
  border-bottom: 1rpx solid var(--border);
}

.date-section {
  display: flex;
  flex-direction: column;
}

.date-day {
  font-size: 56rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1;
  letter-spacing: -2rpx;
}

.date-month {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.date-year {
  font-size: var(--font-size-xs);
  color: var(--text-placeholder);
  margin-top: 2rpx;
}

/* Pinterest Badge - Warm Wash Background (使用全局变量) */
.module-badge {
  display: inline-flex;
  align-items: center;
  padding: var(--space-xs) var(--space-sm);
  background-color: var(--accent-warm-light);
  border-radius: var(--radius-full);
  font-size: var(--font-size-xs);
  color: var(--text-secondary);
  font-weight: 500;
}

/* ==================== 内容区域 ==================== */
.card-content {
  margin-bottom: var(--space-md);
}

.content-title {
  font-size: var(--space-xl);
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.4;
  margin-bottom: var(--space-sm);
  letter-spacing: -1rpx;
}

.content-summary {
  font-size: var(--font-size-base);
  color: var(--text-secondary);
  line-height: 1.6;
}

.content-body {
  margin-top: var(--space-md);
  padding: var(--space-md);
  background-color: var(--surface-accent);
  border-radius: var(--radius-md);
}

.content-text {
  font-size: var(--font-size-base);
  color: var(--text-primary);
  line-height: 1.8;
}

/* ==================== 引用样式 ==================== */
/* Pinterest Quote Style - left border accent */
.quote-section {
  position: relative;
  margin-top: var(--space-md);
  padding: var(--space-md);
  padding-left: var(--space-xl);
  background-color: var(--surface-accent);
  border-radius: var(--radius-md);
}

.quote-section::before {
  content: '"';
  position: absolute;
  top: 8rpx;
  left: 16rpx;
  font-size: 80rpx;
  color: var(--border);
  font-family: serif;
  line-height: 1;
}

.quote-text {
  font-size: var(--font-size-base);
  font-style: italic;
  color: var(--text-primary);
  line-height: 1.7;
}

.quote-author {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
  margin-top: var(--space-sm);
  text-align: right;
}

/* ==================== 图片网格 ==================== */
.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-xs);
  margin-top: var(--space-md);
}

.image-grid.cols-2 {
  grid-template-columns: repeat(2, 1fr);
}

.image-grid.cols-1 {
  grid-template-columns: 1fr;
}

.grid-image {
  width: 100%;
  aspect-ratio: 1;
  border-radius: var(--radius-md);
  background-color: var(--surface-accent);
}

.grid-image.single {
  aspect-ratio: 16/9;
  border-radius: var(--radius-lg);
}

/* ==================== 标签 ==================== */
/* Pinterest Tag - Warm Wash Badge */
.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
  margin-top: var(--space-md);
}

.tag-item {
  display: inline-flex;
  align-items: center;
  padding: var(--space-xs) var(--space-sm);
  background-color: var(--accent-warm-light);
  border-radius: var(--radius-full);
  font-size: var(--font-size-xs);
  color: var(--text-secondary);
  font-weight: 500;
}

.tag-item.highlight {
  background-color: var(--pinterest-red);
  color: #000000;
}

/* ==================== 操作按钮 ==================== */
/* Pinterest Secondary Button - Sand Gray */
.action-buttons {
  display: flex;
  gap: var(--space-sm);
  margin-top: var(--space-md);
  padding-top: var(--space-md);
  border-top: 1rpx solid var(--border);
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-sm) var(--space-md);
  background-color: var(--border);
  border-radius: var(--radius-md);
  border: none;
  font-size: var(--font-size-sm);
  color: var(--text-primary);
  font-weight: 400;
  transition: opacity 0.15s ease;
}

.action-btn:active {
  opacity: 0.8;
}

.action-btn.focus-ring:focus {
  outline: 3rpx solid var(--focus-ring);
  outline-offset: 2rpx;
}

/* Pinterest Primary Red Button */
.action-btn.primary {
  background-color: var(--pinterest-red);
  color: #000000;
}

.action-btn-icon {
  margin-right: var(--space-xs);
}

/* ==================== 底部信息 ==================== */
.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: var(--space-md);
  padding-top: var(--space-sm);
}

/* Pinterest AI Badge - Sand Background */
.footer-left {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.ai-badge {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  padding: 6rpx var(--space-sm);
  background-color: var(--border);
  border-radius: var(--radius-full);
  font-size: 20rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.footer-time {
  font-size: 22rpx;
  color: var(--text-placeholder);
}

.footer-actions {
  display: flex;
  gap: var(--space-xs);
}

/* Pinterest Circular Action Button - Warm Light */
.icon-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--accent-warm-light);
  border-radius: 50%;
  border: none;
  font-size: var(--font-size-base);
  color: var(--text-primary);
  transition: transform 0.15s ease;
}

.icon-btn:active {
  transform: scale(0.95);
}

.icon-btn.focus-ring:focus {
  outline: 3rpx solid var(--focus-ring);
  outline-offset: 2rpx;
}

/* ==================== 展开/收起动画 ==================== */
@keyframes expand {
  from {
    max-height: 0;
    opacity: 0;
  }
  to {
    max-height: 1000rpx;
    opacity: 1;
  }
}

@keyframes collapse {
  from {
    max-height: 1000rpx;
    opacity: 1;
  }
  to {
    max-height: 0;
    opacity: 0;
  }
}

.expanding {
  animation: expand 0.3s ease forwards;
}

.collapsing {
  animation: collapse 0.3s ease forwards;
}

/* ==================== 加载状态 ==================== */
/* Pinterest Style Loading */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-xl) 0;
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 3rpx solid var(--border);
  border-top-color: var(--pinterest-red);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: var(--space-sm);
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-xl) 0;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: var(--space-md);
  opacity: 0.4;
}

.empty-title {
  font-size: var(--space-xl);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--space-xs);
  letter-spacing: -1rpx;
}

.empty-desc {
  font-size: var(--font-size-base);
  color: var(--text-secondary);
}

/* ==================== 主按钮 ==================== */
/* Pinterest Primary Red Button */
.primary-button {
  width: 100%;
  padding: var(--space-md);
  background-color: var(--pinterest-red);
  color: #000000;
  border-radius: var(--radius-md);
  font-size: var(--font-size-base);
  font-weight: 400;
  text-align: center;
  border: none;
  transition: opacity 0.15s ease;
}

.primary-button:active {
  opacity: 0.9;
}

.primary-button.focus-ring:focus {
  outline: 3rpx solid var(--focus-ring);
  outline-offset: 2rpx;
}

/* ==================== 圆角按钮 ==================== */
/* Pinterest Circular Action */
.round-button {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--accent-warm-light);
  border-radius: 50%;
  border: none;
  font-size: 36rpx;
  color: var(--text-primary);
  transition: transform 0.15s ease;
}

.round-button:active {
  transform: scale(0.95);
}

.round-button.focus-ring:focus {
  outline: 3rpx solid var(--focus-ring);
  outline-offset: 2rpx;
}

/* ==================== 分割线 ==================== */
.divider {
  height: 1rpx;
  background-color: var(--border);
  margin: var(--space-md) 0;
}

.divider-dashed {
  border-style: dashed;
  border-width: 1rpx 0 0 0;
  border-color: var(--border);
}

/* ==================== 响应式图片 ==================== */
.responsive-image {
  width: 100%;
  border-radius: var(--radius-md);
  background-color: var(--surface-accent);
}

/* ==================== 居中内容 ==================== */
.center-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

/* ==================== 区块标题行 ==================== */
.section-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-md);
  gap: var(--space-sm);

  margin-top: 20rpx;
}

.section-title {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  flex-shrink: 0;
}

.title-icon {
  font-size: 32rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: -1.2rpx;
}

/* ==================== 操作按钮行 ==================== */
.action-btns-row {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
}

/* Pinterest Primary Red Button */
.more-btn {
  display: flex;
  align-items: center;
  padding: var(--space-xs) var(--space-sm);
  background-color: var(--pinterest-red);
  border-radius: var(--radius-md);
  border: none;
  font-size: 22rpx;
  color: #000000;
  font-weight: 400;
  transition: opacity 0.15s ease;
}

.more-btn:active {
  opacity: 0.9;
}

.more-btn.focus-ring:focus {
  outline: 3rpx solid var(--focus-ring);
  outline-offset: 2rpx;
}

.more-icon {
  font-size: 24rpx;
  margin-right: 4rpx;
}

.more-text {
  font-size: 22rpx;
}

/* Pinterest Circular Action Button */
.share-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--accent-warm-light);
  border-radius: 50%;
  border: none;
  font-size: 26rpx;
  color: var(--text-primary);
  transition: transform 0.15s ease;
}

.share-btn:active {
  transform: scale(0.95);
}

.share-btn.focus-ring:focus {
  outline: 3rpx solid var(--focus-ring);
  outline-offset: 2rpx;
}

.share-icon {
  font-size: 24rpx;
  color: var(--text-primary);
}

/* Pinterest Secondary Button - Sand Gray */
.refresh-btn {
  display: flex;
  align-items: center;
  padding: var(--space-xs) var(--space-sm);
  background-color: var(--border);
  border-radius: var(--radius-md);
  border: none;
  font-size: 22rpx;
  color: var(--text-primary);
  font-weight: 400;
  transition: opacity 0.15s ease;
}

.refresh-btn:active {
  opacity: 0.8;
}

.refresh-btn.focus-ring:focus {
  outline: 3rpx solid var(--focus-ring);
  outline-offset: 2rpx;
}

.refresh-btn.loading {
  opacity: 0.7;
}

.refresh-icon {
  font-size: 24rpx;
  margin-right: 4rpx;
  display: inline-block;
}

.refresh-icon.spin {
  animation: spin 1s linear infinite;
}

.refresh-text {
  font-size: 22rpx;
}

/* ==================== 内容卡片 ==================== */
/* Pinterest Card - flat design, warm background */
.content-card {
  background-color: var(--surface);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
  border: 1rpx solid var(--border);
  margin-top: var(--space-md);
}

/* ==================== 卡片标签区域 ==================== */
.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
  margin-bottom: var(--space-md);
}

/* ==================== 标签样式 ==================== */
.tag-item {
  display: inline-flex;
  align-items: center;
  padding: var(--space-xs) var(--space-sm);
  background-color: var(--accent-warm-light);
  border-radius: var(--radius-full);
  font-size: 22rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.tag-icon {
  font-size: 24rpx;
  margin-right: 4rpx;
}

.tag-text {
  font-size: 22rpx;
}

.tag-item.ai-tag {
  background-color: var(--border);
  color: var(--text-secondary);
}

.tag-item.meta-tag {
  background-color: var(--accent-warm-light);
}

/* ==================== 引用内容 ==================== */
.quote-content {
  font-size: var(--font-size-lg);
  font-style: italic;
  color: var(--text-primary);
  line-height: 1.7;
  margin-bottom: var(--space-sm);
}

.quote-author {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
  margin-bottom: var(--space-sm);
}

.quote-meta {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
  margin-top: var(--space-sm);
}

/* ==================== 来源标签 ==================== */
.source-tag,
.category-tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx var(--space-sm);
  background-color: var(--accent-warm-light);
  border-radius: var(--radius-full);
  font-size: 22rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

/* ==================== 笑话内容 ==================== */
.joke-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-sm);
  padding-bottom: var(--space-sm);
  border-bottom: 1rpx solid var(--border);
}

.joke-title {
  font-size: var(--font-size-xl);
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: -1rpx;
}

.joke-content {
  font-size: var(--font-size-base);
  color: var(--text-secondary);
  line-height: 1.7;
}

.joke-footer {
  margin-top: var(--space-md);
  padding-top: var(--space-sm);
}

/* ==================== 知识内容 ==================== */
.knowledge-title {
  font-size: var(--font-size-xl);
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.4;
  margin-bottom: var(--space-sm);
  letter-spacing: -1rpx;
}

.knowledge-content {
  font-size: var(--font-size-base);
  color: var(--text-secondary);
  line-height: 1.7;
}

/* ==================== 爱情内容 ==================== */
.love-content {
  font-size: var(--font-size-lg);
  font-style: italic;
  color: var(--text-primary);
  line-height: 1.7;
  text-align: center;
  padding: var(--space-md) 0;
}

.love-author {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: var(--space-xs);
  margin-top: var(--space-md);
  padding-top: var(--space-sm);
  border-top: 1rpx solid var(--border);
}

.author-prefix {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
}

.author-name {
  font-size: var(--font-size-sm);
  font-weight: 600;
  color: var(--text-primary);
}

.author-source {
  font-size: 22rpx;
  color: var(--text-placeholder);
  margin-left: var(--space-xs);
}

/* 甜蜜时刻 - 元信息和总结 */
.love-meta {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-sm);
  margin-top: var(--space-sm);
  padding-top: var(--space-sm);
}

.love-source {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.love-region {
  font-size: 20rpx;
  padding: 4rpx var(--space-xs);
  border-radius: var(--radius-full);
}

.love-subtitle {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: var(--space-sm);
  padding: var(--space-sm);
  border-radius: var(--radius-md);
  font-size: var(--font-size-sm);
  text-align: center;
}

/* ==================== 电影内容 ==================== */
.movie-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-sm);
  padding-bottom: var(--space-sm);
  border-bottom: 1rpx solid var(--border);
}

.movie-title {
  font-size: var(--font-size-xl);
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: -1rpx;
  flex: 1;
}

.movie-rating {
  display: inline-flex;
  align-items: center;
  padding: 4rpx var(--space-xs);
  background-color: var(--accent-warm-light);
  border-radius: var(--radius-full);
  font-size: 22rpx;
  margin-left: var(--space-sm);
}

.movie-meta {
  display: flex;
  gap: var(--space-md);
  margin-bottom: var(--space-sm);
}

.movie-director,
.movie-year {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.movie-summary {
  font-size: var(--font-size-base);
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: var(--space-sm);
}

.movie-quote {
  font-size: 26rpx;
  font-style: italic;
  padding: var(--space-sm) var(--space-md);
  background-color: var(--accent-warm-light);
  border-radius: var(--radius-md);
  margin-bottom: var(--space-sm);
}

.movie-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
}

.movie-tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx var(--space-sm);
  background-color: var(--accent-warm-light);
  border-radius: var(--radius-full);
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* ==================== 音乐内容 ==================== */
.music-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-sm);
  padding-bottom: var(--space-sm);
  border-bottom: 1rpx solid var(--border);
}

.music-title {
  font-size: var(--font-size-xl);
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: -1rpx;
  flex: 1;
}

.music-mood {
  display: inline-flex;
  align-items: center;
  padding: 4rpx var(--space-xs);
  background-color: var(--accent-warm-light);
  border-radius: var(--radius-full);
  font-size: 22rpx;
}

.music-meta {
  display: flex;
  gap: var(--space-md);
  margin-bottom: var(--space-xs);
}

.music-artist,
.music-year {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.music-album {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: var(--space-sm);
}

.album-label {
  color: var(--text-placeholder);
}

.music-duration {
  color: var(--text-placeholder);
}

.music-content {
  font-size: var(--font-size-base);
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: var(--space-sm);
}

.music-lyric {
  font-size: 26rpx;
  font-style: italic;
  padding: var(--space-sm) var(--space-md);
  background-color: var(--accent-warm-light);
  border-radius: var(--radius-md);
  margin-bottom: var(--space-sm);
}

.music-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
}

.music-tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx var(--space-sm);
  background-color: var(--accent-warm-light);
  border-radius: var(--radius-full);
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* ==================== 科技内容 ==================== */
.tech-header {
  margin-bottom: var(--space-sm);
  padding-bottom: var(--space-sm);
  border-bottom: 1rpx solid var(--border);
}

.tech-title {
  font-size: var(--font-size-xl);
  font-weight: 600;
