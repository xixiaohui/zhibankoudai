<!-- pages/study/index.wxml - 学习提升 -->
<view class="container">

  <!-- 头部 -->
  <view class="study-header">
    <view class="sh-bg-circle shc1"></view>
    <view class="sh-bg-circle shc2"></view>
    <view class="sh-title">学习提升 📚</view>
    <view class="sh-stats-row">
      <view class="sh-stat">
        <view class="sh-stat-val">{{totalNotes}}</view>
        <view class="sh-stat-label">笔记数</view>
      </view>
      <view class="sh-stat">
        <view class="sh-stat-val">{{todayMinutes}}</view>
        <view class="sh-stat-label">今日分钟</view>
      </view>
      <view class="sh-stat">
        <view class="sh-stat-val">{{streakDays}}</view>
        <view class="sh-stat-label">连续天数</view>
      </view>
    </view>
  </view>

  <!-- 学习计时器 -->
  <view class="timer-card">
    <view class="timer-title">专注计时</view>
    <view class="timer-display">{{timerDisplay}}</view>
    <view class="timer-btns">
      <view class="timer-btn start {{isTimerRunning ? 'disabled' : ''}}" bindtap="startTimer">
        {{isTimerRunning ? '计时中...' : '开始'}}
      </view>
      <view class="timer-btn stop" bindtap="stopTimer">暂停</view>
      <view class="timer-btn reset" bindtap="resetTimer">完成</view>
    </view>
  </view>

  <!-- 搜索 -->
  <view class="search-bar">
    <text class="search-icon">🔍</text>
    <input class="search-input" placeholder="搜索笔记..." bindinput="onSearch"/>
  </view>

  <!-- 分类筛选 -->
  <scroll-view scroll-x class="cat-filter-scroll">
    <view class="cat-filter-row">
      <view class="cat-filter-btn {{activeCategory === item.key ? 'active' : ''}}"
            wx:for="{{categories}}" wx:key="key"
            bindtap="setCategory" data-key="{{item.key}}">
        <text>{{item.icon}}</text>
        <text>{{item.label}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- 笔记列表 -->
  <view class="notes-container" wx:if="{{filteredNotes.length > 0}}">
    <view class="note-card" wx:for="{{filteredNotes}}" wx:key="id"
          bindtap="openDetail" data-id="{{item.id}}">
      <view class="note-header-row">
        <view class="note-cat-badge" style="background:{{item.catInfo.color}}18; color:{{item.catInfo.color}}">
          {{item.catInfo.icon}} {{item.catInfo.label}}
        </view>
        <text class="note-date">{{item.date}}</text>
      </view>
      <view class="note-title">{{item.title}}</view>
      <view class="note-content-preview">{{item.content}}</view>
      <view class="note-footer-row">
        <view class="note-tags" wx:if="{{item.tags}}">
          <text class="tag-item" wx:for="{{item.tags.split(',')}}" wx:key="index">
            #{{item}}
          </text>
        </view>
        <view wx:if="{{item.duration > 0}}" class="note-duration">
          ⏱ {{item.duration}}分钟
        </view>
      </view>
    </view>
  </view>

  <view wx:else class="empty-state">
    <text class="empty-icon">📚</text>
    <text>还没有笔记，开始记录你的学习吧！</text>
  </view>

  <view style="height:160rpx"></view>

  <!-- FAB -->
  <view class="fab study-fab" bindtap="openAddModal">+</view>

  <!-- 新增笔记弹窗 -->
  <view class="modal-mask" wx:if="{{showAddModal}}" bindtap="closeAddModal">
    <view class="modal-box note-modal" catchtap="">
      <view class="modal-title">记录笔记</view>

      <!-- 分类选择 -->
      <scroll-view scroll-x class="form-cat-scroll">
        <view class="form-cat-row">
          <view class="form-cat-btn {{form.category === item.key ? 'active' : ''}}"
                wx:for="{{studyCategories}}" wx:key="key"
                bindtap="setFormCategory" data-key="{{item.key}}">
            {{item.icon}} {{item.label}}
          </view>
        </view>
      </scroll-view>

      <input class="input-item" placeholder="笔记标题 *"
             value="{{form.title}}" bindinput="onTitleInput"/>
      <textarea class="input-item note-textarea" placeholder="写下你学到的内容..."
                value="{{form.content}}" bindinput="onContentInput" auto-height/>
      <input class="input-item" placeholder="学习时长（分钟）" type="number"
             value="{{form.duration}}" bindinput="onDurationInput"/>
      <input class="input-item" placeholder="标签，逗号分隔（如：Vue,前端）"
             value="{{form.tags}}" bindinput="onTagsInput"/>

      <view class="btn-primary save-btn" bindtap="saveNote">保存笔记</view>
    </view>
  </view>

  <!-- 详情弹窗 -->
  <view class="modal-mask detail-mask" wx:if="{{showDetailModal}}" bindtap="closeDetail">
    <view class="detail-box" catchtap="" wx:if="{{currentNote}}">
      <view class="detail-header" style="background:{{currentNote.catInfo.color}}18">
        <view class="detail-cat-badge" style="color:{{currentNote.catInfo.color}}">
          {{currentNote.catInfo.icon}} {{currentNote.catInfo.label}}
        </view>
        <view class="detail-date">{{currentNote.date}}</view>
      </view>
      <scroll-view scroll-y class="detail-scroll">
        <view class="detail-title">{{currentNote.title}}</view>
        <view class="detail-content">{{currentNote.content}}</view>
        <view class="detail-meta">
          <view wx:if="{{currentNote.duration > 0}}" class="meta-item">
            ⏱ 学习 {{currentNote.duration}} 分钟
          </view>
          <view wx:if="{{currentNote.tags}}" class="meta-item">
            🏷 {{currentNote.tags}}
          </view>
        </view>
      </scroll-view>
      <view class="detail-footer">
        <view class="del-btn" bindtap="deleteNote" data-id="{{currentNote.id}}">删除</view>
        <view class="close-btn" bindtap="closeDetail">关闭</view>
      </view>
    </view>
  </view>

</view>
