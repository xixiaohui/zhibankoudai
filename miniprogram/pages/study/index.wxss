/* pages/study/index.wxss */

/* 头部 */
.study-header {
  background: linear-gradient(135deg, #43D9AD, #26C6A0);
  padding: 40rpx 32rpx 40rpx;
  position: relative; overflow: hidden; color: #fff;
}
.sh-bg-circle { position: absolute; border-radius: 50%; background: rgba(255,255,255,0.1); }
.shc1 { width: 260rpx; height: 260rpx; top: -60rpx; right: -50rpx; }
.shc2 { width: 150rpx; height: 150rpx; bottom: -50rpx; left: 30rpx; background: rgba(255,255,255,0.07); }

.sh-title { font-size: 36rpx; font-weight: 700; color: #fff; margin-bottom: 28rpx; }
.sh-stats-row { display: flex; align-items: center; }
.sh-stat { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 6rpx; }
.sh-stat-val { font-size: 44rpx; font-weight: 700; color: #fff; }
.sh-stat-label { font-size: 22rpx; color: rgba(255,255,255,0.75); }

/* 计时器 */
.timer-card {
  background: #fff; margin: 16rpx 24rpx; border-radius: 24rpx;
  padding: 28rpx; box-shadow: 0 4rpx 20rpx rgba(67,217,173,0.12);
  display: flex; flex-direction: column; align-items: center;
}
.timer-title { font-size: 26rpx; color: #888; margin-bottom: 16rpx; }
.timer-display { font-size: 72rpx; font-weight: 700; color: #1A1A2E; letter-spacing: 4rpx; margin-bottom: 24rpx; font-variant-numeric: tabular-nums; }
.timer-btns { display: flex; gap: 20rpx; }
.timer-btn {
  padding: 16rpx 40rpx; border-radius: 100rpx;
  font-size: 26rpx; font-weight: 600;
}
.timer-btn.start { background: #43D9AD; color: #fff; }
.timer-btn.start.disabled { background: #A8E6DB; }
.timer-btn.stop { background: #FFB347; color: #fff; }
.timer-btn.reset { background: #6C63FF; color: #fff; }

/* 搜索 */
.search-bar {
  display: flex; align-items: center; gap: 16rpx;
  background: #fff; border-radius: 100rpx;
  padding: 16rpx 28rpx; margin: 8rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.search-icon { font-size: 32rpx; }
.search-input { flex: 1; font-size: 28rpx; color: #333; }

/* 分类筛选 */
.cat-filter-scroll { white-space: nowrap; margin: 8rpx 0; }
.cat-filter-row { display: inline-flex; gap: 12rpx; padding: 8rpx 24rpx; }
.cat-filter-btn {
  display: inline-flex; align-items: center; gap: 6rpx;
  padding: 10rpx 24rpx; border-radius: 100rpx;
  font-size: 24rpx; color: #666; background: #F5F5FA;
}
.cat-filter-btn.active { background: #43D9AD; color: #fff; }

/* 笔记容器 */
.notes-container { padding: 4rpx 24rpx; }

.note-card {
  background: #fff; border-radius: 20rpx;
  padding: 24rpx; margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(67,217,173,0.08);
}
.note-header-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12rpx; }
.note-cat-badge {
  display: inline-flex; align-items: center; gap: 6rpx;
  padding: 6rpx 16rpx; border-radius: 100rpx; font-size: 22rpx; font-weight: 500;
}
.note-date { font-size: 22rpx; color: #AAA; }
.note-title { font-size: 30rpx; font-weight: 700; color: #1A1A2E; margin-bottom: 10rpx; }
.note-content-preview {
  font-size: 26rpx; color: #666; line-height: 1.6;
  overflow: hidden; text-overflow: ellipsis;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
}
.note-footer-row { display: flex; align-items: center; justify-content: space-between; margin-top: 14rpx; }
.note-tags { display: flex; gap: 10rpx; flex-wrap: wrap; }
.tag-item { font-size: 20rpx; color: #43D9AD; }
.note-duration { font-size: 22rpx; color: #AAA; }

/* 弹窗 */
.note-modal { max-height: 88vh; overflow-y: auto; }
.form-cat-scroll { white-space: nowrap; margin-bottom: 20rpx; }
.form-cat-row { display: inline-flex; gap: 12rpx; }
.form-cat-btn {
  display: inline-flex; align-items: center; gap: 6rpx;
  padding: 10rpx 20rpx; border-radius: 100rpx;
  font-size: 24rpx; color: #666; background: #F5F5FA;
  white-space: nowrap;
}
.form-cat-btn.active { background: #43D9AD; color: #fff; }
.note-textarea {
  min-height: 180rpx; line-height: 1.8;
  font-size: 28rpx;
}
.save-btn { margin-top: 16rpx; }

/* 详情弹窗 */
.detail-mask { align-items: center; }
.detail-box {
  width: 88vw; background: #fff; border-radius: 32rpx;
  overflow: hidden; max-height: 80vh; display: flex; flex-direction: column;
}
.detail-header { padding: 28rpx; display: flex; align-items: center; justify-content: space-between; }
.detail-cat-badge { font-size: 28rpx; font-weight: 600; }
.detail-date { font-size: 24rpx; color: #888; }
.detail-scroll { flex: 1; padding: 0 28rpx; max-height: 55vh; }
.detail-title { font-size: 36rpx; font-weight: 700; color: #1A1A2E; margin-bottom: 20rpx; line-height: 1.4; }
.detail-content { font-size: 28rpx; color: #444; line-height: 1.9; white-space: pre-wrap; }
.detail-meta { margin-top: 24rpx; padding-top: 20rpx; border-top: 1rpx solid #F0F0F8; display: flex; gap: 24rpx; }
.meta-item { font-size: 24rpx; color: #888; }
.detail-footer { display: flex; gap: 16rpx; padding: 20rpx 28rpx; border-top: 1rpx solid #F0F0F8; }
.del-btn {
  flex: 1; height: 80rpx; border-radius: 100rpx;
  display: flex; align-items: center; justify-content: center;
  background: #FFEBEE; color: #FF5252; font-size: 28rpx; font-weight: 600;
}
.close-btn {
  flex: 2; height: 80rpx; border-radius: 100rpx;
  display: flex; align-items: center; justify-content: center;
  background: #43D9AD; color: #fff; font-size: 28rpx; font-weight: 600;
}

/* FAB */
.study-fab {
  position: fixed; right: 40rpx; bottom: 160rpx;
  width: 100rpx; height: 100rpx; border-radius: 50rpx;
  background: #43D9AD; color: #fff; font-size: 56rpx;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(67, 217, 173, 0.45); z-index: 100;
}

.empty-state {
  display: flex; flex-direction: column; align-items: center;
  padding: 80rpx 40rpx; gap: 20rpx;
}
.empty-icon { font-size: 100rpx; }
.empty-state text:last-child { font-size: 28rpx; color: #999BB8; }
