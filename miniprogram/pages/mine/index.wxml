<!-- pages/mine/index.wxml - 我的页面 -->
<view class="page-container">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="user-header">
      <view class="avatar">👤</view>
      <view class="user-info">
        <view class="nickname">{{userProfile.nickname || '未设置昵称'}}</view>
        <view class="join-date">加入于 {{userProfile.joinDate || '未知'}}</view>
      </view>
    </view>
    
    <view class="user-stats">
      <block wx:for="{{dataStats}}" wx:key="label">
        <view class="stat-item">
          <view class="stat-value">{{item.value}}</view>
          <view class="stat-label">{{item.label}}</view>
        </view>
      </block>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="functions-section">
    <view class="section-title">功能与服务</view>
    <view class="functions-grid">
      <block wx:for="{{functions}}" wx:key="id">
        <view class="function-item" data-id="{{item.id}}" bindtap="onFunctionTap">
          <view class="function-icon" style="background-color: {{item.color}}">{{item.icon}}</view>
          <view class="function-info">
            <view class="function-name">{{item.name}}</view>
            <view class="function-desc">{{item.desc}}</view>
          </view>
          <view class="function-arrow">›</view>
        </view>
      </block>
    </view>
  </view>

  <!-- 快捷操作 -->
  <view class="quick-actions">
    <view class="section-title">快捷操作</view>
    <view class="actions-grid">
      <view class="action-btn" bindtap="onViewGuide">
        <view class="action-icon">📚</view>
        <view class="action-text">使用指南</view>
      </view>
      <view class="action-btn" bindtap="onExportData">
        <view class="action-icon">📤</view>
        <view class="action-text">导出数据</view>
      </view>
      <view class="action-btn" bindtap="onShareApp">
        <view class="action-icon">📢</view>
        <view class="action-text">分享应用</view>
      </view>
    </view>
  </view>

  <!-- 关于信息 -->
  <view class="about-section">
    <view class="about-content">
      <view class="app-name">智伴口袋</view>
      <view class="app-desc">你的随身AI陪伴助手</view>
      <view class="version">版本 {{version}}</view>
      <view class="version">皖ICP备2024039490号-3X</view>
      
    </view>
    <view class="copyright">
      © 2024 智伴口袋 · 温暖陪伴，触手可及
    </view>
  </view>
</view>