<!-- pages/mine/index.wxml - 我的 -->
<view class="container">

  <!-- 用户信息卡片 -->
  <view class="profile-card">
    <view class="profile-bg">
      <view class="profile-avatar" bindtap="getUserInfo">
        <image wx:if="{{userInfo && userInfo.avatar}}" src="{{userInfo.avatar}}" mode="aspectFill"/>
        <text wx:else>{{userInfo && userInfo.name ? userInfo.name[0] : '👤'}}</text>
      </view>
      <view class="profile-info" bindtap="getUserInfo">
        <view class="profile-name">
          {{userInfo && userInfo.name ? userInfo.name : '点击登录'}}
        </view>
        <view class="profile-title" wx:if="{{userInfo && userInfo.title}}">
          {{userInfo.title}}
        </view>
        <view class="profile-title" wx:else>
          设置您的专家资料
        </view>
      </view>
      <view class="profile-level level-{{userInfo && userInfo.level || 'junior'}}">
        {{userInfo && userInfo.level === 'expert' ? '专家' : userInfo && userInfo.level === 'senior' ? '高级' : userInfo && userInfo.level === 'mid' ? '中级' : '初级'}}
      </view>
    </view>

    <!-- 数据统计 -->
    <view class="stats-bar">
      <view class="stat-item">
        <text class="stat-num">{{stats.records}}</text>
        <text class="stat-label">记账</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">{{stats.notes}}</text>
        <text class="stat-label">笔记</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">{{stats.skills}}</text>
        <text class="stat-label">技能</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">{{stats.projects}}</text>
        <text class="stat-label">项目</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">{{stats.todos}}</text>
        <text class="stat-label">已完成</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view 
      class="menu-item"
      wx:for="{{menuList}}"
      wx:key="action"
      bindtap="onMenuTap"
      data-action="{{item.action}}">
      <view class="menu-left">
        <text class="menu-icon">{{item.icon}}</text>
        <view class="menu-text">
          <text class="menu-label">{{item.label}}</text>
          <text class="menu-desc">{{item.desc}}</text>
        </view>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 底部信息 -->
  <view class="footer-info">
    <text class="app-name">智伴口袋</text>
    <text class="app-version">v{{appVersion}}</text>
    <text class="app-desc">您的个人专家资料库</text>
  </view>

</view>
