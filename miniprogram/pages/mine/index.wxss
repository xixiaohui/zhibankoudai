/* pages/mine/index.wxss - 我的页面样式 */

.page-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #F8F6FF 0%, #F0EDFF 100%);
  padding: 30rpx 30rpx 100rpx;
}

/* 用户信息卡片 */
.user-card {
  background: white;
  border-radius: 32rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(124, 106, 255, 0.1);
}

.user-header {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #7C6AFF, #9D8FFF);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  color: white;
  margin-right: 30rpx;
}

.user-info {
  flex: 1;
}

.nickname {
  font-size: 40rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 10rpx;
}

.join-date {
  font-size: 26rpx;
  color: #999999;
}

.user-stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #7C6AFF;
  margin-bottom: 5rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999999;
}

/* 功能列表 */
.functions-section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
}

.functions-grid {
  background: white;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.05);
}

.function-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.function-item:last-child {
  border-bottom: none;
}

.function-item:active {
  background: #F8F8F8;
}

.function-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: white;
  margin-right: 24rpx;
}

.function-info {
  flex: 1;
}

.function-name {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 5rpx;
}

.function-desc {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.3;
}

.function-arrow {
  font-size: 36rpx;
  color: #CCCCCC;
  font-weight: bold;
  margin-left: 20rpx;
}

/* 快捷操作 */
.quick-actions {
  margin-bottom: 40rpx;
}

.actions-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.action-btn {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.2s;
}

.action-btn:active {
  transform: scale(0.98);
}

.action-icon {
  font-size: 40rpx;
  margin-bottom: 15rpx;
  display: block;
}

.action-text {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
}

/* 关于信息 */
.about-section {
  text-align: center;
  padding: 40rpx;
  background: white;
  border-radius: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.05);
}

.about-content {
  margin-bottom: 30rpx;
}

.app-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 10rpx;
}

.app-desc {
  font-size: 28rpx;
  color: #7C6AFF;
  margin-bottom: 15rpx;
}

.version {
  font-size: 24rpx;
  color: #999999;
}

.copyright {
  font-size: 22rpx;
  color: #CCCCCC;
  padding-top: 20rpx;
  border-top: 1rpx solid #F0F0F0;
}