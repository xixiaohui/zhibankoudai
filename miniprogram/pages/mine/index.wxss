/* pages/mine/index.wxss - Pinterest Design System */

.page-container {
  min-height: 100vh;
  background-color: var(--surface-secondary);
  padding: var(--space-lg) var(--space-lg) 100rpx;
}

.user-card {
  background: var(--surface);
  border-radius: var(--radius-lg);
  padding: var(--space-xl);
  margin-bottom: var(--space-lg);
  border: 1rpx solid var(--border);
}

.user-header {
  display: flex;
  align-items: center;
  margin-bottom: var(--space-xl);
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  background: var(--text-secondary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  color: var(--surface);
  margin-right: var(--space-lg);
}

.user-info {
  flex: 1;
}

.nickname {
  font-size: var(--font-size-xxl);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--space-xs);
}

.join-date {
  font-size: var(--font-size-base);
  color: var(--text-secondary);
}

.user-stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-sm);
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: var(--font-size-xl);
  font-weight: 600;
  color: var(--primary);
  margin-bottom: 4rpx;
}

.stat-label {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
}

.functions-section {
  margin-bottom: var(--space-lg);
}

.section-title {
  font-size: var(--font-size-xl);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--space-sm);
}

.functions-grid {
  background: var(--surface);
  border-radius: var(--radius-lg);
  overflow: hidden;
  border: 1rpx solid var(--border);
}

.function-item {
  display: flex;
  align-items: center;
  padding: var(--space-lg);
  border-bottom: 1rpx solid var(--border);
}

.function-item:last-child {
  border-bottom: none;
}

.function-item:active {
  background: var(--surface-secondary);
}

.function-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: var(--surface);
  margin-right: var(--space-md);
  background-color: var(--text-secondary);
}

.function-info {
  flex: 1;
}

.function-name {
  font-size: var(--font-size-lg);
  color: var(--text-primary);
  font-weight: 500;
  margin-bottom: 4rpx;
}

.function-desc {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
  line-height: 1.3;
}

.function-arrow {
  font-size: 36rpx;
  color: var(--text-placeholder);
  font-weight: bold;
  margin-left: var(--space-sm);
}

.quick-actions {
  margin-bottom: var(--space-lg);
}

.actions-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-sm);
}

.action-btn {
  background: var(--surface);
  border-radius: var(--radius-lg);
  padding: var(--space-lg) var(--space-sm);
  text-align: center;
  border: 1rpx solid var(--border);
  transition: transform 0.2s;
}

.action-btn:active {
  transform: scale(0.98);
}

.action-icon {
  font-size: 40rpx;
  margin-bottom: var(--space-sm);
  display: block;
}

.action-text {
  font-size: var(--font-size-base);
  color: var(--text-primary);
  font-weight: 500;
}

.about-section {
  text-align: center;
  padding: var(--space-xl);
  background: var(--surface);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--border);
}

.about-content {
  margin-bottom: var(--space-lg);
}

.app-name {
  font-size: var(--font-size-xl);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--space-xs);
}

.app-desc {
  font-size: var(--font-size-base);
  color: var(--primary);
  margin-bottom: var(--space-sm);
}

.version {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
}

.copyright {
  font-size: var(--font-size-xs);
  color: var(--text-placeholder);
  padding-top: var(--space-sm);
  border-top: 1rpx solid var(--border);
}
