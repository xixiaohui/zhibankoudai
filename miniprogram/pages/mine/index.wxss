/* pages/mine/index.wxss - 我的页面样式 */

.container {
  min-height: 100vh;
  background: #F7F8FC;
  padding-bottom: 60rpx;
}

/* ===== 用户信息卡片 ===== */
.profile-card {
  background: linear-gradient(135deg, #6C63FF 0%, #A594F9 100%);
  padding: 60rpx 32rpx 0;
  border-radius: 0 0 48rpx 48rpx;
}

.profile-bg {
  display: flex;
  align-items: center;
  position: relative;
}

.profile-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  color: #fff;
  overflow: hidden;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.profile-avatar image {
  width: 100%;
  height: 100%;
}

.profile-info {
  flex: 1;
  margin-left: 24rpx;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.profile-title {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.profile-level {
  position: absolute;
  top: 0;
  right: 0;
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
}

.level-expert {
  background: rgba(233, 30, 99, 0.8);
}

.level-senior {
  background: rgba(255, 152, 0, 0.8);
}

.level-mid {
  background: rgba(33, 150, 243, 0.8);
}

/* ===== 数据统计 ===== */
.stats-bar {
  display: flex;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  margin-top: 40rpx;
  padding: 28rpx 0;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #6C63FF;
  margin-bottom: 4rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
}

.stat-divider {
  width: 1rpx;
  height: 50rpx;
  background: #eee;
  margin-top: 4rpx;
}

/* ===== 功能菜单 ===== */
.menu-section {
  background: #fff;
  border-radius: 24rpx;
  margin: 24rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 28rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 44rpx;
  margin-right: 20rpx;
}

.menu-text {
  display: flex;
  flex-direction: column;
}

.menu-label {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.menu-desc {
  font-size: 22rpx;
  color: #999;
}

.menu-arrow {
  font-size: 36rpx;
  color: #ccc;
}

/* ===== 底部信息 ===== */
.footer-info {
  text-align: center;
  padding: 48rpx 24rpx;
}

.app-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #6C63FF;
  margin-bottom: 8rpx;
}

.app-version {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.app-desc {
  display: block;
  font-size: 24rpx;
  color: #bbb;
}
