/* pages/mine/index.wxss */

/* 头部 */
.mine-header {
  background: linear-gradient(135deg, #6C63FF, #9B59B6);
  padding: 48rpx 32rpx 40rpx; position: relative; overflow: hidden; color: #fff;
}
.mh-bg-circle { position: absolute; border-radius: 50%; background: rgba(255,255,255,0.08); }
.mhc1 { width: 260rpx; height: 260rpx; top: -60rpx; right: -40rpx; }
.mhc2 { width: 160rpx; height: 160rpx; bottom: -60rpx; left: -30rpx; background: rgba(255,255,255,0.05); }

/* 用户信息 */
.user-info-row {
  display: flex; align-items: center; gap: 24rpx; margin-bottom: 36rpx; position: relative; z-index: 1;
}
.user-avatar { width: 96rpx; height: 96rpx; border-radius: 48rpx; border: 4rpx solid rgba(255,255,255,0.4); }
.user-name { font-size: 34rpx; font-weight: 700; color: #fff; margin-bottom: 6rpx; }
.user-join { font-size: 22rpx; color: rgba(255,255,255,0.65); }

/* 登录入口 */
.login-btn-wrap {
  display: flex; align-items: center; gap: 20rpx;
  margin-bottom: 36rpx; position: relative; z-index: 1;
}
.default-avatar {
  width: 96rpx; height: 96rpx; border-radius: 48rpx;
  background: rgba(255,255,255,0.2); display: flex; align-items: center;
  justify-content: center; font-size: 52rpx;
}
.login-prompt { flex: 1; }
.login-title { font-size: 32rpx; font-weight: 700; color: #fff; margin-bottom: 6rpx; }
.login-sub { font-size: 22rpx; color: rgba(255,255,255,0.65); }
.login-arrow { font-size: 48rpx; color: rgba(255,255,255,0.5); }

/* 统计 */
.stats-row {
  display: flex; align-items: center;
  background: rgba(255,255,255,0.15); border-radius: 20rpx;
  padding: 24rpx 0; position: relative; z-index: 1;
}
.stat-item { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 6rpx; }
.stat-val { font-size: 40rpx; font-weight: 700; color: #fff; }
.stat-label { font-size: 20rpx; color: rgba(255,255,255,0.7); }
.stat-divider { width: 1rpx; height: 50rpx; background: rgba(255,255,255,0.25); }

/* AI Banner */
.ai-banner {
  display: flex; align-items: center; justify-content: space-between;
  background: linear-gradient(135deg, #1A1A2E, #2D2D5E);
  border-radius: 24rpx; padding: 28rpx 32rpx; margin: 16rpx 24rpx 0;
}
.ai-banner-left { display: flex; align-items: center; gap: 20rpx; }
.ai-banner-icon { font-size: 52rpx; }
.ai-banner-title { font-size: 28rpx; font-weight: 700; color: #fff; margin-bottom: 4rpx; }
.ai-banner-sub { font-size: 22rpx; color: rgba(255,255,255,0.55); }
.ai-banner-arrow { font-size: 48rpx; color: rgba(255,255,255,0.35); }

/* 菜单卡片 */
.menu-card {
  background: #fff; border-radius: 24rpx;
  padding: 0 0; margin: 16rpx 24rpx 0;
  overflow: hidden; box-shadow: 0 4rpx 20rpx rgba(108,99,255,0.08);
}
.menu-item {
  display: flex; align-items: center; padding: 28rpx 28rpx;
  border-bottom: 1rpx solid #F5F5FA;
}
.menu-item:last-child { border-bottom: none; }
.menu-icon-wrap {
  width: 72rpx; height: 72rpx; border-radius: 20rpx;
  background: #F5F5FA; display: flex; align-items: center;
  justify-content: center; margin-right: 20rpx; flex-shrink: 0;
}
.menu-icon { font-size: 36rpx; }
.menu-info { flex: 1; }
.menu-label { font-size: 28rpx; color: #1A1A2E; font-weight: 500; margin-bottom: 4rpx; }
.menu-desc { font-size: 22rpx; color: #999BB8; }
.menu-arrow { font-size: 36rpx; color: #CCCCDD; }

/* 版本 */
.version-info {
  display: flex; flex-direction: column; align-items: center;
  padding: 32rpx 0; gap: 8rpx;
}
.version-logo { font-size: 28rpx; font-weight: 700; color: #6C63FF; }
.version-text { font-size: 22rpx; color: #BBBBCC; }
