/* miniprogram/pages/careerCardList/index.wxss - AI 职业内容生成页面样式 */

.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 头部信息 */
.header {
  background: linear-gradient(135deg, #10B981 0%, #059669 100%);
  padding: 40rpx 30rpx;
  color: #fff;
}

.agent-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.agent-emoji {
  font-size: 60rpx;
}

.agent-detail {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.agent-name {
  font-size: 36rpx;
  font-weight: bold;
}

.agent-category {
  font-size: 24rpx;
  opacity: 0.9;
}

/* 生成区域 */
.generate-section {
  background: #fff;
  padding: 30rpx;
  margin: 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

/* 聊天助手按钮 */
.chat-assistant-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, #6366F1 0%, #818CF8 100%);
  border-radius: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(99, 102, 241, 0.3);
}

.chat-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.chat-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

/* 快速模板 */
.templates {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.template-item {
  font-size: 24rpx;
  color: #666;
  background: #f5f5f5;
  padding: 12rpx 20rpx;
  border-radius: 30rpx;
  border: 2rpx solid transparent;
}

.template-item.active {
  color: #10B981;
  background: #ecfdf5;
  border-color: #10B981;
}

/* 输入框 */
.prompt-input {
  width: 100%;
  min-height: 120rpx;
  padding: 20rpx;
  background: #f9fafb;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}

.prompt-input.disabled {
  opacity: 0.6;
}

.prompt-input[disabled] {
  background: #f5f5f5;
}

/* 生成按钮 */
.generate-btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  background: linear-gradient(135deg, #10B981 0%, #059669 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 45rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.generate-btn.loading {
  background: linear-gradient(135deg, #9CA3AF 0%, #6B7280 100%);
}

.generate-btn[disabled] {
  opacity: 0.6;
}

/* 内容列表 */
.content-section {
  padding: 0 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.refresh-btn {
  font-size: 26rpx;
  color: #10B981;
}

.count {
  font-size: 24rpx;
  color: #999;
}

/* 加载状态 */
.loading-state {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}

/* 内容卡片 */
.content-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
  padding-right: 20rpx;
}

.poster-btn {
  font-size: 24rpx;
  color: #fff;
  background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 100%);
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
}

.card-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  word-break: break-all;
  white-space: pre-wrap;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.card-tag {
  font-size: 22rpx;
  color: #10B981;
  background: #ecfdf5;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.card-date {
  font-size: 24rpx;
  color: #999;
}
