/* pages/detail/index.wxss - Pinterest Design System */

page {
  background: var(--surface);
  min-height: 100vh;
}

.detail-page {
  min-height: 100vh;
  padding-bottom: 160rpx;
  background: var(--surface);
}

.module-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-xxl) var(--space-lg);
  color: var(--surface);
  background-color: var(--text-secondary);
}

.module-icon {
  font-size: 44rpx;
  margin-right: var(--space-sm);
}

.module-name {
  font-size: var(--font-size-xl);
  font-weight: 600;
  letter-spacing: 2rpx;
}

.content-area {
  margin: 0 var(--space-lg);
  padding: var(--space-xl) var(--space-lg) var(--space-lg);
  background: var(--surface);
  position: relative;
}

.content-title {
  font-size: var(--font-size-xl);
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.5;
  margin-bottom: var(--space-md);
}

.content-subtitle {
  font-size: var(--font-size-base);
  color: var(--text-secondary);
  margin-bottom: var(--space-lg);
  line-height: 1.5;
}

.divider {
  width: 60rpx;
  height: 4rpx;
  border-radius: 2rpx;
  margin: var(--space-lg) 0;
  background-color: var(--primary);
}

.content-body {
  margin-bottom: var(--space-lg);
}

.content-text {
  font-size: var(--font-size-lg);
  color: var(--text-primary);
  line-height: 1.9;
}

.content-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
  margin-top: var(--space-lg);
}

.tag-item {
  padding: var(--space-xs) var(--space-md);
  background: var(--accent-warm-light);
  border-radius: var(--radius-full);
  font-size: var(--font-size-sm);
  color: var(--text-primary);
}

.content-extra {
  margin-top: var(--space-lg);
  padding: var(--space-md);
  background: var(--surface-secondary);
  border-radius: var(--radius-md);
  font-size: var(--font-size-base);
  color: var(--text-secondary);
  line-height: 1.6;
}

.quote-decor {
  position: absolute;
  top: var(--space-lg);
  left: var(--space-md);
  opacity: 0.08;
}

.quote-mark {
  font-size: 120rpx;
  font-family: serif;
  line-height: 1;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: var(--space-md);
  padding: var(--space-md) var(--space-lg);
  padding-bottom: calc(var(--space-md) + env(safe-area-inset-bottom));
  background: var(--surface);
  border-top: 1rpx solid var(--border);
}

.btn-poster,
.btn-copy {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  border-radius: var(--radius-lg);
  font-size: var(--font-size-lg);
  font-weight: 500;
  margin: 0;
  padding: 0;
  border: none;
  line-height: 1;
  color: var(--surface);
}

.btn-poster {
  background-color: var(--primary);
}

.btn-copy {
  background: var(--accent-warm-light);
  color: var(--text-primary);
}

.btn-icon {
  font-size: var(--font-size-xl);
  margin-right: var(--space-xs);
}

.btn-text {
  font-size: var(--font-size-base);
}

.btn-poster:active,
.btn-copy:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.section-title {
  margin-top: var(--space-lg);
  margin-bottom: var(--space-md);
  font-size: var(--font-size-base);
  font-weight: 600;
}

.section-title.warning {
  color: var(--primary);
}

.section-content {
  padding: var(--space-md);
  background: var(--surface-secondary);
  border-radius: var(--radius-md);
  margin-bottom: var(--space-xs);
}

.warning-content {
  background: #FFF5F5;
  border: 1rpx solid var(--primary);
}

.quote-content {
  border-left: 4rpx solid var(--primary);
  background: var(--surface-secondary);
  font-style: italic;
}

.lyric-content {
  background: var(--surface-secondary);
  text-align: center;
}

.key-points-list {
  margin-bottom: var(--space-md);
}

.key-point-item {
  display: flex;
  align-items: flex-start;
  padding: var(--space-sm) var(--space-md);
  margin-bottom: var(--space-xs);
  background: var(--surface-secondary);
  border-radius: var(--radius-md);
  line-height: 1.6;
}

.point-num {
  flex-shrink: 0;
  width: 40rpx;
  font-size: var(--font-size-lg);
  font-weight: 600;
  color: var(--primary);
}

.point-text {
  flex: 1;
  font-size: var(--font-size-base);
  color: var(--text-primary);
  line-height: 1.6;
}
