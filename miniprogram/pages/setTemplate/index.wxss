/* pages/setTemplate/index.wxss - 服务设置页面 */
.page-container {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 30rpx;
}

/* 页面标题 */
.page-header {
  padding: 20rpx 0 40rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.header-desc {
  font-size: 26rpx;
  color: #999;
}

/* 设置分组 */
.settings-group {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  overflow: hidden;
}

.group-title {
  font-size: 24rpx;
  color: #999;
  padding: 24rpx 30rpx 16rpx;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

/* 设置项 */
.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-item.danger .setting-name {
  color: #FF4D4F;
}

.setting-item.danger .setting-icon {
  background: #FFF1F0;
}

.setting-item.danger .setting-desc {
  color: #FFBEBE;
}

.setting-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.setting-icon {
  width: 72rpx;
  height: 72rpx;
  background: #F5F5F5;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 24rpx;
}

.setting-info {
  flex: 1;
}

.setting-name {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 6rpx;
}

.setting-value {
  font-size: 26rpx;
  color: #7C6AFF;
}

.setting-desc {
  font-size: 24rpx;
  color: #999;
}

.setting-arrow {
  font-size: 36rpx;
  color: #CCC;
  margin-left: 16rpx;
}

/* 底部占位 */
.bottom-space {
  height: 100rpx;
}
