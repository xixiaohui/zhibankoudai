/* pages/chat/index.wxss - 微信风格聊天界面 */

/* 页面容器 */
.chat-page {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #EDEDED;
  overflow: hidden;
}

/* ==================== 导航栏 ==================== */
.nav-bar {
  width: 100%;
  background-color: #FFFFFF;
  border-bottom: 1rpx solid #E5E5E5;
  flex-shrink: 0;
  z-index: 100;
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
}

.nav-left {
  display: flex;
  align-items: center;
  min-width: 120rpx;
}

.back-icon {
  font-size: 48rpx;
  color: #576B95;
  font-weight: bold;
  margin-right: 4rpx;
}

.back-text {
  font-size: 28rpx;
  color: #576B95;
}

.nav-center {
  display: flex;
  align-items: center;
  flex: 1;
  justify-content: center;
}

.nav-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 8rpx;
  background-color: #6192D6;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
}

.nav-avatar text {
  font-size: 30rpx;
}

.nav-info {
  display: flex;
  flex-direction: column;
}

.nav-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.nav-status {
  font-size: 22rpx;
  color: #999;
}

.nav-right {
  display: flex;
  align-items: center;
  min-width: 120rpx;
  justify-content: flex-end;
}

.clear-icon {
  font-size: 36rpx;
}

/* ==================== 消息区域 ==================== */
.messages-wrapper {
  flex: 1;
  width: 100%;
  overflow: hidden;
}

.messages-container {
  max-width: 750rpx;
  margin: 0 auto;
  padding: 20rpx 0;
}

/* 日期分隔线 */
.date-divider {
  text-align: center;
  margin: 20rpx 0;
}

.date-divider text {
  display: inline-block;
  padding: 8rpx 24rpx;
  background-color: #D4D4D4;
  border-radius: 4rpx;
  font-size: 24rpx;
  color: #fff;
}

/* 欢迎提示 */
.welcome-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.welcome-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.welcome-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.welcome-desc {
  font-size: 26rpx;
  color: #999;
  margin-top: 12rpx;
}

/* ==================== 消息样式 ==================== */
.message-row {
  display: flex;
  margin: 20rpx 24rpx;
  align-items: flex-start;
  animation: msg-appear 0.25s ease;
}

/* AI 消息（头像在左边） */
.ai-row {
  flex-direction: row;
}

.ai-row .avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 8rpx;
  background-color: #6192D6;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ai-row .avatar text {
  font-size: 36rpx;
}

.ai-row .message-content {
  margin-left: 16rpx;
  max-width: 74%;
  display: flex;
  flex-direction: column;
}

.ai-row .time-label {
  font-size: 20rpx;
  color: #B2B2B2;
  margin-top: 6rpx;
  margin-left: 12rpx;
}

/* 用户消息（头像在右边） */
.user-row {
  flex-direction: row-reverse;
}

.user-row .user-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 8rpx;
  background-color: #FAC81B;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.user-row .user-avatar text {
  font-size: 36rpx;
}

.user-row .message-content {
  margin-right: 16rpx;
  max-width: 74%;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.user-row .time-label {
  font-size: 20rpx;
  color: #B2B2B2;
  margin-top: 6rpx;
  margin-right: 12rpx;
}

/* 气泡样式 */
.bubble {
  padding: 18rpx 24rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  line-height: 1.5;
  word-break: break-word;
}

.bubble-text {
  word-break: break-all;
}

/* AI 气泡 - 白色背景 */
.ai-bubble {
  background-color: #fff;
  border: 1rpx solid #E0E0E0;
  border-top-left-radius: 4rpx;
}

/* 用户气泡 - 绿色背景 */
.user-bubble {
  background-color: #96EC6D;
  border-top-right-radius: 4rpx;
}

/* 思考中动画 */
.typing-dot {
  display: inline-block;
  color: #999;
  animation: typing-blink 1s infinite;
}

@keyframes typing-blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

.streaming.ai-bubble {
  min-height: 56rpx;
}

/* ==================== 输入区域 ==================== */
.input-container {
  width: 100%;
  background-color: #F7F7F7;
  border-top: 1rpx solid #D9D9D9;
  flex-shrink: 0;
}

/* 模式标签 */
.mode-tabs {
  display: flex;
  white-space: nowrap;
  padding: 12rpx 16rpx;
  background-color: #F7F7F7;
  border-bottom: 1rpx solid #E5E5E5;
}

.mode-tab {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 18rpx;
  margin-right: 12rpx;
  border-radius: 32rpx;
  background-color: #fff;
  border: 1rpx solid #E0E0E0;
  flex-shrink: 0;
}

.mode-tab.active {
  background-color: #6192D6;
  border-color: #6192D6;
}

.mode-tab .tab-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}

.mode-tab .tab-text {
  font-size: 24rpx;
  color: #666;
}

.mode-tab.active .tab-text {
  color: #fff;
}

/* 输入行 */
.input-row {
  display: flex;
  align-items: flex-end;
  padding: 12rpx 16rpx;
  gap: 12rpx;
}

.input-wrapper {
  flex: 1;
  background-color: #fff;
  border: 1rpx solid #E0E0E0;
  border-radius: 10rpx;
  padding: 14rpx 18rpx;
  min-height: 70rpx;
  max-height: 160rpx;
  box-sizing: border-box;
}

.text-input {
  width: 100%;
  font-size: 30rpx;
  line-height: 1.4;
  color: #333;
  min-height: 40rpx;
}

.placeholder {
  color: #B2B2B2;
  font-size: 30rpx;
}

/* 发送按钮 */
.send-btn {
  width: 96rpx;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 10rpx;
  background-color: #C9C9C9;
  flex-shrink: 0;
}

.send-btn.active {
  background-color: #6192D6;
}

.send-text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 500;
}

.send-btn-hover {
  opacity: 0.85;
}

/* 安全区域 */
.safe-area {
  height: env(safe-area-inset-bottom);
  background-color: #F7F7F7;
}

/* ==================== 动画 ==================== */
@keyframes msg-appear {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
