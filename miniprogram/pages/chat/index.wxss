/* pages/chat/index.wxss - 陪伴对话页面样式 */

.page-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F5F7FA;
}

/* 顶部导航 */
.chat-header {
  background: white;
  padding: 20rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #F0F0F0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.header-left {
  flex: 1;
}

.mode-indicator {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
  color: white;
  font-size: 26rpx;
  font-weight: 500;
}

.mode-icon {
  margin-right: 10rpx;
  font-size: 28rpx;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: #F8F8F8;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #666666;
}

.action-icon {
  margin-right: 6rpx;
  font-size: 26rpx;
}

/* 对话区域 */
.messages-container {
  flex: 1;
  padding: 30rpx;
  overflow-y: auto;
}

.message {
  display: flex;
  margin-bottom: 40rpx;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.ai-message {
  justify-content: flex-start;
}

.user-message {
  justify-content: flex-end;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}

.ai-avatar {
  background: linear-gradient(135deg, #7C6AFF, #9D8FFF);
  color: white;
  margin-right: 20rpx;
}

.user-avatar {
  background: linear-gradient(135deg, #6BCB77, #8CE695);
  color: white;
  margin-left: 20rpx;
}

.message-content {
  max-width: 70%;
  display: flex;
  flex-direction: column;
}

.ai-message .message-content {
  align-items: flex-start;
}

.user-message .message-content {
  align-items: flex-end;
}

.message-text {
  padding: 24rpx 30rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-word;
  position: relative;
}

.ai-message .message-text {
  background: white;
  color: #333333;
  border-top-left-radius: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(124, 106, 255, 0.1);
}

.user-message .message-text {
  background: linear-gradient(135deg, #7C6AFF, #9D8FFF);
  color: white;
  border-top-right-radius: 8rpx;
}

.message-time {
  font-size: 22rpx;
  color: #999999;
  margin-top: 8rpx;
}

.user-message .message-time {
  color: #7C6AFF;
}

/* 思考指示器 */
.thinking-indicator {
  display: flex;
  padding: 24rpx 30rpx;
  background: white;
  border-radius: 32rpx;
  border-top-left-radius: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(124, 106, 255, 0.1);
}

.dot {
  font-size: 40rpx;
  color: #7C6AFF;
  animation: blink 1.4s infinite both;
}

.dot:nth-child(2) {
  animation-delay: 0.2s;
}

.dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes blink {
  0%, 20%, 100% { opacity: 0.2; }
  50% { opacity: 1; }
}

/* 输入区域 */
.input-container {
  background: white;
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #F0F0F0;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.chat-input {
  flex: 1;
  background: #F8F8F8;
  border-radius: 40rpx;
  padding: 24rpx 30rpx;
  font-size: 28rpx;
  color: #333333;
  min-height: 80rpx;
  max-height: 200rpx;
}

.send-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #7C6AFF;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
  font-size: 36rpx;
}

.send-btn[disabled] {
  background: #CCCCCC;
  opacity: 0.6;
}

.send-icon {
  margin-top: 2rpx;
}

/* 模式选择弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.mode-select-modal {
  background: white;
  border-radius: 32rpx;
  width: 700rpx;
  max-width: 90vw;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.modal-header {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  text-align: center;
  padding: 40rpx 40rpx 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.modes-list {
  flex: 1;
  overflow-y: auto;
  padding: 30rpx 40rpx;
}

.mode-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 24rpx;
  border: 2rpx solid #F0F0F0;
  background: #F8F8F8;
  transition: all 0.2s;
  position: relative;
}

.mode-item.selected {
  border-color: #7C6AFF;
  background: rgba(124, 106, 255, 0.05);
}

.mode-item:active {
  transform: scale(0.98);
}

.mode-item-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: white;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.mode-item-info {
  flex: 1;
}

.mode-item-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.mode-item-desc {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.4;
}

.selected-mark {
  color: #7C6AFF;
  font-size: 36rpx;
  font-weight: bold;
  margin-left: 20rpx;
}

.modal-footer {
  padding: 30rpx 40rpx;
  border-top: 1rpx solid #F0F0F0;
  display: flex;
  justify-content: center;
}

.btn-cancel {
  background: #F8F8F8;
  color: #666666;
  border-radius: 16rpx;
  padding: 20rpx 60rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
}

.btn-cancel:active {
  background: #EEEEEE;
}