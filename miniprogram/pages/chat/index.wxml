<!-- pages/chat/index.wxml - 微信风格聊天页面 -->
<view class="chat-page">

  <!-- 对话区域 -->
  <scroll-view 
    class="messages-wrapper" 
    scroll-y
    scroll-top="{{scrollTop}}"
    scroll-into-view="{{scrollIntoView}}"
    scroll-with-animation
    enhanced
    bounces="{{false}}"
  >
    <view class="messages-container">
      <!-- 日期分隔线 -->
      <view class="date-divider" wx:if="{{showDateDivider}}">
        <text>{{currentDate}}</text>
      </view>

      <!-- 欢迎提示 -->
      <view class="welcome-tip" wx:if="{{messages.length === 0 && !isLoading}}">
        <text class="welcome-icon">👋</text>
        <text class="welcome-text">{{modeIcon}} {{modeName}}</text>
        <text class="welcome-desc">随时陪你聊聊</text>
      </view>

      <!-- 消息列表 -->
      <block wx:for="{{messages}}" wx:key="uniqueId">
        
        <!-- AI消息（头像在左边） -->
        <view wx:if="{{item.type === 'ai'}}" class="message-row ai-row" id="msg-{{item.uniqueId}}">
          <view class="avatar avatar-left">
            <text class="avatar-icon">🤖</text>
          </view>
          <view class="message-content">
            <view class="bubble ai-bubble {{item.isStreaming ? 'streaming' : ''}}">
              <text class="bubble-text">{{item.content}}</text>
              <text class="typing-dot" wx:if="{{item.isStreaming}}">...</text>
            </view>
            <text class="time-label">{{formatTimeDisplay(item.time)}}</text>
          </view>
        </view>
        
        <!-- 用户消息（头像在右边） -->
        <view wx:if="{{item.type === 'user'}}" class="message-row user-row" id="msg-{{item.uniqueId}}">
          <view class="message-content">
            <view class="bubble user-bubble">
              <text class="bubble-text">{{item.content}}</text>
            </view>
            <text class="time-label">{{formatTimeDisplay(item.time)}}</text>
          </view>
          <view class="avatar avatar-right">
            <text class="avatar-icon">😀</text>
          </view>
        </view>
        
      </block>

      <!-- 滚动到底部标记 -->
      <view id="msg-bottom"></view>
    </view>
  </scroll-view>

  <!-- 底部输入区域 -->
  <view class="input-container">
    <!-- 模式标签 + 更多工具 -->
    <scroll-view class="mode-tabs" scroll-x enable-flex>
      <block wx:for="{{chatModes}}" wx:key="id">
        <view 
          class="mode-tab {{item.id === mode ? 'active' : ''}}" 
          data-mode="{{item.id}}" 
          bindtap="onSelectMode"
        >
          <text class="tab-icon">{{item.icon}}</text>
          <text class="tab-text">{{item.name}}</text>
        </view>
      </block>
      <!-- 更多工具按钮 -->
      <view class="mode-tab more-tab {{showMenu ? 'active' : ''}}" bindtap="toggleMenu">
        <text class="tab-icon">⋯</text>
        <text class="tab-text">更多</text>
      </view>
    </scroll-view>

    <!-- 输入框 -->
    <view class="input-row">
      <view class="input-wrapper">
        <textarea
          class="text-input"
          placeholder="说点什么..."
          placeholder-class="placeholder"
          value="{{inputValue}}"
          bindinput="onInput"
          bindconfirm="onSend"
          maxlength="500"
          cursor-spacing="10"
          auto-height
          show-confirm-bar="{{false}}"
          adjust-position="{{false}}"
        />
      </view>
      <view 
        class="send-btn {{inputValue.length > 0 ? 'active' : ''}}" 
        bindtap="onSend"
        hover-class="send-btn-hover"
      >
        <text class="send-text">发送</text>
      </view>
    </view>
    
    <!-- 安全区域 -->
    <view class="safe-area"></view>
  </view>

  <!-- 下拉菜单遮罩层 -->
  <view class="menu-overlay {{showMenu ? 'show' : ''}}" bindtap="toggleMenu"></view>

  <!-- 下拉菜单 -->
  <view class="dropdown-menu {{showMenu ? 'show' : ''}}">
    <view class="menu-header">
      <text class="menu-title">更多工具</text>
    </view>
    <view class="menu-list">
      <view class="menu-item" bindtap="onClearChat">
        <text class="menu-item-icon">🗑</text>
        <text class="menu-item-text">清空对话</text>
      </view>
      <view class="menu-item" bindtap="onShareToTimeline">
        <text class="menu-item-icon">🖼</text>
        <text class="menu-item-text">分享海报</text>
      </view>
      <view class="menu-item" bindtap="onShareApp">
        <text class="menu-item-icon">↗</text>
        <text class="menu-item-text">分享给好友</text>
      </view>
      <view class="menu-item" bindtap="onViewMemory">
        <text class="menu-item-icon">🧠</text>
        <text class="menu-item-text">查看记忆</text>
      </view>
      <view class="menu-item" bindtap="onAbout">
        <text class="menu-item-icon">ℹ</text>
        <text class="menu-item-text">关于智伴</text>
      </view>
    </view>
    <view class="menu-footer">
      <text class="mode-hint">{{modeIcon}} 当前模式：{{modeName}}</text>
    </view>
  </view>

</view>
