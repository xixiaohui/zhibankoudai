<!-- pages/chat/index.wxml - 陪伴对话页面 -->
<view class="page-container">
  <!-- 顶部导航 -->
  <view class="chat-header">
    <view class="header-left">
      <view class="mode-indicator" style="background-color: {{modeColor}}">
        <text class="mode-icon">{{modeIcon}}</text>
        <text class="mode-name">{{modeName}}</text>
      </view>
    </view>
    <view class="header-right">
      <view class="action-btn" bindtap="onSwitchMode">
        <text class="action-icon">🔄</text>
        <text class="action-text">切换</text>
      </view>
      <view class="action-btn" bindtap="onClearChat">
        <text class="action-icon">🗑️</text>
        <text class="action-text">清空</text>
      </view>
    </view>
  </view>

  <!-- 对话区域 -->
  <scroll-view class="messages-container" scroll-y scroll-with-animation scroll-top="{{scrollTop}}">
    <block wx:for="{{messages}}" wx:key="id">
      <!-- AI消息 -->
      <view wx:if="{{item.type === 'ai'}}" class="message ai-message">
        <view class="avatar ai-avatar">🤖</view>
        <view class="message-content">
          <view class="message-text">{{item.content}}</view>
          <view class="message-time">{{formatTimeDisplay(item.time)}}</view>
        </view>
      </view>
      
      <!-- 用户消息 -->
      <view wx:if="{{item.type === 'user'}}" class="message user-message">
        <view class="message-content">
          <view class="message-text">{{item.content}}</view>
          <view class="message-time">{{formatTimeDisplay(item.time)}}</view>
        </view>
        <view class="avatar user-avatar">👤</view>
      </view>
    </block>
    
    <!-- AI思考中 -->
    <view wx:if="{{isAIThinking}}" class="message ai-message">
      <view class="avatar ai-avatar">🤖</view>
      <view class="message-content">
        <view class="thinking-indicator">
          <text class="dot">.</text>
          <text class="dot">.</text>
          <text class="dot">.</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 输入区域 -->
  <view class="input-container">
    <input 
      class="chat-input" 
      placeholder="说点什么..." 
      value="{{inputValue}}"
      bindinput="onInput"
      bindconfirm="onSend"
      placeholder-style="color: #999999"
      confirm-type="send"
    />
    <button class="send-btn" bindtap="onSend" disabled="{{!inputValue.trim()}}">
      <text class="send-icon">📤</text>
    </button>
  </view>

  <!-- 模式选择弹窗 -->
  <view wx:if="{{showModeSelect}}" class="modal-mask" catchtap="onCloseModeSelect">
    <view class="mode-select-modal" catchtap="noop">
      <view class="modal-header">选择陪伴模式</view>
      <view class="modes-list">
        <block wx:for="{{getChatModes()}}" wx:key="id">
          <view 
            class="mode-item {{item.id === mode ? 'selected' : ''}}" 
            data-mode="{{item.id}}" 
            bindtap="onSelectMode"
          >
            <view class="mode-item-icon" style="background-color: {{item.color}}">{{item.icon}}</view>
            <view class="mode-item-info">
              <view class="mode-item-name">{{item.name}}</view>
              <view class="mode-item-desc">{{item.prompt}}</view>
            </view>
            <view wx:if="{{item.id === mode}}" class="selected-mark">✓</view>
          </view>
        </block>
      </view>
      <view class="modal-footer">
        <button class="btn-cancel" bindtap="onCloseModeSelect">取消</button>
      </view>
    </view>
  </view>
</view>