<!-- pages/dailyTest/dailyTest.wxml - 每日内容组件测试页面 -->
<view class="page-container">
  <view class="page-header">
    <view class="header-title">每日内容组件测试</view>
    <view class="header-desc">测试通用每日内容卡片组件</view>
  </view>

