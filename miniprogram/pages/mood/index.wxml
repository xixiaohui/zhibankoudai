<!-- pages/mood/index.wxml - 情绪记录页面 -->
<view class="page-container">
  <!-- 顶部标题 -->
  <view class="header">
    <view class="title">记录此刻心情</view>
    <view class="subtitle">标记你的情绪，让我更懂你</view>
  </view>

  <!-- 情绪选择网格 -->
  <view class="moods-section">
    <view class="section-title">选择你的情绪</view>
    <view class="moods-grid">
      <block wx:for="{{moods}}" wx:key="id">
        <view 
          class="mood-item {{item.selected ? 'selected' : ''}}" 
          style="background-color: {{item.selected ? item.color : '#F8F8F8'}}; border-color: {{item.color}}"
          data-id="{{item.id}}"
          bindtap="onSelectMood"
        >
          <view class="mood-emoji">{{item.emoji}}</view>
          <view class="mood-name">{{item.id}}</view>
        </view>
      </block>
    </view>
  </view>

  <!-- 备注输入区域 -->
  <view wx:if="{{showNoteInput}}" class="note-section">
    <view class="section-title">发生了什么？</view>
    <view class="selected-mood-display">
      <text class="selected-emoji">{{getMoodEmoji(selectedMood)}}</text>
      <text class="selected-text">{{selectedMood}}</text>
    </view>
    <textarea 
      class="note-input" 
      placeholder="想记录点什么吗？（选填）" 
      value="{{note}}"
      bindinput="onNoteInput"
      placeholder-style="color: #CCCCCC"
      maxlength="200"
      auto-height
    />
    <view class="input-tip">写下原因或感受，我会更好地理解你</view>
    
    <button class="submit-btn" bindtap="onSubmit" loading="{{isSubmitting}}">
      {{isSubmitting ? '记录中...' : '记录情绪'}}
    </button>
    
    <view class="quick-chat-tip" bindtap="onStartChatWithMood">
      <text class="tip-icon">💬</text>
      <text class="tip-text">想聊聊这个情绪吗？</text>
    </view>
  </view>

  <!-- 快捷记录 -->
  <view wx:if="{{!showNoteInput}}" class="quick-section">
    <view class="section-title">快捷记录</view>
    <view class="quick-tip">点击情绪标签直接记录（无备注）</view>
    <view class="quick-moods">
      <block wx:for="{{moods}}" wx:key="id">
        <view 
          class="quick-mood-item" 
          style="background-color: {{item.color}}"
          data-id="{{item.id}}"
          bindtap="onQuickRecord"
        >
          <text class="quick-emoji">{{item.emoji}}</text>
          <text class="quick-name">{{item.id}}</text>
        </view>
      </block>
    </view>
  </view>

  <!-- 本周情绪统计 -->
  <view wx:if="{{hasMoodStats}}" class="stats-section">
    <view class="section-header">
      <view class="section-title">本周情绪统计</view>
      <view class="view-trend" bindtap="onViewMoodTrend">查看趋势 ↗</view>
    </view>
    <view class="stats-grid">
      <block wx:for="{{moods}}" wx:key="id">
        <view wx:if="{{moodStats[item.id]}}" class="stat-item">
          <view class="stat-header">
            <text class="stat-emoji">{{item.emoji}}</text>
            <text class="stat-name">{{item.id}}</text>
          </view>
          <view class="stat-bar-container">
            <view 
              class="stat-bar" 
              style="width: {{(moodStats[item.id] / moodStatsMax) * 100}}%; background-color: {{item.color}}"
            ></view>
          </view>
          <view class="stat-count">{{moodStats[item.id]}}次</view>
        </view>
      </block>
    </view>
  </view>

  <!-- 最近记录 -->
  <view wx:if="{{recentRecords.length > 0}}" class="history-section">
    <view class="section-title">最近记录</view>
    <view class="records-list">
      <block wx:for="{{recentRecords}}" wx:key="id">
        <view class="record-item" data-record="{{item}}" bindtap="onViewRecordDetail">
          <view class="record-left">
            <view class="record-mood">
              <text class="record-emoji">{{getMoodEmoji(item.mood)}}</text>
              <text class="record-mood-text">{{item.mood}}</text>
            </view>
            <view wx:if="{{item.note}}" class="record-note">{{item.note}}</view>
          </view>
          <view class="record-right">
            <view class="record-time">{{formatRelativeTime(item.date + ' ' + item.time)}}</view>
            <view class="record-date">{{formatDateDisplay(item.date)}}</view>
          </view>
        </view>
      </block>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{recentRecords.length === 0 && !showNoteInput}}" class="empty-section">
    <view class="empty-icon">📝</view>
    <view class="empty-title">还没有情绪记录</view>
    <view class="empty-desc">开始记录你的情绪，我会更好地陪伴你</view>
  </view>
</view>