/* pages/mood/index.wxss - Pinterest Design System */

.page-container {
  min-height: 100vh;
  background-color: var(--surface-secondary);
  padding: var(--space-lg) var(--space-lg) 100rpx;
}

.header {
  padding: var(--space-xl) 0 var(--space-lg);
  text-align: center;
}

.title {
  font-size: var(--font-size-xxxl);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--space-xs);
}

.subtitle {
  font-size: var(--font-size-base);
  color: var(--text-secondary);
}

.section-title {
  font-size: var(--font-size-xl);
  font-weight: 600;
  color: var(--text-primary);
  margin: var(--space-lg) 0 var(--space-sm);
}

.moods-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-sm);
}

.mood-item {
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-lg);
  padding: var(--space-lg) var(--space-sm);
  text-align: center;
  transition: all 0.2s;
}

.mood-item.selected {
  color: var(--surface);
  background-color: var(--primary);
  border-color: var(--primary);
  transform: scale(1.02);
}

.mood-emoji {
  font-size: 60rpx;
  margin-bottom: var(--space-sm);
  display: block;
}

.mood-name {
  font-size: var(--font-size-base);
  font-weight: 500;
}

.note-section {
  background: var(--surface);
  border-radius: var(--radius-lg);
  padding: var(--space-xl);
  margin-top: var(--space-lg);
  border: 1rpx solid var(--border);
}

.selected-mood-display {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-sm);
  margin-bottom: var(--space-lg);
  padding: var(--space-sm);
  background: var(--surface-secondary);
  border-radius: var(--radius-md);
}

.selected-emoji {
  font-size: 40rpx;
}

.selected-text {
  font-size: var(--font-size-xl);
  font-weight: 600;
  color: var(--text-primary);
}

.note-input {
  width: 100%;
  min-height: 200rpx;
  background: var(--surface-secondary);
  border-radius: var(--radius-md);
  padding: var(--space-lg);
  font-size: var(--font-size-base);
  color: var(--text-primary);
  line-height: 1.5;
  margin-bottom: var(--space-sm);
  border: 1rpx solid var(--border);
}

.input-tip {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
  text-align: center;
  margin-bottom: var(--space-lg);
}

.submit-btn {
  background: var(--primary);
  color: var(--surface);
  border-radius: var(--radius-md);
  padding: var(--space-lg);
  font-size: var(--font-size-lg);
  font-weight: 500;
  border: none;
  margin-bottom: var(--space-sm);
}

.submit-btn:active {
  opacity: 0.9;
}

.quick-chat-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-xs);
  color: var(--text-primary);
  font-size: var(--font-size-base);
  padding: var(--space-sm);
  border-radius: var(--radius-md);
  border: 1rpx dashed var(--border);
  background: var(--accent-warm-light);
}

.tip-icon {
  font-size: var(--font-size-lg);
}

.quick-section {
  margin-top: var(--space-lg);
}

.quick-tip {
  font-size: var(--font-size-base);
  color: var(--text-secondary);
  margin-bottom: var(--space-sm);
  text-align: center;
}

.quick-moods {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
  justify-content: center;
}

.quick-mood-item {
  padding: var(--space-sm) var(--space-lg);
  border-radius: var(--radius-full);
  color: var(--surface);
  font-size: var(--font-size-base);
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  transition: transform 0.2s;
  background-color: var(--text-secondary);
}

.quick-mood-item:active {
  transform: scale(0.95);
}

.quick-emoji {
  font-size: var(--font-size-base);
}

.stats-section {
  background: var(--surface);
  border-radius: var(--radius-lg);
  padding: var(--space-xl);
  margin-top: var(--space-lg);
  border: 1rpx solid var(--border);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-lg);
}

.view-trend {
  font-size: var(--font-size-base);
  color: var(--primary);
  font-weight: 500;
}

.stats-grid {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.stat-item {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.stat-header {
  width: 120rpx;
  display: flex;
  align-items: center;
  gap: var(--space-xs);
}

.stat-emoji {
  font-size: var(--font-size-xl);
}

.stat-name {
  font-size: var(--font-size-base);
  color: var(--text-primary);
  font-weight: 500;
}

.stat-bar-container {
  flex: 1;
  height: 20rpx;
  background: var(--accent-warm-light);
  border-radius: 10rpx;
  overflow: hidden;
}

.stat-bar {
  height: 100%;
  border-radius: 10rpx;
  transition: width 0.5s ease;
  background-color: var(--primary);
}

.stat-count {
  width: 80rpx;
  text-align: right;
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
  font-weight: 500;
}

.history-section {
  margin-top: var(--space-lg);
}

.records-list {
  background: var(--surface);
  border-radius: var(--radius-lg);
  overflow: hidden;
  border: 1rpx solid var(--border);
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-lg);
  border-bottom: 1rpx solid var(--border);
}

.record-item:last-child {
  border-bottom: none;
}

.record-left {
  flex: 1;
}

.record-mood {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  margin-bottom: var(--space-xs);
}

.record-emoji {
  font-size: 36rpx;
}

.record-mood-text {
  font-size: var(--font-size-base);
  color: var(--text-primary);
  font-weight: 500;
}

.record-note {
  font-size: var(--font-size-base);
  color: var(--text-secondary);
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.record-right {
  text-align: right;
  margin-left: var(--space-sm);
}

.record-time {
  font-size: var(--font-size-base);
  color: var(--text-secondary);
  margin-bottom: 4rpx;
}

.record-date {
  font-size: var(--font-size-sm);
  color: var(--text-placeholder);
}

.empty-section {
  text-align: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: var(--space-lg);
  opacity: 0.5;
}

.empty-title {
  font-size: var(--font-size-xl);
  color: var(--text-placeholder);
  margin-bottom: var(--space-sm);
}

.empty-desc {
  font-size: var(--font-size-base);
  color: var(--text-secondary);
}
