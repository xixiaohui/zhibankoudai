/* pages/memory/index.wxss - Pinterest Design System */

.page-container {
  min-height: 100vh;
  background-color: var(--surface-secondary);
  padding: var(--space-lg) var(--space-lg) 100rpx;
}

.header {
  padding: var(--space-xl) 0 var(--space-lg);
  text-align: center;
}

.title {
  font-size: var(--font-size-xxxl);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--space-xs);
}

.subtitle {
  font-size: var(--font-size-base);
  color: var(--text-secondary);
}

.stats-overview {
  background: var(--surface);
  border-radius: var(--radius-lg);
  padding: var(--space-xl);
  margin-bottom: var(--space-lg);
  border: 1rpx solid var(--border);
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-sm);
  margin-bottom: var(--space-lg);
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: var(--font-size-xxl);
  font-weight: 600;
  color: var(--primary);
  margin-bottom: 4rpx;
}

.stat-label {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
}

.view-detail {
  text-align: center;
  color: var(--text-primary);
  font-size: var(--font-size-base);
  font-weight: 500;
  padding: var(--space-sm);
  border-radius: var(--radius-md);
  background: var(--accent-warm-light);
  border: 1rpx solid var(--border);
}

.tabs-container {
  display: flex;
  background: var(--surface);
  border-radius: var(--radius-lg);
  padding: var(--space-xs);
  margin-bottom: var(--space-lg);
  border: 1rpx solid var(--border);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-sm);
  border-radius: var(--radius-md);
  transition: all 0.2s;
}

.tab-item.active {
  background: var(--accent-warm-light);
}

.tab-icon {
  font-size: var(--font-size-xl);
  margin-bottom: var(--space-xs);
}

.tab-name {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
}

.tab-item.active .tab-name {
  color: var(--text-primary);
  font-weight: 500;
}

.tab-content {
  margin-bottom: var(--space-lg);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-lg);
  padding-bottom: var(--space-sm);
  border-bottom: 1rpx solid var(--border);
}

.card-title {
  font-size: var(--font-size-xl);
  font-weight: 600;
  color: var(--text-primary);
}

.card-actions .action-btn {
  color: var(--text-primary);
  font-size: var(--font-size-base);
  font-weight: 500;
  padding: var(--space-xs) var(--space-sm);
  border-radius: var(--radius-md);
  background: var(--accent-warm-light);
}

.profile-card,
.recent-card,
.goals-card,
.milestones-card {
  background: var(--surface);
  border-radius: var(--radius-lg);
  padding: var(--space-xl);
  margin-bottom: var(--space-sm);
  border: 1rpx solid var(--border);
}

.profile-field {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-md) 0;
  border-bottom: 1rpx solid var(--surface-secondary);
}

.profile-field:last-child {
  border-bottom: none;
}

.field-label {
  font-size: var(--font-size-base);
  color: var(--text-secondary);
  font-weight: 500;
}

.field-value {
  font-size: var(--font-size-base);
  color: var(--text-primary);
}

.edit-form {
  margin-top: var(--space-sm);
}

.form-field {
  margin-bottom: var(--space-lg);
}

.form-input {
  background: var(--surface-secondary);
  border-radius: var(--radius-md);
  padding: var(--space-md);
  font-size: var(--font-size-base);
  color: var(--text-primary);
  margin-top: var(--space-xs);
  border: 1rpx solid var(--border);
}

.tone-selector {
  display: flex;
  gap: var(--space-sm);
  margin-top: var(--space-xs);
}

.tone-option {
  flex: 1;
  text-align: center;
  padding: var(--space-sm);
  background: var(--surface-secondary);
  border-radius: var(--radius-md);
  font-size: var(--font-size-base);
  color: var(--text-secondary);
  border: 2rpx solid transparent;
}

.tone-option.selected {
  background: var(--accent-warm-light);
  color: var(--text-primary);
  border-color: var(--text-primary);
  font-weight: 500;
}

.form-actions {
  display: flex;
  gap: var(--space-sm);
  margin-top: var(--space-xl);
}

.btn-cancel,
.btn-save {
  flex: 1;
  border-radius: var(--radius-md);
  padding: var(--space-md);
  font-size: var(--font-size-base);
  font-weight: 500;
  border: none;
}

.btn-cancel {
  background: var(--surface-secondary);
  color: var(--text-secondary);
}

.btn-save {
  background: var(--primary);
  color: var(--surface);
}

.section {
  margin-bottom: var(--space-lg);
}

.section-title {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--space-sm);
}

.mood-timeline {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.mood-day {
  display: flex;
  align-items: center;
  padding: var(--space-sm);
  background: var(--surface-secondary);
  border-radius: var(--radius-md);
}

.mood-date {
  flex: 1;
  font-size: var(--font-size-base);
  color: var(--text-secondary);
}

.mood-emoji {
  font-size: var(--font-size-xl);
  margin: 0 var(--space-sm);
}

.mood-text {
  font-size: var(--font-size-base);
  color: var(--text-primary);
  font-weight: 500;
}

.events-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.event-item {
  background: var(--surface-secondary);
  border-radius: var(--radius-md);
  padding: var(--space-lg);
}

.event-content {
  font-size: var(--font-size-base);
  color: var(--text-primary);
  line-height: 1.5;
  margin-bottom: var(--space-xs);
}

.event-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.event-date {
  font-size: var(--font-size-sm);
  color: var(--text-placeholder);
}

.event-mood {
  font-size: var(--font-size-sm);
  color: var(--primary);
}

.delete-btn {
  color: var(--primary);
  font-size: var(--font-size-sm);
  font-weight: 500;
}

.goals-list,
.completed-goals {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.goal-item,
.completed-goal {
  display: flex;
  align-items: flex-start;
  padding: var(--space-md);
  background: var(--surface-secondary);
  border-radius: var(--radius-md);
}

.goal-checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid var(--border);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-base);
  color: var(--text-placeholder);
  margin-right: var(--space-sm);
  margin-top: 4rpx;
  flex-shrink: 0;
}

.completed-checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid var(--success);
  border-radius: 50%;
  background: var(--success);
  color: var(--surface);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-sm);
  margin-right: var(--space-sm);
  margin-top: 4rpx;
  flex-shrink: 0;
}

.goal-content {
  flex: 1;
}

.goal-text {
  font-size: var(--font-size-base);
  color: var(--text-primary);
  line-height: 1.4;
  margin-bottom: var(--space-xs);
}

.goal-meta {
  display: flex;
  gap: var(--space-sm);
  font-size: var(--font-size-sm);
  color: var(--text-placeholder);
}

.goal-created {
  color: var(--text-placeholder);
}

.goal-deadline {
  color: #E60023;
}

.goal-actions {
  display: flex;
  align-items: center;
}

.completed-content {
  flex: 1;
  font-size: var(--font-size-base);
  color: var(--text-secondary);
  text-decoration: line-through;
  margin-bottom: var(--space-xs);
}

.completed-date {
  font-size: var(--font-size-sm);
  color: var(--success);
}

.milestones-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.milestone-item {
  display: flex;
  align-items: flex-start;
  padding: var(--space-md);
  background: var(--surface-secondary);
  border-radius: var(--radius-md);
}

.milestone-icon {
  font-size: 40rpx;
  margin-right: var(--space-sm);
  margin-top: 4rpx;
}

.milestone-content {
  flex: 1;
}

.milestone-text {
  font-size: var(--font-size-base);
  color: var(--text-primary);
  line-height: 1.4;
  margin-bottom: var(--space-xs);
}

.milestone-date {
  font-size: var(--font-size-sm);
  color: var(--text-placeholder);
}

.empty-state {
  text-align: center;
  padding: var(--space-xxl) 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: var(--space-md);
  opacity: 0.5;
}

.empty-text {
  font-size: var(--font-size-xl);
  color: var(--text-placeholder);
  margin-bottom: var(--space-xs);
}

.empty-desc {
  font-size: var(--font-size-base);
  color: var(--text-secondary);
}

.danger-zone {
  background: var(--surface);
  border-radius: var(--radius-lg);
  padding: var(--space-xl);
  margin-top: var(--space-lg);
  border: 2rpx solid var(--primary);
}

.danger-title {
  font-size: var(--font-size-xl);
  font-weight: 600;
  color: var(--primary);
  margin-bottom: var(--space-xs);
}

.danger-desc {
  font-size: var(--font-size-base);
  color: var(--text-secondary);
  line-height: 1.4;
  margin-bottom: var(--space-lg);
}

.btn-danger {
  background: var(--primary);
  color: var(--surface);
  border-radius: var(--radius-md);
  padding: var(--space-md);
  font-size: var(--font-size-base);
  font-weight: 500;
  border: none;
}

.btn-danger:active {
  opacity: 0.9;
}
