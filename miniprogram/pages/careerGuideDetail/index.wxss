  border-left: 3rpx solid #0EA5E9;
  line-height: 1.5;
  word-break: break-all;
}

/* 学习与记忆列表 */
.learning-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.learning-item {
  font-size: 26rpx;
  color: #555;
  padding: 16rpx;
  background: linear-gradient(135deg, #fae8ff 0%, #fff 100%);
  border-radius: 12rpx;
  border-left: 3rpx solid #A855F7;
  line-height: 1.5;
  word-break: break-all;
}

/* 附加说明列表 */
.notes-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.notes-item {
  font-size: 26rpx;
  color: #555;
  padding: 16rpx;
  background: #fafafa;
  border-radius: 12rpx;
  line-height: 1.5;
  word-break: break-all;
}

/* 工具网格 */
.tools-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tool-tag {
  font-size: 24rpx;
  color: #fff;
  background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 100%);
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
}

/* 操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  display: flex;
  gap: 20rpx;
}

.share-btn,
.ai-generate-btn {
  flex: 1;
  height: 90rpx;
  line-height: 90rpx;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 45rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ai-generate-btn {
  background: linear-gradient(135deg, #10B981 0%, #059669 100%);
}

.share-btn {
  background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 100%);
}

.share-btn:active,
.ai-generate-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

/* 加载状态 */
.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 60vh;
  font-size: 28rpx;
  color: #999;
}
