  border-radius: 12rpx;
  border-left: 3rpx solid #EC4899;
  line-height: 1.5;
  word-break: break-all;
}

/* 专业领域列表 */
.expertise-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.expertise-item {
  font-size: 26rpx;
  color: #555;
  padding: 16rpx;
  background: linear-gradient(135deg, #ecfdf5 0%, #fff 100%);
  border-radius: 12rpx;
  border-left: 3rpx solid #10B981;
  line-height: 1.5;
  word-break: break-all;
}

/* 成功指标列表 */
.metrics-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.metrics-item {
  font-size: 26rpx;
