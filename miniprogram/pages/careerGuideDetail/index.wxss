/* miniprogram/pages/careerGuideDetail/index.wxss */

.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
  overflow-x: hidden;
  max-width: 750rpx;
  margin: 0 auto;
  box-sizing: border-box;
}

/* 头部区域 */
.header {
  padding: 60rpx 30rpx 80rpx;
  color: #fff;
}

.header-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.agent-emoji {
  font-size: 100rpx;
  margin-bottom: 20rpx;
  background: rgba(255, 255, 255, 0.2);
  width: 160rpx;
  height: 160rpx;
  line-height: 160rpx;
  text-align: center;
  border-radius: 40rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.2);
}

.agent-name {
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
  text-align: center;
  color: #059669;
}

.agent-tags {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 16rpx;
}

.tag {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.2);
}

.vibe-tag {
  font-style: italic;
  opacity: 0.9;
}

/* 内容区块 */
.section {
  margin: 20rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.section-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  word-break: break-all;
}

/* 核心使命列表 */
.mission-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.mission-item {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 20rpx;
  background: linear-gradient(135deg, #f8f9ff 0%, #fff 100%);
  border-radius: 16rpx;
  border-left: 4rpx solid #6366F1;
}

.mission-text {
  font-size: 28rpx;
  color: #444;
  line-height: 1.5;
  word-break: break-all;
}

/* 关键规则列表 */
.rules-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.rule-item {
  padding: 16rpx 20rpx;
  background: linear-gradient(135deg, #fff5f5 0%, #fff 100%);
  border-radius: 16rpx;
  border-left: 4rpx solid #EF4444;
}

.rule-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  word-break: break-all;
}

/* 工作流程列表 */
.workflow-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.workflow-item {
  font-size: 26rpx;
  color: #555;
  padding: 16rpx;
  background: #fafafa;
  border-radius: 12rpx;
  line-height: 1.5;
  word-break: break-all;
}

/* 技术产出列表 */
.deliverable-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.deliverable-item {
  font-size: 26rpx;
  color: #555;
  padding: 16rpx;
  background: linear-gradient(135deg, #f0f9ff 0%, #fff 100%);
  border-radius: 12rpx;
  border-left: 3rpx solid #0EA5E9;
  line-height: 1.5;
  word-break: break-all;
}

/* 背景经历列表 */
.background-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.background-item {
  font-size: 26rpx;
  color: #555;
  padding: 16rpx;
  background: linear-gradient(135deg, #f5f3ff 0%, #fff 100%);
  border-radius: 12rpx;
  border-left: 3rpx solid #8B5CF6;
  line-height: 1.5;
  word-break: break-all;
}

/* 沟通风格列表 */
