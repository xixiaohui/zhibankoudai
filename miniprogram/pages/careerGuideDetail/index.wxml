<!-- miniprogram/pages/careerGuideDetail/index.wxml - AI Agent 详情页 -->
<view class="container" wx:if="{{agent}}">
  <!-- 头部区域 -->
  <view class="header" style="background: linear-gradient(135deg, {{agent.color}} 0%, {{agent.color}}cc 100%)">
    <view class="header-content">
      <text class="agent-emoji">{{agent.emoji || '🤖'}}</text>
      <text class="agent-name">{{agent.name || agent.nameEn}}</text>
      <view class="agent-tags">
        <text class="tag category-tag">{{agent.categoryIcon}} {{agent.categoryName || agent.categoryNameEn}}</text>
        <text class="tag vibe-tag">{{agent.vibe || agent.vibeEn}}</text>
      </view>
    </view>
  </view>

  <!-- 简介 -->
  <view class="section">
    <view class="section-title">💡 Description</view>
    <view class="section-content">
      <text>{{agent.description || agent.descriptionEn}}</text>
    </view>
  </view>

  <!-- 核心使命 Core Mission -->
  <view class="section" wx:if="{{agent.coreMission.length > 0}}">
    <view class="section-title">🎯 Core Mission</view>
    <view class="mission-list">
      <view wx:for="{{agent.coreMission}}" wx:key="index" class="mission-item">
        <text class="mission-text">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 关键规则 Critical Rules -->
  <view class="section" wx:if="{{agent.criticalRules.length > 0}}">
    <view class="section-title">⚠️ Critical Rules</view>
    <view class="rules-list">
      <view wx:for="{{agent.criticalRules}}" wx:key="index" class="rule-item">
        <text class="rule-text">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 工作流程 Workflow -->
  <view class="section" wx:if="{{agent.workflow.length > 0}}">
    <view class="section-title">🔄 Workflow Process</view>
    <view class="workflow-list">
      <view wx:for="{{agent.workflow}}" wx:key="index" class="workflow-item">
        <text>{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 技术产出 Technical Deliverables -->
  <view class="section" wx:if="{{agent.technicalDeliverables.length > 0}}">
    <view class="section-title">📋 Technical Deliverables</view>
    <view class="deliverable-list">
      <view wx:for="{{agent.technicalDeliverables}}" wx:key="index" class="deliverable-item">
        <text>{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 背景经历 Background -->
  <view class="section" wx:if="{{agent.background.length > 0}}">
    <view class="section-title">👤 Background</view>
    <view class="background-list">
      <view wx:for="{{agent.background}}" wx:key="index" class="background-item">
        <text>{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 沟通风格 Communication Style -->
  <view class="section" wx:if="{{agent.communicationStyle.length > 0}}">
    <view class="section-title">💬 Communication Style</view>
    <view class="style-list">
      <view wx:for="{{agent.communicationStyle}}" wx:key="index" class="style-item">
        <text>{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 个性特征 Personality -->
  <view class="section" wx:if="{{agent.personality.length > 0}}">
    <view class="section-title">🎭 Personality</view>
    <view class="personality-list">
      <view wx:for="{{agent.personality}}" wx:key="index" class="personality-item">
        <text>{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 专业领域 Expertise -->
  <view class="section" wx:if="{{agent.expertise.length > 0}}">
    <view class="section-title">🎓 Expertise</view>
    <view class="expertise-list">
      <view wx:for="{{agent.expertise}}" wx:key="index" class="expertise-item">
        <text>{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 成功指标 Success Metrics -->
  <view class="section" wx:if="{{agent.successMetrics.length > 0}}">
    <view class="section-title">📊 Success Metrics</view>
    <view class="metrics-list">
      <view wx:for="{{agent.successMetrics}}" wx:key="index" class="metrics-item">
        <text>{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 高级能力 Advanced Capabilities -->
  <view class="section" wx:if="{{agent.advancedCapabilities.length > 0}}">
    <view class="section-title">🚀 Advanced Capabilities</view>
    <view class="advanced-list">
      <view wx:for="{{agent.advancedCapabilities}}" wx:key="index" class="advanced-item">
        <text>{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 研究产出 Research Deliverables -->
  <view class="section" wx:if="{{agent.researchDeliverables.length > 0}}">
    <view class="section-title">📚 Research Deliverables</view>
    <view class="research-list">
      <view wx:for="{{agent.researchDeliverables}}" wx:key="index" class="research-item">
        <text>{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 学习与记忆 Learning & Memory -->
  <view class="section" wx:if="{{agent.learningMemory.length > 0}}">
    <view class="section-title">🧠 Learning & Memory</view>
    <view class="learning-list">
      <view wx:for="{{agent.learningMemory}}" wx:key="index" class="learning-item">
        <text>{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 工具能力 Tools -->
  <view class="section" wx:if="{{agent.tools.length > 0}}">
    <view class="section-title">🛠️ Tools</view>
    <view class="tools-grid">
      <text wx:for="{{agent.tools}}" wx:key="index" class="tool-tag">{{item}}</text>
    </view>
  </view>

  <!-- 附加说明 Additional Notes -->
  <view class="section" wx:if="{{agent.additionalNotes.length > 0}}">
    <view class="section-title">📝 Additional Notes</view>
    <view class="notes-list">
      <view wx:for="{{agent.additionalNotes}}" wx:key="index" class="notes-item">
        <text>{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-bar">
    <button class="ai-generate-btn" bindtap="onGenerateContent">
      <text>✨ 了解更多</text>
    </button>
    <!-- <button class="share-btn" bindtap="onSharePoster">
      <text>📤 生成海报</text>
    </button> -->
  </view>

  <!-- 海报画布 -->
  <!-- <canvas canvas-id="posterCanvas" style="width:375px;height:550px;position:fixed;left:-9999px;top:-9999px;"></canvas> -->
</view>

<!-- 加载状态 -->
<view wx:if="{{!agent}}" class="loading-state">
  <text>加载中...</text>
</view>
