/* pages/ai/index.wxss - AI助手样式 */

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F7F8FC;
}

/* ===== 聊天区域 ===== */
.chat-area {
  flex: 1;
  padding: 24rpx;
  padding-bottom: 0;
}

/* ===== 欢迎区域 ===== */
.welcome-section {
  text-align: center;
  padding: 80rpx 40rpx;
}

.welcome-avatar {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.welcome-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.welcome-desc {
  font-size: 28rpx;
  color: #999;
  line-height: 1.6;
}

/* ===== 消息列表 ===== */
.message-list {
  padding-bottom: 24rpx;
}

.message-item {
  display: flex;
  margin-bottom: 32rpx;
  align-items: flex-start;
}

.message-item.user {
  flex-direction: row-reverse;
}

.message-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.ai-avatar {
  background: linear-gradient(135deg, #6C63FF, #A594F9);
}

.user-avatar {
  background: #43D9AD;
}

.message-content-wrap {
  max-width: 70%;
  margin: 0 16rpx;
}

.message-content {
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  line-height: 1.6;
  white-space: pre-wrap;
  word-break: break-word;
}

.message-content.user {
  background: linear-gradient(135deg, #6C63FF, #A594F9);
  color: #fff;
  border-bottom-right-radius: 8rpx;
}

.message-content.ai {
  background: #fff;
  color: #333;
  border-bottom-left-radius: 8rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.message-text {
  white-space: pre-wrap;
}

.message-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
  justify-content: flex-start;
}

.action-btn {
  font-size: 22rpx;
  color: #999;
  padding: 4rpx 0;
}

.message-time {
  font-size: 20rpx;
  color: #bbb;
  margin-top: 8rpx;
}

.message-item.user .message-time {
  text-align: right;
}

/* ===== 正在输入 ===== */
.typing-content {
  min-width: 100rpx;
}

.typing-dots {
  display: flex;
  gap: 8rpx;
  padding: 8rpx 0;
}

.typing-dots .dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #6C63FF;
  animation: typing 1.4s infinite;
}

.typing-dots .dot:nth-child(2) {
  animation-delay: 0.2s;
}

.typing-dots .dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes typing {
  0%, 60%, 100% {
    transform: translateY(0);
    opacity: 0.4;
  }
  30% {
    transform: translateY(-8rpx);
    opacity: 1;
  }
}

/* ===== 快捷问题 ===== */
.quick-questions {
  padding: 0 24rpx 16rpx;
}

.quick-title {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.quick-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.quick-item {
  background: #fff;
  padding: 16rpx 24rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #666;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* ===== 输入区域 ===== */
.input-area {
  background: #fff;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #eee;
}

.input-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.chat-input {
  flex: 1;
  background: #F7F8FC;
  border-radius: 40rpx;
  padding: 20rpx 28rpx;
  font-size: 28rpx;
}

.send-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #fff;
  padding: 0;
  margin: 0;
}

.send-btn.active {
  background: linear-gradient(135deg, #6C63FF, #A594F9);
}

.send-btn[disabled] {
  background: #ddd;
}

.toolbar {
  display: flex;
  justify-content: flex-end;
  margin-top: 12rpx;
}

.tool-btn {
  font-size: 24rpx;
  color: #999;
  padding: 8rpx 16rpx;
}
