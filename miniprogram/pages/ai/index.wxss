/* pages/ai/index.wxss - AI助手样式 */

.ai-page {
  display: flex; flex-direction: column;
  height: 100vh; background: #F0F1FF;
  overflow: hidden;
}

/* 顶部栏 */
.ai-topbar {
  background: #1A1A2E; padding: 16rpx 28rpx 16rpx;
  display: flex; align-items: center; justify-content: space-between;
  padding-top: calc(env(safe-area-inset-top) + 16rpx);
}
.ai-topbar-left { display: flex; align-items: center; gap: 16rpx; }
.ai-avatar-dot {
  width: 52rpx; height: 52rpx; border-radius: 26rpx;
  background: linear-gradient(135deg, #6C63FF, #9B59B6);
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx;
}
.ai-name { font-size: 28rpx; font-weight: 700; color: #fff; }
.ai-status { font-size: 20rpx; }
.ai-status.online { color: #43D9AD; }
.ai-status.typing { color: #FFB347; }

.ai-topbar-actions { display: flex; gap: 16rpx; }
.topbar-btn {
  width: 60rpx; height: 60rpx; border-radius: 30rpx;
  background: rgba(255,255,255,0.1);
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx;
}

/* 角色切换 */
.role-scroll { background: #1A1A2E; white-space: nowrap; }
.role-row { display: inline-flex; gap: 12rpx; padding: 12rpx 20rpx 16rpx; }
.role-chip {
  display: inline-flex; align-items: center; gap: 6rpx;
  padding: 10rpx 22rpx; border-radius: 100rpx;
  font-size: 22rpx; color: rgba(255,255,255,0.7);
  background: rgba(255,255,255,0.1); white-space: nowrap;
}

/* 聊天滚动区 */
.chat-scroll {
  flex: 1; overflow-y: auto;
  padding: 20rpx 0;
}

/* 快捷问题 */
.quick-questions { padding: 20rpx 28rpx; }
.qq-title { font-size: 24rpx; color: #888; margin-bottom: 16rpx; }
.qq-grid { display: flex; flex-direction: column; gap: 12rpx; }
.qq-item {
  background: #fff; padding: 20rpx 28rpx;
  border-radius: 16rpx; font-size: 26rpx; color: #444;
  box-shadow: 0 2rpx 10rpx rgba(108,99,255,0.06);
}

/* 消息包装 */
.msg-wrapper { padding: 12rpx 24rpx; }
.user-side { display: flex; flex-direction: column; align-items: flex-end; }
.ai-side { display: flex; flex-direction: column; align-items: flex-start; }

/* AI气泡 */
.ai-bubble-wrap { display: flex; align-items: flex-start; gap: 16rpx; max-width: 85%; }
.ai-bot-icon {
  width: 60rpx; height: 60rpx; border-radius: 30rpx;
  background: #6C63FF; display: flex; align-items: center;
  justify-content: center; font-size: 32rpx; flex-shrink: 0; margin-top: 4rpx;
}
.msg-right { flex: 1; display: flex; flex-direction: column; gap: 8rpx; }

/* 思维链 */
.think-wrap {
  background: rgba(108,99,255,0.06); border-radius: 16rpx;
  border: 1rpx solid rgba(108,99,255,0.15); overflow: hidden; margin-bottom: 4rpx;
}
.think-header {
  display: flex; align-items: center; gap: 10rpx;
  padding: 14rpx 18rpx;
}
.think-icon { font-size: 24rpx; }
.think-label { font-size: 22rpx; color: #6C63FF; flex: 1; }
.think-toggle { font-size: 20rpx; color: #888; }
.think-content {
  padding: 0 18rpx 14rpx;
  font-size: 22rpx; color: #888; line-height: 1.7;
  white-space: pre-wrap; border-top: 1rpx solid rgba(108,99,255,0.1);
  padding-top: 12rpx;
}

.ai-bubble {
  background: #fff; padding: 24rpx 28rpx;
  border-radius: 6rpx 24rpx 24rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(108,99,255,0.08);
  max-width: 100%;
}
.loading-bubble { min-width: 100rpx; min-height: 60rpx; display: flex; align-items: center; }

.msg-text { font-size: 28rpx; line-height: 1.8; display: block; }
.ai-text { color: #1A1A2E; white-space: pre-wrap; }

/* 消息操作栏 */
.msg-actions { display: flex; align-items: center; gap: 20rpx; padding-left: 4rpx; }
.msg-time { font-size: 20rpx; color: #AAA; }
.msg-copy { font-size: 22rpx; color: #6C63FF; }

/* 打字动效 */
.typing-indicator { display: flex; align-items: center; gap: 8rpx; padding: 4rpx 0; }
.dot {
  width: 12rpx; height: 12rpx; border-radius: 6rpx;
  background: #6C63FF; animation: bounce 1.2s infinite ease-in-out;
}
.d1 { animation-delay: 0s; }
.d2 { animation-delay: 0.2s; }
.d3 { animation-delay: 0.4s; }
@keyframes bounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}

/* 用户气泡 */
.user-bubble-wrap { display: flex; flex-direction: column; align-items: flex-end; max-width: 80%; }
.user-bubble {
  background: linear-gradient(135deg, #6C63FF, #9B59B6);
  padding: 22rpx 28rpx; border-radius: 24rpx 6rpx 24rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(108,99,255,0.25);
}
.user-text { color: #fff; white-space: pre-wrap; }
.user-time { font-size: 20rpx; color: #AAA; margin-top: 8rpx; padding-right: 8rpx; }

/* 输入区 */
.chat-input-area {
  background: #fff;
  padding: 16rpx 20rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 16rpx);
  border-top: 1rpx solid #EEEEEE;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05);
}
.chat-input-row {
  display: flex; align-items: flex-end; gap: 16rpx;
  background: #F5F5FA; border-radius: 24rpx; padding: 12rpx 16rpx 12rpx 24rpx;
}
.chat-input {
  flex: 1; font-size: 28rpx; color: #1A1A2E;
  max-height: 200rpx; line-height: 1.6; background: transparent;
}
.input-placeholder { color: #BBBBCC; font-size: 28rpx; }

.send-btn {
  width: 72rpx; height: 72rpx; border-radius: 36rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 36rpx; font-weight: 700; flex-shrink: 0; transition: all 0.2s;
}
.send-btn.active { background: #6C63FF; color: #fff; }
.send-btn.disabled { background: #DDD; color: #999; }

.char-hint { font-size: 20rpx; color: #FFB347; text-align: right; padding: 4rpx 8rpx 0; }

/* Mini 加载器 */
.mini-loader { display: flex; align-items: center; gap: 4rpx; }
.ml-dot {
  width: 8rpx; height: 8rpx; border-radius: 4rpx;
  background: #fff; animation: bounce 1.2s infinite ease-in-out;
}
.ml-dot:nth-child(2) { animation-delay: 0.2s; }
.ml-dot:nth-child(3) { animation-delay: 0.4s; }
