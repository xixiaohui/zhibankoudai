<!-- pages/ai/index.wxml - AI助手 -->
<view class="container">
  <!-- 聊天区域 -->
  <scroll-view
    class="chat-area"
    scroll-y
    scroll-top="{{scrollTop}}"
    scroll-with-animation
    enhanced>
    
    <!-- 欢迎语 -->
    <view wx:if="{{messages.length === 0}}" class="welcome-section">
      <view class="welcome-avatar">🤖</view>
      <view class="welcome-title">你好，我是智伴AI助手</view>
      <view class="welcome-desc">我可以帮助你解答问题、学习新知识、制定计划等</view>
    </view>

    <!-- 消息列表 -->
    <view class="message-list">
      <view 
        class="message-item {{msg.role === 'user' ? 'user' : 'ai'}}"
        wx:for="{{messages}}"
        wx:key="id">
        
        <!-- AI头像 -->
        <view wx:if="{{msg.role === 'assistant'}}" class="message-avatar ai-avatar">
          <text>🤖</text>
        </view>
        
        <!-- 消息内容 -->
        <view class="message-content-wrap">
          <view class="message-content {{msg.role === 'user' ? 'user' : 'ai'}}">
            <text class="message-text">{{msg.content}}</text>
          </view>
          
          <!-- 操作按钮 -->
          <view class="message-actions" wx:if="{{msg.role === 'assistant'}}">
            <view class="action-btn" bindtap="copyMessage" data-content="{{msg.content}}">📋 复制</view>
          </view>
          
          <!-- 时间 -->
          <view class="message-time">{{msg.time}}</view>
        </view>
        
        <!-- 用户头像 -->
        <view wx:if="{{msg.role === 'user'}}" class="message-avatar user-avatar">
          <text>{{userInfo && userInfo.name ? userInfo.name[0] : '👤'}}</text>
        </view>
      </view>

      <!-- 正在输入指示器 -->
      <view wx:if="{{isTyping}}" class="message-item ai">
        <view class="message-avatar ai-avatar">
          <text>🤖</text>
        </view>
        <view class="message-content ai typing-content">
          <view class="typing-dots">
            <text class="dot"></text>
            <text class="dot"></text>
            <text class="dot"></text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 快捷问题 -->
  <view wx:if="{{showQuickQuestions && !isTyping}}" class="quick-questions">
    <view class="quick-title">试试这样问我</view>
    <view class="quick-list">
      <view 
        class="quick-item"
        wx:for="{{quickQuestions}}"
        wx:key="index"
        bindtap="onQuickQuestion"
        data-question="{{item}}">
        {{item}}
      </view>
    </view>
  </view>

  <!-- 输入区域 -->
  <view class="input-area">
    <view class="input-wrap">
      <input
        class="chat-input"
        type="text"
        placeholder="输入您的问题..."
        value="{{inputValue}}"
        bindinput="onInput"
        bindconfirm="sendMessage"
        confirm-type="send"
        focus="{{inputFocus}}"/>
      <button 
        class="send-btn {{inputValue.trim() ? 'active' : ''}}"
        bindtap="sendMessage"
        disabled="{{!inputValue.trim()}}">
        <text>➤</text>
      </button>
    </view>
    
    <!-- 底部工具栏 -->
    <view class="toolbar">
      <view class="tool-btn" bindtap="clearChat">🗑️ 清除</view>
    </view>
  </view>

  <view style="height: env(safe-area-inset-bottom)"></view>
</view>
