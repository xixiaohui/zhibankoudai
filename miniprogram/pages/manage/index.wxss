/* pages/manage/index.wxss - 助手管理页面 */
.page-container {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 30rpx;
}

/* 页面标题 */
.page-header {
  padding: 20rpx 0 40rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.header-desc {
  font-size: 26rpx;
  color: #999;
}

/* 模块列表 */
.module-list {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
}

.module-item {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.module-item:last-child {
  border-bottom: none;
}

.module-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 24rpx;
}

.module-info {
  flex: 1;
}

.module-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.module-desc {
  font-size: 24rpx;
  color: #999;
}

/* 底部说明 */
.footer-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 40rpx 0;
}

.tip-icon {
  font-size: 28rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #999;
}
