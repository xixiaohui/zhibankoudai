/* pages/expert/index.wxss - 个人专家资料库样式 */

.container {
  min-height: 100vh;
  background: #F7F8FC;
  padding-bottom: 120rpx;
}

.tab-content {
  padding: 24rpx;
}

/* ===== Tab导航 ===== */
.tab-nav {
  display: flex;
  background: #fff;
  padding: 20rpx 16rpx;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 0;
  color: #999;
  font-size: 24rpx;
  transition: all 0.3s;
}

.tab-item.active {
  color: #6C63FF;
}

.tab-item.active .tab-icon {
  transform: scale(1.2);
}

.tab-icon {
  font-size: 40rpx;
  margin-bottom: 6rpx;
  transition: transform 0.3s;
}

.tab-label {
  font-size: 24rpx;
}

/* ===== 名片预览 ===== */
.card-preview {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.profile-card {
  background: linear-gradient(135deg, #6C63FF 0%, #A594F9 100%);
  padding: 40rpx 32rpx;
  color: #fff;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.avatar-wrap {
  position: relative;
  margin-right: 24rpx;
}

.avatar-img,
.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  background: rgba(255, 255, 255, 0.2);
}

.avatar-edit-hint {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  white-space: nowrap;
}

.profile-info {
  flex: 1;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
  display: flex;
  align-items: center;
}

.level-badge {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-left: 16rpx;
  background: rgba(255, 255, 255, 0.2);
}

.level-junior { background: #4CAF50; }
.level-mid { background: #2196F3; }
.level-senior { background: #FF9800; }
.level-expert { background: #E91E63; }

.profile-title {
  font-size: 28rpx;
  opacity: 0.9;
}

.profile-bio {
  font-size: 26rpx;
  line-height: 1.6;
  opacity: 0.95;
  margin-bottom: 24rpx;
}

.skill-tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 24rpx;
}

.skill-tag {
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin: 0 8rpx 8rpx 0;
}

.contact-row {
  display: flex;
  flex-wrap: wrap;
}

.contact-item {
  font-size: 22rpx;
  margin-right: 20rpx;
  margin-bottom: 8rpx;
  opacity: 0.9;
}

/* ===== 个人资料表单 ===== */
.profile-form {
  padding: 32rpx;
}

.form-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #eee;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.form-input {
  background: #F7F8FC;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
}

.form-textarea {
  background: #F7F8FC;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
  min-height: 160rpx;
}

.level-selector {
  display: flex;
  gap: 16rpx;
}

.level-option {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  background: #F7F8FC;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #666;
}

.level-option.selected {
  background: #6C63FF;
  color: #fff;
}

.save-btn {
  background: #6C63FF;
  color: #fff;
  border-radius: 12rpx;
  margin-top: 32rpx;
  font-size: 28rpx;
}

.action-btns {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.action-btn {
  flex: 1;
  font-size: 26rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  margin: 0;
}

.preview-btn {
  background: #F7F8FC;
  color: #666;
}

.share-btn {
  background: #43D9AD;
  color: #fff;
}

.preview-actions {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx 32rpx;
}

.edit-btn {
  flex: 1;
  background: #6C63FF;
  color: #fff;
}

/* ===== 统计数据 ===== */
.stats-row {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #6C63FF;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.stat-divider {
  width: 1rpx;
  background: #eee;
}

/* ===== 章节头部 ===== */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.add-btn {
  background: #6C63FF;
  color: #fff;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
}

/* ===== 技能分类统计 ===== */
.category-stats {
  display: flex;
  flex-wrap: wrap;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.cat-stat {
  width: 33.33%;
  text-align: center;
  padding: 16rpx 0;
  box-sizing: border-box;
}

.cat-icon {
  font-size: 36rpx;
  display: block;
  margin-bottom: 8rpx;
}

.cat-name {
  font-size: 22rpx;
  color: #666;
  display: block;
}

.cat-count {
  font-size: 28rpx;
  font-weight: 600;
  color: #6C63FF;
  display: block;
}

/* ===== 技能列表 ===== */
.skills-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.skill-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.skill-card:last-child {
  border-bottom: none;
}

.skill-info {
  flex: 1;
  display: flex;
  align-items: center;
}

.skill-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.skill-detail {
  flex: 1;
}

.skill-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.skill-desc {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.skill-level {
  position: relative;
  font-size: 24rpx;
  color: #ddd;
  overflow: hidden;
}

.stars-text {
  letter-spacing: 4rpx;
  color: #FFD700;
}

.stars-active {
  position: absolute;
  left: 0;
  top: 0;
  color: #FFD700;
  overflow: hidden;
  white-space: nowrap;
  letter-spacing: 4rpx;
}

.skill-level-tag {
  background: #F7F8FC;
  color: #6C63FF;
  font-size: 20rpx;
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
  margin-left: 16rpx;
}

.delete-btn {
  padding: 12rpx;
  color: #999;
  font-size: 28rpx;
  margin-left: 16rpx;
}

/* ===== 项目列表 ===== */
.projects-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.project-card {
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.project-card:last-child {
  border-bottom: none;
}

.project-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.project-title-row {
  display: flex;
  align-items: center;
}

.project-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.project-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.project-status {
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  border-radius: 12rpx;
}

.status-planning { background: #E0E0E0; color: #666; }
.status-progress { background: #E8F0FE; color: #6C63FF; }
.status-completed { background: #E8F5E9; color: #43D9AD; }
.status-paused { background: #FFF3E0; color: #FFB347; }

.project-role {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.project-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.project-tech {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.tech-label {
  color: #666;
}

.tech-list {
  color: #6C63FF;
}

.project-highlights {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.highlights-label {
  color: #999;
}

.highlights-content {
  color: #43D9AD;
}

.project-dates {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.project-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.project-link {
  font-size: 24rpx;
  color: #6C63FF;
}

/* ===== 知识卡片 ===== */
.knowledge-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.knowledge-card {
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.knowledge-card:last-child {
  border-bottom: none;
}

.knowledge-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.knowledge-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.knowledge-title {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.knowledge-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.knowledge-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.knowledge-tags {
  font-size: 22rpx;
  color: #6C63FF;
}

.knowledge-date {
  font-size: 22rpx;
  color: #999;
}

/* ===== 空状态 ===== */
.empty-state {
  background: #fff;
  border-radius: 16rpx;
  padding: 80rpx 40rpx;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #999;
}

/* ===== 弹窗样式 ===== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.modal-content {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  width: 100%;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
}

.modal-large {
  max-height: 90vh;
}

.modal-scroll {
  max-height: calc(90vh - 120rpx);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #eee;
  font-size: 32rpx;
  font-weight: 600;
}

.modal-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.modal-body {
  padding: 32rpx;
  flex: 1;
  overflow-y: auto;
}

.modal-footer {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #eee;
}

.modal-btn {
  flex: 1;
  font-size: 28rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  margin: 0;
}

.modal-btn.cancel {
  background: #F7F8FC;
  color: #666;
}

.modal-btn.confirm {
  background: #6C63FF;
  color: #fff;
}

/* ===== 分类选择网格 ===== */
.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.cat-option {
  width: calc(33.33% - 12rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
  background: #F7F8FC;
  border-radius: 12rpx;
  font-size: 22rpx;
  color: #666;
  box-sizing: border-box;
}

.cat-option.selected {
  background: #6C63FF;
  color: #fff;
}

.cat-option text:first-child {
  font-size: 32rpx;
  margin-bottom: 8rpx;
}

/* ===== 级别选择 ===== */
.level-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.level-option {
  padding: 16rpx 24rpx;
  background: #F7F8FC;
  border-radius: 12rpx;
  font-size: 26rpx;
}

.level-option.selected {
  background: #6C63FF;
  color: #fff;
}

/* ===== 状态选择 ===== */
.status-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.status-option {
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  background: #F7F8FC;
  color: #666;
}

.status-option.selected {
  background: #6C63FF;
  color: #fff;
}

/* ===== 表单行 ===== */
.form-row {
  display: flex;
  gap: 24rpx;
}

.form-item.half {
  flex: 1;
}

.picker-value {
  background: #F7F8FC;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
}
