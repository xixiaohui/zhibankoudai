/* pages/poster/index.wxss - 分享海报页面样式 */

/* ========= 页面容器 ========= */
.poster-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 24rpx 60rpx;
  box-sizing: border-box;
}

/* ========= 加载状态 ========= */
.loading-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  color: rgba(255, 255, 255, 0.9);
  font-size: 28rpx;
}

/* ========= 海报容器 ========= */
.poster-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 20rpx 0;
}

/* ========= 海报预览图片 ========= */
.poster-preview-image {
  width: 680rpx;
  min-height: 300rpx;
  max-height: 1000rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.2);
  margin-bottom: 20rpx;
  background-color: #f5f5f5;
}

/* ========= 操作按钮区域 ========= */
.action-bar {
  width: 100%;
  display: flex;
  flex-direction: row;
  gap: 24rpx;
  margin-bottom: 30rpx;
  padding: 0 10rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 20rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 50rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
  border: none;
  font-size: inherit;
  line-height: inherit;
  transition: all 0.2s ease;
}

.action-btn::after {
  border: none;
}

/* 按钮图标和文字 */
.btn-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.btn-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

/* 按钮状态 */
.action-btn.hover {
  opacity: 0.85;
  transform: scale(0.98);
}

.action-btn.disabled {
  opacity: 0.6;
  background: rgba(200, 200, 200, 0.9);
}

/* 按钮变体 */
.btn-refresh .btn-icon {
  color: #2196F3;
}

.btn-save .btn-icon {
  color: #4CAF50;
}

.btn-preview .btn-icon {
  color: #FF9800;
}

/* ========= 分享提示 ========= */
.share-tip {
  padding: 16rpx 30rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 30rpx;
}

.share-tip text {
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
}

/* ========= 兼容旧样式 ========= */
.poster-preview {
  width: 680rpx;
  height: 960rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
  position: relative;
  overflow: hidden;
}

.poster-image-wrapper {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
}

.poster-image {
  width: 100%;
  height: 100%;
}

.tip-bar {
  padding: 20rpx 30rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
}

.tip-text {
  color: rgba(255, 255, 255, 0.9);
  font-size: 24rpx;
}

.primary-btn {
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
}

.primary-btn .action-text {
  color: #fff;
}

.secondary-btn {
  background: rgba(255, 255, 255, 0.95);
}

.secondary-btn .action-icon { color: #2196F3; }
.save-btn .action-icon { color: #4CAF50; }
.share-btn .action-icon { color: #FF9800; }
