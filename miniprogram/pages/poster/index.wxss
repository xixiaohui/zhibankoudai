/* pages/poster/index.wxss - 分享海报页面样式 */

/* ==================== 页面容器 ==================== */
.poster-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 30rpx;
}

/* ==================== 海报预览区域 ==================== */
.poster-preview {
  width: 100%;
  display: flex;
  justify-content: center;
  margin-bottom: 60rpx;
}

.poster-container {
  width: 560rpx;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 
    0 20rpx 60rpx rgba(0,0,0,0.3),
    0 8rpx 20rpx rgba(0,0,0,0.2);
}

/* ==================== 海报背景 ==================== */
.poster-bg {
  width: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
  padding: 0;
  position: relative;
  overflow: hidden;
}

/* 背景装饰圆 */
.poster-bg::before {
  content: '';
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.1);
}

.poster-bg::after {
  content: '';
  position: absolute;
  bottom: -80rpx;
  left: -80rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
}

/* ==================== 顶部区域 ==================== */
.poster-top {
  padding: 48rpx 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  z-index: 1;
}

.poster-logo {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.95);
  padding: 12rpx 28rpx 12rpx 16rpx;
  border-radius: 50rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.15);
}

.logo-icon {
  font-size: 36rpx;
  margin-right: 10rpx;
}

.logo-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #667eea;
}

.poster-slogan {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: rgba(255,255,255,0.9);
  letter-spacing: 4rpx;
}

/* ==================== 主标题区域 ==================== */
.poster-main {
  padding: 0 40rpx 32rpx;
  text-align: center;
  position: relative;
  z-index: 1;
}

.poster-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.4;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
  margin-bottom: 12rpx;
}

.poster-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
}

/* ==================== 模式展示 ==================== */
.poster-mode {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
  position: relative;
  z-index: 1;
}

.mode-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.mode-name {
  font-size: 28rpx;
  color: #FFFFFF;
  background: rgba(255,255,255,0.2);
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
}

/* ==================== 引用区域 ==================== */
.poster-quote {
  margin: 24rpx 40rpx;
  padding: 28rpx 32rpx;
  background: rgba(255,255,255,0.15);
  border-radius: 20rpx;
  border-left: 6rpx solid rgba(255,255,255,0.6);
  position: relative;
  z-index: 1;
}

.quote-text {
  font-size: 28rpx;
  color: #FFFFFF;
  line-height: 1.6;
  font-style: italic;
}

/* ==================== 小程序码区域 ==================== */
.poster-qrcode {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 40rpx 40rpx;
  position: relative;
  z-index: 1;
}

.qrcode-placeholder {
  width: 200rpx;
  height: 200rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.15);
}

.qrcode-hint {
  font-size: 24rpx;
  color: #999;
}

.qrcode-tip {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
}

/* ==================== 底部区域 ==================== */
.poster-footer {
  padding: 0 40rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  z-index: 1;
}

.footer-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  letter-spacing: 2rpx;
}

.footer-line {
  width: 60rpx;
  height: 4rpx;
  background: rgba(255,255,255,0.5);
  border-radius: 2rpx;
  margin-top: 12rpx;
}

/* ==================== 操作按钮 ==================== */
.action-bar {
  width: 100%;
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.action-btn {
  flex: 1;
  height: 96rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.action-btn:active {
  transform: scale(0.96);
}

.save-btn {
  background: linear-gradient(135deg, #FFFFFF 0%, #F5F5F5 100%);
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.15);
}

.share-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  box-shadow: 0 8rpx 24rpx rgba(102,126,234,0.4);
}

.action-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.action-text {
  font-size: 28rpx;
  font-weight: 500;
}

.save-btn .action-text {
  color: #667eea;
}

.share-btn .action-text {
  color: #FFFFFF;
}

/* ==================== 提示信息 ==================== */
.tip-bar {
  padding: 16rpx 24rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 24rpx;
}

.tip-text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
}
