/* pages/poster/index.wxss - Pinterest Design System */

.poster-page {
  min-height: 100vh;
  background-color: var(--surface-secondary);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-lg) var(--space-md) var(--space-xxl);
  box-sizing: border-box;
}

.loading-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--border);
  border-top-color: var(--text-secondary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: var(--space-sm);
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  color: var(--text-secondary);
  font-size: var(--font-size-base);
}

.poster-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: var(--space-sm) 0;
}

.poster-preview-image {
  width: 680rpx;
  min-height: 300rpx;
  max-height: 1000rpx;
  border-radius: var(--radius-lg);
  margin-bottom: var(--space-sm);
  background-color: var(--surface);
  border: 1rpx solid var(--border);
}

.action-bar {
  width: 100%;
  display: flex;
  flex-direction: row;
  gap: var(--space-md);
  margin-bottom: var(--space-lg);
  padding: 0 var(--space-xs);
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-lg) var(--space-sm);
  background: var(--surface);
  border-radius: var(--radius-full);
  border: 1rpx solid var(--border);
  font-size: inherit;
  line-height: inherit;
  transition: all 0.2s ease;
}

.action-btn::after {
  border: none;
}

.btn-icon {
  font-size: 36rpx;
  margin-right: var(--space-xs);
}

.btn-text {
  font-size: var(--font-size-base);
  color: var(--text-primary);
  font-weight: 500;
}

.action-btn.hover {
  opacity: 0.85;
  transform: scale(0.98);
}

.action-btn.disabled {
  opacity: 0.6;
  background: var(--surface-secondary);
}

.btn-refresh .btn-icon {
  color: var(--focus-ring);
}

.btn-save .btn-icon {
  color: var(--success);
}

.btn-preview .btn-icon {
  color: var(--warning);
}

.share-tip {
  padding: var(--space-xs) var(--space-lg);
  background: var(--accent-warm-light);
  border-radius: var(--radius-full);
}

.share-tip text {
  color: var(--text-secondary);
  font-size: var(--font-size-sm);
}

.poster-preview {
  width: 680rpx;
  height: 960rpx;
  background: var(--surface);
  border-radius: var(--radius-lg);
  position: relative;
  overflow: hidden;
  border: 1rpx solid var(--border);
}

.poster-image-wrapper {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--surface-secondary);
}

.poster-image {
  width: 100%;
  height: 100%;
}

.tip-bar {
  padding: var(--space-sm) var(--space-lg);
  background: var(--accent-warm-light);
  border-radius: var(--radius-full);
}

.tip-text {
  color: var(--text-secondary);
  font-size: var(--font-size-sm);
}

.primary-btn {
  background: var(--primary);
}

.primary-btn .btn-text {
  color: var(--surface);
}

.secondary-btn {
  background: var(--surface);
}
