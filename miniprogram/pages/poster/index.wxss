/* pages/poster/index.wxss - 分享海报页面样式 */

.poster-page {
  min-height: 100vh;
  background: #F5F5F5;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx;
}

/* 海报预览区域 */
.poster-preview {
  width: 100%;
  max-width: 500rpx;
  margin-bottom: 40rpx;
}

.poster-container {
  width: 100%;
  aspect-ratio: 3 / 4;
  border-radius: 32rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
  position: relative;
  overflow: hidden;
}

/* 顶部区域 */
.poster-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.poster-logo {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.9);
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.logo-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.logo-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
}

.poster-date {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.poster-slogan {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 类型标签 */
.poster-type-tag {
  display: inline-flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.95);
  padding: 14rpx 28rpx;
  border-radius: 30rpx;
  margin-bottom: 30rpx;
  align-self: flex-start;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.type-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.type-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
}

.joke-tag {
  background: rgba(255, 255, 255, 0.95);
}

.knowledge-tag {
  background: rgba(255, 255, 255, 0.95);
}

/* 主内容区域 - 名言 */
.poster-main-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 20rpx 10rpx;
  position: relative;
}

.content-quote-bg {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 200rpx;
  height: 200rpx;
  background: rgba(124, 106, 255, 0.08);
  border-radius: 50%;
}

.content-quote-text {
  font-size: 38rpx;
  color: #333;
  line-height: 1.6;
  text-align: center;
  font-style: italic;
  position: relative;
  z-index: 1;
  padding: 0 20rpx;
}

/* 作者信息 */
.poster-author {
  text-align: right;
  margin: 30rpx 0;
  padding-right: 20rpx;
}

.author-text {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

/* 段子标题 */
.joke-title-box {
  background: rgba(255, 255, 255, 0.95);
  padding: 20rpx 30rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  align-self: flex-start;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.joke-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #FF9A76;
}

/* 段子内容 */
.joke-content-box {
  flex: 1;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  padding: 30rpx;
  justify-content: flex-start;
  align-items: flex-start;
  overflow: hidden;
}

.joke-content {
  font-size: 28rpx;
  color: #444;
  line-height: 1.8;
  white-space: pre-wrap;
}

/* 知识标题 */
.knowledge-title-box {
  background: rgba(255, 255, 255, 0.95);
  padding: 20rpx 30rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  align-self: flex-start;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  border-left: 6rpx solid;
}

.knowledge-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1976D2;
}

/* 知识内容 */
.knowledge-content-box {
  flex: 1;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  padding: 24rpx;
  justify-content: flex-start;
  align-items: flex-start;
  overflow: hidden;
}

.knowledge-content {
  font-size: 26rpx;
  color: #444;
  line-height: 1.9;
  white-space: pre-wrap;
}

/* ========== 情话海报样式 ========== */

/* 情话 Logo */
.love-logo {
  background: rgba(255, 107, 157, 0.95);
}

.love-logo .logo-text {
  color: #FFFFFF;
}

.love-date {
  color: rgba(255, 255, 255, 0.95);
}

/* 情话类型标签 */
.love-tag {
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8FB3 100%);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 157, 0.3);
}

.love-tag .type-icon,
.love-tag .type-name {
  color: #FFFFFF;
}

/* 情话内容区域 */
.love-content-box {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 30rpx 20rpx;
  position: relative;
}

/* 爱心装饰 */
.love-heart-decoration {
  font-size: 48rpx;
  margin-bottom: 20rpx;
  animation: heartbeat 1.5s ease-in-out infinite;
}

@keyframes heartbeat {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

/* 情话文字 */
.love-content {
  font-size: 36rpx;
  color: #FFFFFF;
  line-height: 1.7;
  text-align: center;
  font-style: italic;
  text-shadow: 0 2rpx 8rpx rgba(255, 107, 157, 0.3);
  padding: 0 10rpx;
}

/* 情话作者 */
.love-author {
  display: flex;
  align-items: center;
  margin-top: 24rpx;
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 30rpx;
}

.author-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-right: 8rpx;
}

.author-name {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 600;
}

/* 情话出处 */
.love-source {
  margin-top: 16rpx;
}

.source-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  font-style: normal;
}

/* 情话底部 */
.love-slogan {
  color: rgba(255, 255, 255, 0.95);
}

.love-divider {
  background: rgba(255, 255, 255, 0.6);
}

/* 情话二维码 */
.love-qrcode-box {
  background: rgba(255, 107, 157, 0.15);
}

/* 主标题区域 - 默认海报 */
.poster-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
}

.poster-title {
  font-size: 42rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
  line-height: 1.3;
}

.poster-subtitle {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 30rpx;
}

/* 模式展示 */
.poster-mode {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.9);
  padding: 16rpx 32rpx;
  border-radius: 30rpx;
  margin-bottom: 30rpx;
}

.mode-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.mode-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
}

/* 引用区域 */
.poster-quote {
  background: rgba(255, 255, 255, 0.85);
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
  width: 100%;
}

.quote-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
  font-style: italic;
  text-align: center;
}

/* 二维码区域 */
.poster-qrcode {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: auto;
  padding-top: 20rpx;
}

.qrcode-box {
  width: 160rpx;
  height: 160rpx;
  background: white;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 12rpx;
}

.qrcode-placeholder {
  width: 140rpx;
  height: 140rpx;
  background: #F8F8F8;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qrcode-hint {
  font-size: 22rpx;
  color: #999;
}

.qrcode-tip {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.2);
}

/* 底部信息 */
.poster-footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: auto;
  padding-top: 24rpx;
}

.footer-slogan {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.95);
  font-weight: 500;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
  margin-bottom: 16rpx;
}

.footer-divider {
  width: 60rpx;
  height: 4rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 2rpx;
}

.footer-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 16rpx;
}

.footer-line {
  width: 80rpx;
  height: 4rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 2rpx;
}

/* 操作按钮 */
.action-bar {
  display: flex;
  gap: 30rpx;
  margin-bottom: 30rpx;
  width: 100%;
  max-width: 500rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.2s ease;
}

.action-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.save-btn {
  background: #FFFFFF;
  color: #333;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.share-btn {
  background: linear-gradient(135deg, #7C6AFF 0%, #9B8AFF 100%);
  color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(124, 106, 255, 0.3);
}

.action-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.action-text {
  font-size: 28rpx;
}

/* 提示信息 */
.tip-bar {
  padding: 20rpx;
  background: rgba(124, 106, 255, 0.1);
  border-radius: 12rpx;
  width: 100%;
  max-width: 500rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #7C6AFF;
  text-align: center;
  display: block;
}
