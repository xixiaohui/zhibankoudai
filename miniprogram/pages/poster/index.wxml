<view class="poster-page">
  <view wx:if="{{isLoading}}" class="loading-container">
    <view class="loading-spinner"></view>
    <text class="loading-text">正在生成海报...</text>
  </view>

  <!-- 组件直接显示，不在 wx:else 里 -->
  <view class="poster-container">
    <!-- 海报预览图片 -->
    <image 
      wx:if="{{posterConfig.posterTempFilePath}}"
      class="poster-preview-image"
      src="{{posterConfig.posterTempFilePath}}"
      mode="widthFix"
      bindtap="handlePreview"
      binderror="onImageError"
    />
    
    <!-- 海报 Canvas 组件 -->
    <!-- template="minimal" "editorial" -->
    <!-- themePreset="sand" "ink" "forest" "night" -->
    <!-- accentColor="#4F6B52" -->
    <posterCanvas
      id="posterCanvas" 
      template="editorial"
      themePreset="ink"
      title="{{posterConfig.title}}" 
      content="{{posterConfig.content}}" 
      subtitle="{{posterConfig.subtitle}}" 
      icon="{{posterConfig.icon}}" 
      moduleName="{{posterConfig.moduleName}}"
      userName="{{posterConfig.userName}}"
      userId="{{posterConfig.userId}}"
      timestamp="{{posterConfig.timestamp}}"
      author="{{posterConfig.author}}" 
      qrCodeUrl="{{posterConfig.qrCodeUrl}}" 
      footerText="{{posterConfig.footerText}}" 
      subFooterText="{{posterConfig.subFooterText}}" 
      backgroundColor="{{posterConfig.backgroundColor}}" 
      titleColor="{{posterConfig.titleColor}}" 
      contentColor="{{posterConfig.contentColor}}" 
      subtitleColor="{{posterConfig.subtitleColor}}" 
      contentFontSize="{{posterConfig.contentFontSize}}" 
      contentMaxLines="{{posterConfig.contentMaxLines}}" 
      qrCodeSize="{{posterConfig.qrCodeSize}}" 
      radius="{{posterConfig.radius}}" 
      enableShadow="{{posterConfig.enableShadow}}" 
      shadowColor="{{posterConfig.shadowColor}}" 
      shadowBlur="{{posterConfig.shadowBlur}}" 
      shadowOffsetX="{{posterConfig.shadowOffsetX}}" 
      shadowOffsetY="{{posterConfig.shadowOffsetY}}" 
      autoGenerate="{{posterConfig.autoGenerate}}"
      
      bind:ready="onPosterReady" 
      bind:error="onPosterError" 
    />
  </view>

  <view class="action-bar">
    <button 
      class="action-btn btn-refresh {{isGenerating ? 'disabled' : ''}}" 
      bindtap="handleGenerate" 
      hover-class="hover"
      disabled="{{isGenerating}}"
    >
      <text class="btn-icon">🔄</text>
      <text class="btn-text">{{isGenerating ? '生成中...' : '重新生成'}}</text>
    </button>
    
    <button 
      class="action-btn btn-save" 
      bindtap="handleSave" 
      hover-class="hover"
    >
      <text class="btn-icon">💾</text>
      <text class="btn-text">保存相册</text>
    </button>
  </view>

  <view class="share-tip">
    <text>点击右上角 ··· 分享给好友或发朋友圈</text>
  </view>
</view>
