<!-- pages/index/index.wxml - 智伴口袋首页 -->
<view class="page-container">
  <!-- 顶部问候区域 -->
  <view class="greeting-section">
    <view class="greeting-text">{{greeting}}</view>
    <view class="time-text">{{timeOfDay}}好</view>
  </view>

  <!-- 主要动作区域 -->
  <view class="main-actions-section">
    <view class="section-title">今天想做什么？</view>
    <view class="actions-grid">
      <block wx:for="{{mainActions}}" wx:key="id">
        <view class="action-item" data-id="{{item.id}}" bindtap="onMainAction">
          <view class="action-icon" style="background-color: {{item.color}}">{{item.icon}}</view>
          <view class="action-name">{{item.name}}</view>
          <view class="action-desc">{{item.desc}}</view>
        </view>
      </block>
    </view>
  </view>

  <!-- 每日陪伴卡片 -->
  <view wx:if="{{dailyCard}}" class="daily-card-section">
    <view class="section-title-row">
      <view class="section-title">
        今日陪伴卡片
        <text class="consecutive-days">已连续陪伴 {{consecutiveDays}} 天</text>
      </view>
      <view class="share-card-btn" bindtap="onShareCard">
        <text class="share-btn-icon">↗</text>
        <text class="share-btn-text">分享</text>
      </view>
    </view>
    <view class="card-container" bindtap="onViewCard">
      <view class="card-header">
        <text class="card-date">{{dailyCard.date}}</text>
        <text class="card-mood">{{dailyCard.topMood}} {{getMoodEmoji(dailyCard.topMood)}}</text>
      </view>
      <view class="card-content">
        <view class="encouragement">{{dailyCard.encouragement}}</view>
        <view class="review">{{dailyCard.weekReview}}</view>
        <view class="suggestion">📌 {{dailyCard.suggestion}}</view>
        <view wx:if="{{dailyCard.pendingText}}" class="pending">{{dailyCard.pendingText}}</view>
      </view>
    </view>
  </view>

  <!-- 今日名言 -->
  <daily-card moduleType="quote" />

  <!-- 今日段子 -->
  <daily-card moduleType="joke" />

  <!-- 每日心理学 -->
  <daily-card moduleType="psychology" />

  <!-- 每日金融 -->
  <daily-card moduleType="finance" />

  <!-- 每日情话 -->
  <daily-card moduleType="love" />

  <!-- 每日电影 -->
  <daily-card moduleType="movie" />

  <!-- 每日音乐 -->
  <daily-card moduleType="music" />

  <!-- 每日科技 -->
  <daily-card moduleType="tech" />

  <!-- 每日中医 -->
  <daily-card moduleType="tcm" />

  <!-- 每日旅游 -->
  <daily-card moduleType="travel" />

  <!-- 每日一卦 -->
  <daily-card moduleType="fortune" />

  <!-- 每日文学 -->
  <daily-card moduleType="literature" />

  <!-- 外贸助手 -->
  <daily-card moduleType="foreignTrade" />

  <!-- 电商运营助手 -->
  <daily-card moduleType="ecommerce" />

  <!-- 中学数学助手 -->
  <daily-card moduleType="math" />

  <!-- 中学英语助手 -->
  <daily-card moduleType="english" />

  <!-- 快速陪伴入口 -->
  <view class="quick-modes-section">
    <view class="section-title">快速陪伴模式</view>
    <view class="modes-grid">
      <block wx:for="{{quickModes}}" wx:key="id">
        <view class="mode-item" data-mode="{{item}}" bindtap="onQuickMode">
          <view class="mode-icon" style="background-color: {{item.color}}">{{item.icon}}</view>
          <view class="mode-name">{{item.name}}</view>
        </view>
      </block>
    </view>
  </view>

  <!-- 近期状态 -->
  <view wx:if="{{pendingGoals.length > 0 || recentMood}}" class="recent-section">
    <view class="section-title">近期状态</view>
    
    <!-- 最近心情 -->
    <view wx:if="{{recentMood}}" class="recent-mood" bindtap="onViewMemory">
      <view class="mood-header">
        <text class="mood-label">最近心情</text>
        <text class="mood-time">{{formatRelativeTime(recentMood.date + ' ' + recentMood.time)}}</text>
      </view>
      <view class="mood-content">
        <text class="mood-emoji">{{getMoodEmoji(recentMood.mood)}}</text>
        <text class="mood-text">{{recentMood.mood}}</text>
        <text wx:if="{{recentMood.note}}" class="mood-note">· {{recentMood.note}}</text>
      </view>
    </view>

    <!-- 待完成目标 -->
    <view wx:if="{{pendingGoals.length > 0}}" class="pending-goals">
      <view class="goals-header">
        <text class="goals-label">待完成目标</text>
        <text class="goals-count">{{pendingGoals.length}}个</text>
      </view>
      <block wx:for="{{pendingGoals}}" wx:key="id">
        <view class="goal-item" data-id="{{item.id}}" bindtap="onCompleteGoal">
          <view class="goal-checkbox">
            <text class="checkbox-icon">□</text>
          </view>
          <view class="goal-content">{{item.content}}</view>
          <view wx:if="{{item.deadline}}" class="goal-deadline">{{item.deadline}}</view>
        </view>
      </block>
      <view class="add-goal-btn" bindtap="onAddGoal">
        <text class="plus-icon">+</text>
        <text>添加新目标</text>
      </view>
    </view>
  </view>

  <!-- 昵称设置弹窗 -->
  <view wx:if="{{showNicknameModal}}" class="modal-mask" catchtap="closeNicknameModal">
    <view class="nickname-modal" catchtap="noop">
      <view class="modal-header">欢迎来到智伴口袋 👋</view>
      <view class="modal-content">
        <view class="modal-text">我是你的随身AI陪伴助手，怎么称呼你呢？</view>
        <input 
          class="nickname-input" 
          placeholder="请输入昵称（2-10字）" 
          maxlength="10"
          value="{{nicknameInput}}"
          bindinput="onNicknameInput"
          placeholder-style="color: #CCCCCC"
        />
        <view class="modal-tip">我会记住你的称呼，提供更贴心的陪伴</view>
      </view>
      <view class="modal-actions">
        <button class="btn-save" bindtap="saveNickname">开始陪伴</button>
      </view>
    </view>
  </view>
</view>
