<!-- pages/index/index.wxml - 首页 -->
<view class="container">

  <!-- 渐变头部 -->
  <view class="hero-header">
    <view class="hero-bg-circle c1"></view>
    <view class="hero-bg-circle c2"></view>
    <view class="hero-bg-circle c3"></view>
    <view class="status-bar-placeholder"></view>
    <view class="hero-content">
      <view class="flex-between">
        <view>
          <view class="hero-greeting">{{greeting}}</view>
          <view class="hero-date">📅 {{dateStr}}</view>
        </view>
        <view class="hero-avatar" bindtap="goMine">
          <text>👤</text>
        </view>
      </view>

      <!-- 今日财务快看 -->
      <view class="hero-finance-card">
        <view class="finance-mini-row">
          <view class="finance-mini-item">
            <view class="finance-mini-label">今日收入</view>
            <view class="finance-mini-val income">+¥{{todayIncome}}</view>
          </view>
          <view class="finance-mini-divider"></view>
          <view class="finance-mini-item">
            <view class="finance-mini-label">今日支出</view>
            <view class="finance-mini-val expense">-¥{{todayExpense}}</view>
          </view>
          <view class="finance-mini-divider"></view>
          <view class="finance-mini-item">
            <view class="finance-mini-label">本月支出</view>
            <view class="finance-mini-val">¥{{monthExpense}}</view>
          </view>
        </view>
        <!-- 预算进度 -->
        <view wx:if="{{budget.monthly > 0}}" class="budget-bar-wrap">
          <view class="flex-between budget-bar-header">
            <text class="budget-label">月度预算 ¥{{budget.monthly}}</text>
            <text class="budget-percent {{budgetPercent >= 90 ? 'danger' : ''}}">{{budgetPercent}}%</text>
          </view>
          <view class="budget-bar-bg">
            <view class="budget-bar-fill {{budgetPercent >= 90 ? 'danger' : budgetPercent >= 70 ? 'warning' : ''}}" style="width:{{budgetPercent}}%"></view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 快捷功能入口 -->
  <view class="section-card">
    <view class="section-title-row">
      <text class="section-t">⚡ 快捷功能</text>
    </view>
    <view class="quick-grid">
      <view class="quick-item" wx:for="{{quickEntries}}" wx:key="label"
            bindtap="goTo" data-path="{{item.path}}">
        <view class="quick-icon-wrap" style="background:{{item.bg}}">
          <text class="quick-icon">{{item.icon}}</text>
        </view>
        <text class="quick-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <!-- 待办事项预览 -->
  <view class="section-card">
    <view class="section-title-row">
      <text class="section-t">✅ 今日待办</text>
    </view>
    <view wx:if="{{todoList.length > 0}}">
      <view class="todo-item" wx:for="{{todoList}}" wx:key="id">
        <view class="todo-dot {{item.priority === 'high' ? 'dot-high' : item.priority === 'mid' ? 'dot-mid' : 'dot-low'}}"></view>
        <text class="todo-text">{{item.text}}</text>
      </view>
    </view>
    <view wx:else class="empty-hint">
      <text>暂无待办，去添加一个吧 ✨</text>
    </view>
  </view>

  <!-- 学习笔记预览 -->
  <view class="section-card">
    <view class="section-title-row">
      <text class="section-t">📚 最近学习</text>
    </view>
    <view wx:if="{{studyNotes.length > 0}}">
      <view class="note-preview" wx:for="{{studyNotes}}" wx:key="id">
        <view class="note-preview-icon">{{item.icon || '📝'}}</view>
        <view class="flex-1">
          <view class="note-preview-title">{{item.title}}</view>
          <view class="note-preview-sub">{{item.category}} · {{item.date}}</view>
        </view>
      </view>
    </view>
    <view wx:else class="empty-hint">
      <text>还没有学习记录，开始学习吧 🚀</text>
    </view>
  </view>

  <!-- 每日小贴士 -->
  <view class="tip-banner">
    <text class="tip-icon">💬</text>
    <text class="tip-text">{{tips[currentTip]}}</text>
  </view>

  <view style="height:32rpx"></view>
</view>
