/* pages/index/index.wxss - 首页样式 */

/* ===== 渐变头部 ===== */
.hero-header {
  background: linear-gradient(135deg, #6C63FF 0%, #A594F9 100%);
  padding: 0 32rpx 60rpx;
  position: relative;
  overflow: hidden;
}

.hero-bg-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.hero-bg-circle.c1 {
  width: 300rpx;
  height: 300rpx;
  top: -100rpx;
  right: -50rpx;
}

.hero-bg-circle.c2 {
  width: 200rpx;
  height: 200rpx;
  top: 50rpx;
  left: -80rpx;
}

.hero-bg-circle.c3 {
  width: 150rpx;
  height: 150rpx;
  bottom: -50rpx;
  right: 20%;
}

.status-bar-placeholder {
  height: env(safe-area-inset-top);
}

.hero-content {
  position: relative;
  z-index: 1;
}

.hero-greeting {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.hero-date {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.hero-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

/* ===== 财务卡片 ===== */
.hero-finance-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-top: 32rpx;
  box-shadow: 0 8rpx 30rpx rgba(108, 99, 255, 0.2);
}

.finance-mini-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.finance-mini-item {
  flex: 1;
  text-align: center;
}

.finance-mini-label {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.finance-mini-val {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.finance-mini-val.income {
  color: #43D9AD;
}

.finance-mini-val.expense {
  color: #FF6584;
}

.finance-mini-divider {
  width: 1rpx;
  height: 50rpx;
  background: #eee;
}

/* ===== 预算进度条 ===== */
.budget-bar-wrap {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.budget-bar-header {
  margin-bottom: 12rpx;
}

.budget-label {
  font-size: 24rpx;
  color: #666;
}

.budget-percent {
  font-size: 24rpx;
  color: #6C63FF;
  font-weight: 600;
}

.budget-percent.danger {
  color: #FF5252;
}

.budget-bar-bg {
  height: 12rpx;
  background: #F0F0F0;
  border-radius: 6rpx;
  overflow: hidden;
}

.budget-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #6C63FF, #A594F9);
  border-radius: 6rpx;
  transition: width 0.3s;
}

.budget-bar-fill.warning {
  background: linear-gradient(90deg, #FFB347, #FF9800);
}

.budget-bar-fill.danger {
  background: linear-gradient(90deg, #FF6584, #FF5252);
}

/* ===== 快捷入口 ===== */
.quick-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -12rpx;
}

.quick-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
}

.quick-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.quick-icon {
  font-size: 48rpx;
}

.quick-label {
  font-size: 24rpx;
  color: #666;
}

/* ===== 待办列表 ===== */
.todo-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.todo-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.dot-high {
  background: #FF5252;
}

.dot-mid {
  background: #FFB347;
}

.dot-low {
  background: #43D9AD;
}

.todo-text {
  font-size: 28rpx;
  color: #333;
}

/* ===== 学习笔记预览 ===== */
.note-preview {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.note-preview-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.note-preview-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 4rpx;
}

.note-preview-sub {
  font-size: 22rpx;
  color: #999;
}

/* ===== 每日小贴士 ===== */
.tip-banner {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #FFF8E1, #FFECB3);
  margin: 0 24rpx 24rpx;
  padding: 24rpx 28rpx;
  border-radius: 16rpx;
}

.tip-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.tip-text {
  flex: 1;
  font-size: 26rpx;
  color: #8D6E63;
  line-height: 1.5;
}
