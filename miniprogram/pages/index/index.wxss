/* ========== Back to Top Button - Circular Action ========== */
/* Circular Action: #e0e0d9 bg, #211922 icon, 50% radius */
.back-top-btn {
  position: fixed;
  right: 32rpx;
  bottom: 120rpx;
  width: 96rpx;
  height: 96rpx;
  background: var(--surface-warm-light);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  transition: all 0.15s ease;
}

.back-top-btn:active {
  transform: scale(0.95);
}

.back-top-btn.focus-ring:focus {
  outline: 3rpx solid var(--border-focus);
  outline-offset: 2rpx;
}

