/* pages/index/index.wxss - 智伴口袋首页样式 */

.page-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #F8F6FF 0%, #F0EDFF 100%);
  padding: 20rpx 30rpx 100rpx;
}

/* 问候区域 */
.greeting-section {
  padding: 40rpx 0 30rpx;
  text-align: center;
}

.greeting-text {
  font-size: 48rpx;
  font-weight: 600;
  color: #333333;
  line-height: 1.4;
  margin-bottom: 10rpx;
}

.time-text {
  font-size: 28rpx;
  color: #7C6AFF;
  opacity: 0.8;
}

/* 通用区域标题 */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin: 40rpx 0 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex: 1;
}

.section-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 40rpx 0 20rpx;
}

.consecutive-days {
  font-size: 24rpx;
  color: #7C6AFF;
  font-weight: normal;
}

/* 分享卡片按钮 */
.share-card-btn {
  display: flex;
  align-items: center;
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(102,126,234,0.3);
  transition: all 0.2s ease;
}

.share-card-btn:active {
  transform: scale(0.95);
  opacity: 0.9;
}

.share-btn-icon {
  font-size: 24rpx;
  color: #FFFFFF;
  margin-right: 6rpx;
}

.share-btn-text {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 500;
}

/* 操作按钮行（分享+刷新） */
.action-btns-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.share-icon {
  font-size: 26rpx;
  color: #FFFFFF;
}

/* 主要动作区域 */
.main-actions-section {
  margin-top: 20rpx;
}

.actions-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.action-item {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(124, 106, 255, 0.08);
  transition: transform 0.2s;
}

.action-item:active {
  transform: scale(0.98);
}

.action-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  font-size: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20rpx;
  color: white;
}

.action-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
  line-height: 1.3;
}

.action-desc {
  font-size: 22rpx;
  color: #999999;
  line-height: 1.2;
}

/* 每日卡片 */
.daily-card-section {
  margin-top: 40rpx;
}

.card-container {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(124, 106, 255, 0.1);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.card-date {
  font-size: 24rpx;
  color: #999999;
}

.card-mood {
  font-size: 24rpx;
  color: #7C6AFF;
  font-weight: 500;
}

.card-content {
  line-height: 1.6;
}

.encouragement {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 20rpx;
}

.review {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 20rpx;
}

.suggestion {
  font-size: 26rpx;
  color: #7C6AFF;
  font-weight: 500;
  margin-bottom: 10rpx;
}

.pending {
  font-size: 24rpx;
  color: #FF9A76;
  background: rgba(255, 154, 118, 0.1);
  padding: 12rpx 20rpx;
  border-radius: 12rpx;
  margin-top: 15rpx;
}

/* 快速模式 */
.quick-modes-section {
  margin-top: 40rpx;
}

.modes-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.mode-item {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  transition: all 0.2s;
}

.mode-item:active {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(124, 106, 255, 0.15);
}

.mode-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 15rpx;
  color: white;
}

.mode-name {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
}

/* 近期状态 */
.recent-section {
  margin-top: 40rpx;
}

.recent-mood {
  background: white;
  border-radius: 20rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.mood-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.mood-label {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
}

.mood-time {
  font-size: 22rpx;
  color: #999999;
}

.mood-content {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.mood-emoji {
  font-size: 32rpx;
}

.mood-text {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.mood-note {
  font-size: 26rpx;
  color: #666666;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 待完成目标 */
.pending-goals {
  background: white;
  border-radius: 20rpx;
  padding: 24rpx 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.goals-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.goals-label {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
}

.goals-count {
  font-size: 24rpx;
  color: #7C6AFF;
  font-weight: 500;
}

.goal-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F8F8F8;
}

.goal-item:last-child {
  border-bottom: none;
}

.goal-checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #DDDDDD;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.checkbox-icon {
  font-size: 24rpx;
  color: #999999;
}

.goal-content {
  flex: 1;
  font-size: 26rpx;
  color: #333333;
  line-height: 1.4;
}

.goal-deadline {
  font-size: 22rpx;
  color: #FF9A76;
  margin-left: 20rpx;
}

.add-goal-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  color: #7C6AFF;
  font-size: 26rpx;
  font-weight: 500;
  margin-top: 15rpx;
  border-radius: 12rpx;
  border: 1rpx dashed #7C6AFF;
  background: rgba(124, 106, 255, 0.05);
}

.plus-icon {
  font-size: 30rpx;
  margin-right: 10rpx;
}

/* 昵称设置弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.nickname-modal {
  background: white;
  border-radius: 32rpx;
  width: 600rpx;
  max-width: 90vw;
  padding: 40rpx;
  box-shadow: 0 16rpx 64rpx rgba(0, 0, 0, 0.15);
}

.modal-header {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  text-align: center;
  margin-bottom: 30rpx;
}

.modal-content {
  margin-bottom: 40rpx;
}

.modal-text {
  font-size: 28rpx;
  color: #666666;
  text-align: center;
  margin-bottom: 30rpx;
  line-height: 1.5;
}

.nickname-input {
  border: 2rpx solid #7C6AFF;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333333;
  text-align: center;
  margin-bottom: 20rpx;
}

.modal-tip {
  font-size: 24rpx;
  color: #999999;
  text-align: center;
}

.modal-actions {
  display: flex;
  justify-content: center;
}

.btn-save {
  background: #7C6AFF;
  color: white;
  border-radius: 16rpx;
  padding: 20rpx 60rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
}

.btn-save:active {
  opacity: 0.9;
}

/* 今日名言 */
.quote-section {
  margin-top: 40rpx;
}

.quote-share-btn {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(102,126,234,0.3);
}

.quote-refresh-btn {
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  background: linear-gradient(135deg, #7C6AFF 0%, #9B8AFF 100%);
  border-radius: 24rpx;
  color: white;
  font-size: 24rpx;
}

.refresh-icon {
  font-size: 26rpx;
  margin-right: 6rpx;
}

.refresh-text {
  font-weight: 500;
}

.quote-card {
  background: linear-gradient(135deg, #FFFFFF 0%, #F8F6FF 100%);
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(124, 106, 255, 0.12);
  position: relative;
  overflow: hidden;
}

.quote-card::before {
  content: '"';
  position: absolute;
  top: 10rpx;
  left: 20rpx;
  font-size: 120rpx;
  color: #7C6AFF;
  opacity: 0.1;
  font-family: serif;
  line-height: 1;
}

.quote-domain-tag {
  display: inline-flex;
  align-items: center;
  background: rgba(124, 106, 255, 0.1);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
}

.quote-domain-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.quote-domain-name {
  font-size: 22rpx;
  color: #7C6AFF;
  font-weight: 500;
}

.quote-ai-tag {
  font-size: 18rpx;
  color: #FF9A76;
  background: rgba(255, 154, 118, 0.15);
  padding: 4rpx 10rpx;
  border-radius: 10rpx;
  margin-left: 12rpx;
  font-weight: 600;
}

.quote-text {
  font-size: 30rpx;
  color: #333333;
  line-height: 1.6;
  margin-bottom: 24rpx;
  padding-left: 20rpx;
  font-style: italic;
}

.quote-author {
  font-size: 26rpx;
  color: #666666;
  text-align: right;
  margin-bottom: 20rpx;
}

.quote-meta {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(124, 106, 255, 0.1);
}

.quote-era {
  font-size: 22rpx;
  color: #7C6AFF;
  background: rgba(124, 106, 255, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

.quote-era.modern {
  color: #FF9A76;
  background: rgba(255, 154, 118, 0.1);
}

.quote-region {
  font-size: 28rpx;
}

.quote-loading {
  text-align: center;
  padding: 60rpx 40rpx;
  color: #999999;
  font-size: 26rpx;
}

.loading-dots {
  display: flex;
  justify-content: center;
  margin-bottom: 20rpx;
}

.loading-dots .dot {
  font-size: 48rpx;
  color: #7C6AFF;
  animation: dotPulse 1.4s infinite ease-in-out;
  margin: 0 8rpx;
}

.loading-dots .dot:nth-child(1) { animation-delay: 0s; }
.loading-dots .dot:nth-child(2) { animation-delay: 0.2s; }
.loading-dots .dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes dotPulse {
  0%, 80%, 100% { opacity: 0.3; transform: scale(0.8); }
  40% { opacity: 1; transform: scale(1.2); }
}

.loading-text {
  color: #7C6AFF;
  font-size: 26rpx;
}

.quote-placeholder {
  text-align: center;
  padding: 60rpx 40rpx;
  color: #BBBBBB;
  font-size: 26rpx;
}

.btn-active {
  opacity: 0.7;
  transform: scale(0.95);
}

