  box-shadow: 0 8rpx 32rpx rgba(255, 107, 157, 0.15);
  border: 1rpx solid rgba(255, 107, 157, 0.2);
}

.love-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
