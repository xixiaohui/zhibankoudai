/* pages/index/index.wxss - Pinterest Design System */

/* ========== Pinterest Design Tokens ========== */
.page-container {
  /* Pinterest Brand Colors */
  --pinterest-red: #e60023;
  --pinterest-plum: #211922;
  
  /* Text Colors */
  --text-primary: #211922;
  --text-secondary: #62625b;
  --text-muted: #91918c;
  --text-white: #ffffff;
  --text-black: #000000;
  
  /* Surface Colors - Warm Neautrals */
  --surface-white: #ffffff;
  --surface-fog: #f6f6f3;
  --surface-sand: #e5e5e0;
  --surface-warm-light: #e0e0d9;
  
  /* Border Colors */
  --border-light: #c8c8c1;
  --border-focus: #435ee5;
  --border-hover: #bcbcb3;
  
  /* Badge Background - Warm Wash */
  --badge-wash: hsla(60, 20%, 98%, 0.5);
  
  /* Semantic Colors */
  --success: #103c25;
  --error: #9e0a0a;
  
  /* Border Radius - Pinterest Scale */
  --radius-sm: 12rpx;
  --radius-md: 16rpx;
  --radius-lg: 20rpx;
  --radius-xl: 28rpx;
  --radius-section: 32rpx;
  --radius-hero: 40rpx;
  
  /* Spacing - 8px Base Unit */
  --space-xs: 8rpx;
  --space-sm: 12rpx;
  --space-md: 16rpx;
  --space-lg: 24rpx;
  --space-xl: 32rpx;
  
  /* Typography */
  --font-family: -apple-system, system-ui, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
}

/* ========== Page Container ========== */
.page-container {
  min-height: 100vh;
  background: var(--surface-white);
  padding: 20rpx 32rpx 120rpx;
  font-family: var(--font-family);
  color: var(--text-primary);
  -webkit-font-smoothing: antialiased;
}

/* ========== Greeting Section ========== */
.greeting-section {
  padding: 40rpx 0 30rpx;
  text-align: center;
}

.greeting-text {
  font-size: 48rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.4;
  margin-bottom: 10rpx;
  letter-spacing: -1.2rpx;
}

.time-text {
  font-size: 28rpx;
  color: var(--pinterest-red);
  opacity: 0.9;
}

/* ========== Section Titles ========== */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin: 40rpx 10rpx 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex: 1;
  letter-spacing: -1.2rpx;
}

.section-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 40rpx 0 20rpx;
}

.consecutive-days {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: normal;
}

/* ========== Share Card Button - Pinterest Primary Red ========== */
/* Pinterest Primary Red: #e60023, text: #000000, radius: 16px */
.share-card-btn {
  display: flex;
  align-items: center;
  padding: 12rpx 28rpx;
  background: var(--pinterest-red);
  border-radius: var(--radius-md);
  border: 2rpx solid rgba(255, 255, 255, 0);
  transition: all 0.15s ease;
}

.share-card-btn:active {
  transform: scale(0.95);
  opacity: 0.9;
}

.share-card-btn.focus-ring:focus {
  outline: 3rpx solid var(--border-focus);
  outline-offset: 2rpx;
}

.share-btn-icon {
  font-size: 24rpx;
  color: var(--text-black);
  margin-right: 6rpx;
}

.share-btn-text {
  font-size: 24rpx;
  color: var(--text-black);
  font-weight: 400;
}

/* ========== Action Buttons Row ========== */
.action-btns-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.share-icon {
  font-size: 26rpx;
  color: var(--text-white);
}

/* ========== Main Actions Section ========== */
.main-actions-section {
  margin-top: 20rpx;
}

.actions-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.action-item {
  background: var(--surface-white);
  border-radius: var(--radius-lg);
  padding: 30rpx 20rpx;
  text-align: center;
  border: 1rpx solid var(--border-light);
  transition: transform 0.15s ease;
}

.action-item:active {
  transform: scale(0.98);
}

.action-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  font-size: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20rpx;
  color: var(--text-white);
}

.action-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
  line-height: 1.3;
  letter-spacing: -0.5rpx;
}

.action-desc {
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.2;
}

/* ========== Daily Card Section ========== */
/* Pinterest Card: white bg, 16-20px radius, no shadow */
.daily-card-section {
  margin-top: 40rpx;
}

/* ========== Module Guide ========== */
.module-guide {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #f8f9ff 0%, #f0f4ff 100%);
  border-radius: var(--radius-lg);
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #e0e4ff;
}

.module-guide:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.guide-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.guide-content {
  flex: 1;
}

.guide-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.guide-desc {
  font-size: 24rpx;
  color: #888;
}

.guide-arrow {
  font-size: 40rpx;
  color: #ccc;
  font-weight: 300;
}

.card-container {
  background: var(--surface-white);
  border-radius: var(--radius-lg);
  padding: 30rpx;
  border: 1rpx solid var(--border-light);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--surface-sand);
}

.card-date {
  font-size: 24rpx;
  color: var(--text-muted);
}

.card-mood {
  font-size: 24rpx;
  color: var(--pinterest-red);
  font-weight: 500;
}

.card-content {
  line-height: 1.6;
}

.encouragement {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
  margin-bottom: 20rpx;
}

.review {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 20rpx;
}

.suggestion {
  font-size: 26rpx;
  color: var(--pinterest-red);
  font-weight: 500;
  margin-bottom: 10rpx;
}

.pending {
  font-size: 24rpx;
  color: var(--pinterest-red);
  background: var(--badge-wash);
  padding: 12rpx 20rpx;
  border-radius: var(--radius-md);
  margin-top: 15rpx;
}

/* ========== Quick Modes Section ========== */
/* Circular Action Button: #e0e0d9 background, #211922 icon, 50% radius */
.quick-modes-section {
  margin-top: 40rpx;
}

.modes-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.mode-item {
  background: var(--surface-white);
  border-radius: var(--radius-lg);
  padding: 30rpx 20rpx;
  text-align: center;
  border: 1rpx solid var(--border-light);
  transition: all 0.15s ease;
}

.mode-item:active {
  transform: scale(0.98);
}

.mode-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: var(--surface-warm-light);
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 15rpx;
  color: var(--text-primary);
}

.mode-name {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
}

/* ========== Recent Section ========== */
.recent-section {
  margin-top: 40rpx;
}

.recent-mood {
  background: var(--surface-white);
  border-radius: 16px;
  padding: 24rpx 30rpx;
  margin-bottom: 20rpx;
  border: 1px solid var(--border-light);
}

.mood-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.mood-label {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.mood-time {
  font-size: 22rpx;
  color: var(--text-muted);
}

.mood-content {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.mood-emoji {
  font-size: 32rpx;
}

.mood-text {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.mood-note {
  font-size: 26rpx;
  color: var(--text-secondary);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ========== Pending Goals ========== */
.pending-goals {
  background: var(--surface-white);
  border-radius: 16px;
  padding: 24rpx 30rpx;
  border: 1px solid var(--border-light);
}

.goals-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid var(--surface-sand);
}

.goals-label {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.goals-count {
  font-size: 24rpx;
  color: var(--pinterest-red);
  font-weight: 500;
}

.goal-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--surface-fog);
}

.goal-item:last-child {
  border-bottom: none;
}

.goal-checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid var(--border-light);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.checkbox-icon {
  font-size: 24rpx;
  color: var(--text-muted);
}

.goal-content {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-primary);
  line-height: 1.4;
}

.goal-deadline {
  font-size: 22rpx;
  color: var(--pinterest-red);
  margin-left: 20rpx;
}

/* ========== Add Goal Button - Pinterest Secondary Sand ========== */
.add-goal-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  color: var(--text-secondary);
  font-size: 26rpx;
  font-weight: 500;
  margin-top: 15rpx;
  border-radius: var(--radius-md);
  background: var(--surface-sand);
  border: 1rpx solid var(--border-light);
  transition: all 0.15s ease;
}

.add-goal-btn.focus-ring:focus {
  outline: 3rpx solid var(--border-focus);
  outline-offset: 2rpx;
}

.plus-icon {
  font-size: 30rpx;
  margin-right: 10rpx;
}

/* ========== Nickname Modal ========== */
/* Pinterest Modal: warm overlay, generous radius */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(33, 25, 34, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.nickname-modal {
  background: var(--surface-white);
  border-radius: var(--radius-section);
  width: 600rpx;
  max-width: 90vw;
  padding: 48rpx 40rpx;
}

.modal-header {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  text-align: center;
  margin-bottom: 30rpx;
  letter-spacing: -1.2rpx;
}

.modal-content {
  margin-bottom: 40rpx;
}

.modal-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  text-align: center;
  margin-bottom: 30rpx;
  line-height: 1.5;
}

/* Pinterest Input: white bg, #91918c border, 16px radius */
.nickname-input {
  border: 1rpx solid var(--text-muted);
  border-radius: var(--radius-md);
  padding: 22rpx 30rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  text-align: center;
  margin-bottom: 20rpx;
  background: var(--surface-white);
}

.nickname-input.focus-ring:focus {
  outline: 3rpx solid var(--border-focus);
  outline-offset: 2rpx;
}

.modal-tip {
  font-size: 24rpx;
  color: var(--text-muted);
  text-align: center;
}

.modal-actions {
  display: flex;
  justify-content: center;
}

/* Pinterest Primary Button: #e60023 bg, #000000 text, 16px radius */
.btn-save {
  background: var(--pinterest-red);
  color: var(--text-black);
  border-radius: var(--radius-md);
  padding: 20rpx 60rpx;
  font-size: 28rpx;
  font-weight: 400;
  border: none;
}

.btn-save:active {
  opacity: 0.9;
}

/* ========== Quote Section ========== */
.quote-section {
  margin-top: 40rpx;
}

.quote-share-btn {
  width: 56rpx;
  height: 56rpx;
  background: var(--surface-warm-light);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.quote-share-btn:active {
  transform: scale(0.95);
}

.quote-refresh-btn {
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  background: var(--surface-warm-light);
  border-radius: var(--radius-md);
  color: var(--text-primary);
  font-size: 24rpx;
  transition: all 0.15s ease;
}

.quote-refresh-btn:active {
  opacity: 0.8;
}

.quote-refresh-btn.focus-ring:focus {
  outline: 3rpx solid var(--border-focus);
  outline-offset: 2rpx;
}

.refresh-icon {
  font-size: 26rpx;
  margin-right: 6rpx;
}

.refresh-text {
  font-weight: 500;
}

.quote-card {
  background: var(--surface-white);
  border-radius: var(--radius-lg);
  padding: 36rpx 32rpx;
  border: 1rpx solid var(--border-light);
  position: relative;
  overflow: hidden;
}

.quote-card::before {
  content: '"';
  position: absolute;
  top: 10rpx;
  left: 20rpx;
  font-size: 120rpx;
  color: var(--surface-sand);
  font-family: serif;
  line-height: 1;
}

.quote-domain-tag {
  display: inline-flex;
  align-items: center;
  background: var(--badge-wash);
  padding: 8rpx 20rpx;
  border-radius: 50px;
  margin-bottom: 24rpx;
}

.quote-domain-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.quote-domain-name {
  font-size: 22rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.quote-ai-tag {
  font-size: 18rpx;
  color: var(--text-muted);
  background: var(--surface-sand);
  padding: 4rpx 10rpx;
  border-radius: 50px;
  margin-left: 12rpx;
  font-weight: 500;
}

.quote-text {
  font-size: 30rpx;
  color: var(--text-primary);
  line-height: 1.7;
  margin-bottom: 24rpx;
  padding-left: 20rpx;
  font-style: italic;
  font-weight: 400;
}

.quote-author {
  font-size: 26rpx;
  color: var(--text-secondary);
  text-align: right;
  margin-bottom: 20rpx;
}

.quote-meta {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--surface-sand);
}

.quote-era {
  font-size: 22rpx;
  color: var(--text-secondary);
  background: var(--surface-fog);
  padding: 6rpx 16rpx;
  border-radius: 50px;
  font-weight: 500;
}

.quote-era.modern {
  color: var(--text-secondary);
  background: var(--surface-sand);
}

.quote-region {
  font-size: 28rpx;
}

.quote-loading {
  text-align: center;
  padding: 60rpx 40rpx;
  color: var(--text-muted);
  font-size: 26rpx;
}

.loading-dots {
  display: flex;
  justify-content: center;
  margin-bottom: 20rpx;
}

.loading-dots .dot {
  font-size: 48rpx;
  color: var(--text-muted);
  animation: dotPulse 1.4s infinite ease-in-out;
  margin: 0 8rpx;
}

.loading-dots .dot:nth-child(1) { animation-delay: 0s; }
.loading-dots .dot:nth-child(2) { animation-delay: 0.2s; }
.loading-dots .dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes dotPulse {
  0%, 80%, 100% { opacity: 0.3; transform: scale(0.8); }
  40% { opacity: 1; transform: scale(1.2); }
}

.loading-text {
  color: var(--text-secondary);
  font-size: 26rpx;
}

.quote-placeholder {
  text-align: center;
  padding: 60rpx 40rpx;
  color: var(--text-muted);
  font-size: 26rpx;
}

.btn-active {
  opacity: 0.7;
  transform: scale(0.95);
}

/* ========== Joke Section ========== */
.joke-section {
  margin-top: 40rpx;
}

.joke-share-btn {
  width: 56rpx;
  height: 56rpx;
