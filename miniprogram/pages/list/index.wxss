/* pages/list/index.wxss - 内容列表页样式 */

/* 页面容器 */
.list-page {
  min-height: 100vh;
  background: #F8F6FF;
  display: flex;
  flex-direction: column;
}

/* 横向导航栏 */
.module-nav {
  position: sticky;
  top: 0;
  z-index: 100;
  background: #fff;
  padding: 20rpx 0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.nav-inner {
  display: flex;
  flex-direction: row;
  padding: 0 24rpx;
  gap: 16rpx;
  white-space: nowrap;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 28rpx;
  border-radius: 24rpx;
  border: 2rpx solid transparent;
  background: #fff;
  min-width: 100rpx;
  white-space: nowrap;
  transition: all 0.3s ease;
}

.nav-item.active {
  color: #fff;
}

.nav-icon {
  font-size: 32rpx;
  margin-bottom: 6rpx;
}

.nav-text {
  font-size: 24rpx;
  font-weight: 500;
}

.nav-text.active-text {
  color: #fff;
}

/* 内容区域 */
.content-area {
  flex: 1;
  padding: 24rpx;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(0, 0, 0, 0.1);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  opacity: 0.5;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
}

/* 内容列表 */
.content-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 内容卡片 */
.content-card {
  border-radius: 24rpx;
  padding: 28rpx;
  transition: transform 0.2s ease;
}

.content-card:active {
  transform: scale(0.98);
}

/* 卡片头部 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-tags {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.tag-item {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}

.tag-ai {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.card-actions {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

/* 卡片内容 */
.card-body {
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.card-summary {
  font-size: 28rpx;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.card-tips {
  font-size: 26rpx;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  line-height: 1.5;
}

/* 名言样式 */
.quote-content {
  font-size: 32rpx;
  line-height: 1.6;
  font-style: italic;
  margin-bottom: 16rpx;
}

.quote-author {
  font-size: 28rpx;
  text-align: right;
}

/* 电影样式 */
.movie-header, .music-header, .lit-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.movie-title, .music-title {
  font-size: 32rpx;
  font-weight: 600;
  flex: 1;
}

.movie-rating, .music-mood {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  margin-left: 16rpx;
}

.movie-meta, .music-meta, .lit-era {
  font-size: 26rpx;
  margin-bottom: 16rpx;
}

.movie-summary, .music-description, .lit-summary {
  font-size: 28rpx;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.movie-quote, .music-lyric, .lit-quote {
  font-size: 26rpx;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  font-style: italic;
  line-height: 1.5;
}

/* 文学样式 */
.lit-author {
  font-size: 32rpx;
  font-weight: 600;
}

.lit-works {
  font-size: 26rpx;
  margin-bottom: 16rpx;
}

/* 卡片底部 */
.card-footer {
  display: flex;
  justify-content: flex-end;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}

.card-date {
  font-size: 24rpx;
}

/* 加载更多 */
.load-more {
  padding: 32rpx 0;
  display: flex;
  justify-content: center;
}

.load-more-btn {
  padding: 16rpx 48rpx;
  border-radius: 32rpx;
  background: rgba(124, 106, 255, 0.1);
}

.loading-dots {
  display: flex;
  gap: 8rpx;
}

.dot {
  font-size: 32rpx;
  animation: dotPulse 1.4s infinite ease-in-out;
}

.dot:nth-child(2) {
  animation-delay: 0.2s;
}

.dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes dotPulse {
  0%, 80%, 100% { opacity: 0.4; }
  40% { opacity: 1; }
}

.no-more {
  padding: 16rpx 0;
}
