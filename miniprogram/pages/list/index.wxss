/* pages/list/index.wxss - Pinterest Design System */

.list-page {
  min-height: 100vh;
  background: var(--surface-secondary);
  display: flex;
  flex-direction: column;
}

.module-nav {
  position: sticky;
  top: 0;
  z-index: 100;
  background: var(--surface);
  padding: var(--space-sm) 0;
  border-bottom: 1rpx solid var(--border);
}

.nav-inner {
  display: flex;
  flex-direction: row;
  padding: 0 var(--space-md);
  gap: var(--space-sm);
  white-space: nowrap;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-sm) var(--space-md);
  border-radius: var(--radius-md);
  border: 2rpx solid transparent;
  background: var(--surface);
  min-width: 140rpx;
  max-width: 180rpx;
  white-space: nowrap;
  transition: all 0.3s ease;
  overflow: hidden;
}

.nav-item.active {
  color: var(--surface);
  background-color: var(--text-secondary);
}

.nav-icon {
  font-size: var(--font-size-xl);
  margin-bottom: 6rpx;
}

.nav-text {
  font-size: var(--font-size-sm);
  font-weight: 500;
  color: var(--text-secondary);
}

.nav-text.active-text {
  color: var(--surface);
}

.content-area {
  flex: 1;
  padding: var(--space-md);
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--border);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: var(--space-md);
  font-size: var(--font-size-base);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  opacity: 0.5;
  margin-bottom: var(--space-md);
}

.empty-title {
  font-size: var(--font-size-xl);
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: var(--space-xs);
}

.empty-desc {
  font-size: var(--font-size-base);
  color: var(--text-placeholder);
}

.content-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.content-card {
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
  transition: transform 0.2s ease;
  background-color: var(--surface);
  border: 1rpx solid var(--border);
  margin-right: var(--space-lg);
}

.content-card:active {
  transform: scale(0.98);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-md);
}

.card-tags {
  display: flex;
  gap: var(--space-xs);
  flex-wrap: wrap;
}

.tag-item {
  font-size: var(--font-size-xs);
  padding: 4rpx var(--space-xs);
  border-radius: var(--radius-full);
  background-color: var(--accent-warm-light);
  color: var(--text-primary);
}

.tag-ai {
  font-size: 20rpx;
  padding: 2rpx var(--space-xs);
  border-radius: var(--radius-sm);
  background-color: var(--surface-secondary);
}

.card-actions {
  display: flex;
  gap: var(--space-xs);
}

.action-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  background-color: var(--surface-secondary);
}

.card-body {
  margin-bottom: var(--space-md);
}

.card-title {
  font-size: var(--font-size-xl);
  font-weight: 600;
  margin-bottom: var(--space-sm);
  line-height: 1.4;
  color: var(--text-primary);
}

.card-summary {
  font-size: var(--font-size-base);
  line-height: 1.6;
  margin-bottom: var(--space-sm);
  color: var(--text-secondary);
}

.card-tips {
  font-size: var(--font-size-base);
  padding: var(--space-sm);
  border-radius: var(--radius-md);
  line-height: 1.5;
  background-color: var(--surface-secondary);
}

.quote-content {
  font-size: var(--font-size-xl);
  line-height: 1.6;
  font-style: italic;
  margin-bottom: var(--space-sm);
  color: var(--text-primary);
}

.quote-author {
  font-size: var(--font-size-base);
  text-align: right;
  color: var(--text-secondary);
}

.movie-header, .music-header, .lit-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-xs);
}

.movie-title, .music-title {
  font-size: var(--font-size-xl);
  font-weight: 600;
  flex: 1;
  color: var(--text-primary);
}

.movie-rating, .music-mood {
  font-size: var(--font-size-sm);
  padding: 4rpx var(--space-sm);
  border-radius: var(--radius-full);
  margin-left: var(--space-sm);
  background-color: var(--accent-warm-light);
  color: var(--text-primary);
}

.movie-meta, .music-meta, .lit-era {
  font-size: var(--font-size-base);
  margin-bottom: var(--space-sm);
  color: var(--text-secondary);
}

.movie-summary, .music-description, .lit-summary {
  font-size: var(--font-size-base);
  line-height: 1.6;
  margin-bottom: var(--space-sm);
  color: var(--text-primary);
}

.movie-quote, .music-lyric, .lit-quote {
  font-size: var(--font-size-sm);
  padding: var(--space-sm);
  border-radius: var(--radius-md);
  font-style: italic;
  line-height: 1.5;
  background-color: var(--surface-secondary);
  color: var(--text-secondary);
}

.lit-author {
  font-size: var(--font-size-xl);
  font-weight: 600;
  color: var(--text-primary);
}

.lit-works {
  font-size: var(--font-size-base);
  margin-bottom: var(--space-sm);
  color: var(--text-secondary);
}

.card-footer {
  display: flex;
  justify-content: flex-end;
  padding-top: var(--space-sm);
  border-top: 1rpx solid var(--border);
}

.card-date {
  font-size: var(--font-size-sm);
  color: var(--text-placeholder);
}

.load-more {
  padding: var(--space-lg) 0;
  display: flex;
  justify-content: center;
}

.load-more-btn {
  padding: var(--space-sm) var(--space-xl);
  border-radius: var(--radius-full);
  background: var(--accent-warm-light);
  color: var(--text-primary);
}

.loading-dots {
  display: flex;
  gap: 8rpx;
}

.dot {
  font-size: var(--font-size-xl);
  animation: dotPulse 1.4s infinite ease-in-out;
}

.dot:nth-child(2) {
  animation-delay: 0.2s;
}

.dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes dotPulse {
  0%, 80%, 100% { opacity: 0.4; }
  40% { opacity: 1; }
}

.no-more {
  padding: var(--space-sm) 0;
}

.code-block-container {
  margin: var(--space-sm) 0;
}

.code-section-title {
  font-size: var(--font-size-base);
  font-weight: 500;
  margin-bottom: var(--space-xs);
}

.code-block {
  background: var(--text-primary);
  border-radius: var(--radius-md);
  overflow: hidden;
  margin-bottom: var(--space-sm);
}

.code-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-xs) var(--space-sm);
  background: var(--text-secondary);
}

.code-lang {
  font-size: var(--font-size-xs);
  color: var(--surface);
  text-transform: uppercase;
}

.code-copy-btn {
  padding: 4rpx var(--space-xs);
  background: var(--success);
  border-radius: var(--radius-sm);
  font-size: var(--font-size-xs);
  color: var(--surface);
}

.code-copy-btn:active {
  opacity: 0.8;
}

.code-content {
  padding: var(--space-sm);
  white-space: pre;
  overflow-x: auto;
}

.code-text {
  font-family: 'SF Mono', Monaco, 'Courier New', monospace;
  font-size: var(--font-size-sm);
  line-height: 1.6;
  color: var(--surface);
  white-space: pre-wrap;
  word-break: break-all;
}
