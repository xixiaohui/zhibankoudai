/* miniprogram/pages/uploadData/uploadData.wxss */
.container {
  padding: 40rpx;
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: #999;
}

.status-box {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.status-label {
  font-size: 28rpx;
  color: #666;
}

.status-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #07c160;
}

.log-box {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
  min-height: 400rpx;
}

.log-title {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.log-content {
  height: 350rpx;
  background: #1a1a1a;
  border-radius: 8rpx;
  padding: 20rpx;
}

.log-item {
  display: block;
  font-size: 24rpx;
  line-height: 1.8;
  font-family: monospace;
}

.log-item.info { color: #fff; }
.log-item.success { color: #07c160; }
.log-item.error { color: #ff4d4f; }
.log-item.warn { color: #faad14; }

.upload-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #07c160, #04a152);
  color: #fff;
  font-size: 32rpx;
  border-radius: 48rpx;
  border: none;
}

.upload-btn.disabled {
  background: #ccc;
}

.tip {
  margin-top: 30rpx;
  text-align: center;
}

.tip text {
  font-size: 24rpx;
  color: #999;
}
