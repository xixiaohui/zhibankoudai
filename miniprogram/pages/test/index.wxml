<!-- pages/test/index.wxml - 功能测试页面 -->
<view class="page-container">

  <!-- 页面标题 -->
  <view class="header">
    <view class="title">功能测试</view>
    <view class="subtitle">测试所有核心功能</view>
  </view>

  <!-- 云数据库测试 -->
  <view class="test-section">
    <view class="section-title">云数据库测试</view>
    <view class="test-card">
      <view class="test-item">
        <view class="test-info">
          <text class="test-name">初始化云数据库</text>
          <text class="test-desc">创建聊天消息、用户画像等集合</text>
        </view>
        <button class="test-btn" bindtap="onTestInitDb" loading="{{testing.initDb}}">
          {{testing.initDb ? '初始化中...' : '测试'}}
        </button>
      </view>
      
      <view class="test-item">
        <view class="test-info">
          <text class="test-name">保存消息到云端</text>
          <text class="test-desc">测试消息云端存储</text>
        </view>
        <button class="test-btn" bindtap="onTestSaveMessage" loading="{{testing.saveMsg}}">
          {{testing.saveMsg ? '测试中...' : '测试'}}
        </button>
      </view>
      
      <view class="test-item">
        <view class="test-info">
          <text class="test-name">从云端获取消息</text>
          <text class="test-desc">测试消息云端读取</text>
        </view>
        <button class="test-btn" bindtap="onTestGetMessages" loading="{{testing.getMsg}}">
          {{testing.getMsg ? '测试中...' : '测试'}}
        </button>
      </view>
    </view>
  </view>

  <!-- 本地存储测试 -->
  <view class="test-section">
    <view class="section-title">本地存储测试</view>
    <view class="test-card">
      <view class="test-item">
        <view class="test-info">
          <text class="test-name">对话历史数量</text>
          <text class="test-desc">{{localStats.chatHistory}} 条消息</text>
        </view>
        <button class="test-btn secondary" bindtap="onClearLocalChat">清空</button>
      </view>
      
      <view class="test-item">
        <view class="test-info">
          <text class="test-name">情绪记录数量</text>
          <text class="test-desc">{{localStats.moodRecords}} 条记录</text>
        </view>
        <button class="test-btn secondary" bindtap="onClearMoodRecords">清空</button>
      </view>
      
      <view class="test-item">
        <view class="test-info">
          <text class="test-name">用户画像</text>
          <text class="test-desc">{{localStats.profile || '未设置昵称'}}</text>
        </view>
        <button class="test-btn secondary" bindtap="onViewProfile">查看</button>
      </view>
    </view>
  </view>

  <!-- AI记忆测试 -->
  <view class="test-section">
    <view class="section-title">AI记忆系统</view>
    <view class="test-card">
      <view class="test-item">
        <view class="test-info">
          <text class="test-name">记忆健康度</text>
          <text class="test-desc">{{memoryStats.health}}%</text>
        </view>
        <view class="progress-bar">
          <view class="progress-fill" style="width: {{memoryStats.health}}%"></view>
        </view>
      </view>
      
      <view class="test-item">
        <view class="test-info">
          <text class="test-name">学到的事实</text>
          <text class="test-desc">{{memoryStats.learnedFacts}} 条</text>
        </view>
      </view>
      
      <view class="test-item">
        <view class="test-info">
          <text class="test-name">活跃目标</text>
          <text class="test-desc">{{memoryStats.activeGoals}} 个</text>
        </view>
      </view>
      
      <view class="test-item">
        <view class="test-info">
          <text class="test-name">对话总数</text>
          <text class="test-desc">{{memoryStats.totalConversations}} 次</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 页面导航测试 -->
  <view class="test-section">
    <view class="section-title">页面跳转测试</view>
    <view class="nav-grid">
      <view class="nav-item" bindtap="goToChat">
        <text class="nav-icon">💬</text>
        <text class="nav-text">聊天页面</text>
      </view>
      <view class="nav-item" bindtap="goToMood">
        <text class="nav-icon">😊</text>
        <text class="nav-text">心情记录</text>
      </view>
      <view class="nav-item" bindtap="goToMemory">
        <text class="nav-icon">🧠</text>
        <text class="nav-text">记忆管理</text>
      </view>
      <view class="nav-item" bindtap="goToHome">
        <text class="nav-icon">🏠</text>
        <text class="nav-text">首页</text>
      </view>
    </view>
  </view>

  <!-- 测试结果日志 -->
  <view class="test-section">
    <view class="section-title">测试日志</view>
    <view class="log-container">
      <block wx:for="{{logs}}" wx:key="time">
        <view class="log-item {{item.type}}">
          <text class="log-time">{{item.time}}</text>
          <text class="log-msg">{{item.msg}}</text>
        </view>
      </block>
      <view wx:if="{{logs.length === 0}}" class="log-empty">
        暂无日志
      </view>
    </view>
    <button class="clear-log-btn" bindtap="onClearLogs" wx:if="{{logs.length > 0}}">清空日志</button>
  </view>

</view>
